{% extends 'base_user.html.twig' %}

{% block title %}Mental Assessment - FitSense{% endblock %}

{% block user_page_title %}Mental Health Assessment{% endblock %}
{% block user_page_subtitle %}Answer these 5 questions to assess your current mental state{% endblock %}

{% block user_content %}
<div class="max-w-3xl mx-auto">
    <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-3xl shadow-2xl p-8 md:p-12 border border-gray-700/50">
        <!-- Decorative background elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-purple-500/10 to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-tr from-blue-500/10 to-transparent rounded-full blur-3xl"></div>

        <div class="relative">
            <div class="flex items-center gap-4 mb-10">
                <div class="w-12 h-12 bg-gradient-to-br from-purple-500 to-blue-500 rounded-2xl flex items-center justify-center shadow-lg shadow-purple-500/20">
                    <i class="fas fa-brain text-white text-xl"></i>
                </div>
                <div>
                    <h2 class="text-2xl font-bold text-white tracking-tight">Your Daily Check-in</h2>
                    <p class="text-gray-400 text-sm">Takes less than 2 minutes</p>
                </div>
            </div>

            {{ form_start(form, {'attr': {'class': 'space-y-8', 'novalidate': 'novalidate'}}) }}
                
                {% set field_icons = {
                    'mood': '😊',
                    'stressLevel': '🧘',
                    'sleepQuality': '😴',
                    'motivation': '⚡',
                    'mentalFatigue': '🧠',
                    'description': '💭'
                } %}

                {% for child in form %}
                    {% if child.vars.name != '_token' %}
                        <div class="group transition-all duration-300">
                            <label class="block text-gray-300 font-semibold mb-3 flex items-center gap-2 group-hover:text-purple-400 transition-colors">
                                <span class="text-xl">
                                    {{ field_icons[child.vars.name] ?? '❓' }}
                                </span>
                                {{ form_label(child, null, {'label_attr': {'class': 'text-inherit'}}) }}
                            </label>
                            
                            <div class="relative">
                                {{ form_widget(child, {
                                    'attr': {
                                        'class': 'w-full bg-gray-900/50 border border-gray-700 text-white px-5 py-4 rounded-xl focus:ring-2 focus:ring-purple-500/40 focus:border-purple-500/50 outline-none transition-all duration-300 appearance-none'
                                    }
                                }) }}
                                <div class="absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-gray-500">
                                    <i class="fas fa-chevron-down text-sm"></i>
                                </div>
                            </div>
                            
                            {% if form_errors(child) %}
                                <div class="mt-2 text-red-400 text-sm bg-red-500/10 px-4 py-2 rounded-lg border border-red-500/20">
                                    {{ form_errors(child) }}
                                </div>
                            {% endif %}
                        </div>
                    {% endif %}
                {% endfor %}

                <div class="pt-6">
                    <button type="submit" class="w-full bg-gradient-to-r from-purple-500 to-blue-500 hover:from-purple-600 hover:to-blue-600 text-white font-bold py-5 rounded-2xl shadow-xl shadow-purple-500/20 transition-all duration-300 flex items-center justify-center gap-3 group relative overflow-hidden">
                        <span class="relative z-10 flex items-center gap-2">
                            Calculate My Wellbeing Score
                            <i class="fas fa-arrow-right group-hover:translate-x-1 transition-transform"></i>
                        </span>
                        <div class="absolute inset-0 bg-white/10 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    </button>
                    
                    <p class="text-center text-gray-500 text-xs mt-6">
                        Your data is used to provide personalized recommendations.
                    </p>
                </div>
            {{ form_end(form) }}
        </div>
    </div>

    <!-- Description Block -->
    <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="bg-gray-900/40 rounded-3xl p-8 border border-gray-700/30 backdrop-blur-sm">
            <h3 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
                <i class="fas fa-heartbeat text-red-400"></i>
                Why track your mental state?
            </h3>
            <ul class="space-y-4">
                <li class="flex items-start gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-blue-400 mt-2 shrink-0"></div>
                    <p class="text-gray-400 text-sm leading-relaxed">
                        <strong class="text-gray-300">Emotional Intelligence:</strong> Identifying your feelings is the first step toward managing them effectively.
                    </p>
                </li>
                <li class="flex items-start gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-blue-400 mt-2 shrink-0"></div>
                    <p class="text-gray-400 text-sm leading-relaxed">
                        <strong class="text-gray-300">Pattern Recognition:</strong> Spot triggers and trends in your stress and energy levels over weeks.
                    </p>
                </li>
                <li class="flex items-start gap-3">
                    <div class="w-1.5 h-1.5 rounded-full bg-blue-400 mt-2 shrink-0"></div>
                    <p class="text-gray-400 text-sm leading-relaxed">
                        <strong class="text-gray-300">Optimized Performance:</strong> Align your physical training with your mental capacity for better results.
                    </p>
                </li>
            </ul>
        </div>

        <div class="bg-gradient-to-br from-purple-500/10 to-blue-500/10 rounded-3xl p-8 border border-purple-500/20 backdrop-blur-sm flex flex-col justify-center">
            <div class="flex items-center gap-2 text-purple-400 mb-2">
                <i class="fas fa-shield-alt"></i>
                <span class="text-xs font-bold uppercase tracking-wider">Confidential & Private</span>
            </div>
            <h3 class="text-xl font-bold text-white mb-4">You're in safe hands</h3>
            <p class="text-gray-400 text-sm leading-relaxed mb-6">
                Your assessments are private and used solely to personalize your FitSense experience. We use this data to adjust your workout intensity and suggest recovery activities.
            </p>
            <div class="flex items-center gap-4">
                <div class="flex -space-x-2">
                    <div class="w-8 h-8 rounded-full border-2 border-gray-900 bg-gray-700 flex items-center justify-center text-[10px] font-bold">JD</div>
                    <div class="w-8 h-8 rounded-full border-2 border-gray-900 bg-purple-600 flex items-center justify-center text-[10px] font-bold">AS</div>
                    <div class="w-8 h-8 rounded-full border-2 border-gray-900 bg-blue-600 flex items-center justify-center text-[10px] font-bold">ML</div>
                </div>
                <span class="text-xs text-gray-500 font-medium">Joined by 1,200+ members today</span>
            </div>
        </div>
    </div>
</div>
{% endblock %}
