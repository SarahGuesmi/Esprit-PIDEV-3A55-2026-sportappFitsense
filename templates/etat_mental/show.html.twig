{% extends 'base_user.html.twig' %}

{% block title %}Mental Assessment Result - FitSense{% endblock %}

{% block user_page_title %}Assessment Result{% endblock %}
{% block user_page_subtitle %}Understanding your current mental wellbeing{% endblock %}

{% block user_content %}
<div class="max-w-4xl mx-auto">
    <div class="bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-3xl shadow-2xl overflow-hidden border border-gray-700/50">
        <div class="p-8 md:p-12">
            <div class="flex flex-col md:flex-row items-center gap-12">
                <!-- Score Visualization -->
                <div class="relative w-48 h-48 flex-shrink-0">
                    <svg class="w-full h-full transform -rotate-90" viewBox="0 0 100 100">
                        <!-- Background Circle -->
                        <circle class="text-gray-800" stroke-width="8" stroke="currentColor" fill="transparent" r="42" cx="50" cy="50" />
                        <!-- Progress Circle -->
                        <circle class="text-purple-500 transition-all duration-1000 ease-out" 
                            stroke-width="8" 
                            stroke-dasharray="264" 
                            stroke-dashoffset="{{ 264 - (264 * etat.totalScore / 25) }}" 
                            stroke-linecap="round" 
                            stroke="currentColor" 
                            fill="transparent" 
                            r="42" cx="50" cy="50" />
                    </svg>
                    <div class="absolute inset-0 flex flex-col items-center justify-center transform rotate-0">
                        <span class="text-5xl font-black text-white">{{ etat.totalScore }}</span>
                        <span class="text-gray-400 text-sm font-bold uppercase tracking-widest">/ 25</span>
                    </div>
                </div>

                <!-- Status Info -->
                <div class="flex-1 text-center md:text-left">
                    {% set status_config = {
                        'Low Well-being': {
                            'icon': '😔',
                            'label': 'Needs Attention',
                            'color': 'text-red-400',
                            'bg': 'bg-red-500/10',
                            'border': 'border-red-500/20',
                            'msg': 'Your mental state seems fragile at the moment. It is important to prioritize rest and self-care.'
                        },
                        'Moderate': {
                            'icon': '😐',
                            'label': 'Moderate State',
                            'color': 'text-yellow-400',
                            'bg': 'bg-yellow-500/10',
                            'border': 'border-yellow-500/20',
                            'msg': 'You are maintaining a steady balance, but there is room for improvement in your daily routine.'
                        },
                        'Good': {
                            'icon': '🎉',
                            'label': 'Excellent Condition',
                            'color': 'text-green-400',
                            'bg': 'bg-green-500/10',
                            'border': 'border-green-500/20',
                            'msg': 'You are in great mental shape! Keep up the good habits and positive outlook.'
                        }
                    } %}

                    {% set current_status = status_config[etat.status == 'Good Well-being' ? 'Good' : (etat.status == 'Low Well-being' ? 'Low Well-being' : 'Moderate')] %}

                    <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full {{ current_status.bg }} {{ current_status.color }} border {{ current_status.border }} font-bold text-sm mb-4">
                        <span>{{ current_status.icon }}</span>
                        {{ current_status.label }}
                    </div>

                    <h2 class="text-3xl font-bold text-white mb-4">You're doing {{ current_status.label|lower }}</h2>
                    <p class="text-gray-400 leading-relaxed max-w-lg">
                        {{ current_status.msg }} Comparison with previous tests shows your resilience levels are 
                        <span class="text-purple-400 font-semibold">stable</span>.
                    </p>
                </div>
            </div>

            <!-- Detailed Breakdowns -->
            <div class="mt-12 grid grid-cols-1 md:grid-cols-2 gap-6">
                <!-- User Note section -->
                {% if etat.description %}
                <div class="col-span-1 md:col-span-2 bg-gray-900/40 rounded-2xl p-6 border border-gray-700/30">
                    <h3 class="text-white font-bold mb-4 flex items-center gap-2">
                        <i class="fas fa-comment-dots text-blue-400"></i>
                        Your Personal Note
                    </h3>
                    <p class="text-gray-400 text-sm italic leading-relaxed">
                        "{{ etat.description }}"
                    </p>
                </div>
                {% endif %}

                <div class="bg-gray-900/40 rounded-2xl p-6 border border-gray-700/30">
                    <h3 class="text-white font-bold mb-4 flex items-center gap-2">
                        <i class="fas fa-lightbulb text-purple-400"></i>
                        Personalized Tips
                    </h3>
                    <ul class="space-y-4">
                        {% if etat.status == 'Low Well-being' %}
                            <li class="flex items-start gap-3 text-gray-400 text-sm">
                                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                                Prioritize 7-9 hours of consistent sleep tonight.
                            </li>
                            <li class="flex items-start gap-3 text-gray-400 text-sm">
                                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                                Try a 10-minute guided meditation.
                            </li>
                        {% elseif etat.status == 'Moderate' %}
                            <li class="flex items-start gap-3 text-gray-400 text-sm">
                                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                                Incorporate a light 15-minute walk into your afternoon.
                            </li>
                            <li class="flex items-start gap-3 text-gray-400 text-sm">
                                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                                Track your water intake to ensure proper hydration.
                            </li>
                        {% else %}
                            <li class="flex items-start gap-3 text-gray-400 text-sm">
                                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                                Share your positive energy with a friend or colleague.
                            </li>
                            <li class="flex items-start gap-3 text-gray-400 text-sm">
                                <div class="w-1.5 h-1.5 rounded-full bg-purple-500 mt-2 shrink-0"></div>
                                It's a great time to challenge yourself with a new workout.
                            </li>
                        {% endif %}
                    </ul>
                </div>

                {% if recommendation is defined and recommendation is not null %}
                <div class="col-span-1 md:col-span-2 bg-gradient-to-br from-blue-900/40 to-purple-900/40 rounded-3xl p-8 border border-blue-500/30 shadow-xl">
                    <div class="flex items-center justify-between mb-8">
                        <div>
                            <h3 class="text-2xl font-bold text-white flex items-center gap-3">
                                <i class="fas fa-user-md text-blue-400"></i>
                                Coach's Prescription
                            </h3>
                            <p class="text-gray-400 text-sm mt-1">Personalized exercises from Coach {{ recommendation.coach.firstname }}</p>
                        </div>
                        <div class="bg-blue-500/20 px-4 py-2 rounded-xl border border-blue-500/20">
                            <span class="text-blue-300 text-xs font-bold uppercase tracking-widest">
                                {{ recommendation.createdAt|date('d M Y') }}
                            </span>
                        </div>
                    </div>

                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
                        {% for exercise in recommendation.recommendedExercises %}
                            <div class="bg-gray-900/60 p-6 rounded-2xl border border-gray-700/50 hover:border-blue-500/50 transition-all group">
                                <div class="w-10 h-10 rounded-lg bg-blue-500/10 flex items-center justify-center text-blue-400 mb-4 group-hover:bg-blue-500 group-hover:text-white transition-all">
                                    <i class="fas fa-dumbbell"></i>
                                </div>
                                <h4 class="text-white font-bold mb-2">{{ exercise.title }}</h4>
                                <p class="text-gray-400 text-xs leading-relaxed mb-4 line-clamp-2">
                                    {{ exercise.description }}
                                </p>
                                <div class="flex items-center gap-2 text-blue-400 text-xs font-bold">
                                    <i class="far fa-clock"></i>
                                    {{ exercise.duration }} min
                                </div>
                            </div>
                        {% endfor %}
                    </div>
                </div>
                {% endif %}

                <div class="bg-gray-900/40 rounded-2xl p-6 border border-gray-700/30">
                    <h3 class="text-white font-bold mb-4 flex items-center gap-2">
                        <i class="fas fa-tasks text-blue-400"></i>
                        Next Steps
                    </h3>
                    <div class="space-y-4">
                        {% if recommendation is defined and recommendation is not null %}
                            <a href="{{ path('etat_mental_coach_recommendation') }}" class="flex items-center justify-between p-4 bg-blue-500/10 hover:bg-blue-500/20 rounded-xl border border-blue-500/20 transition-all group">
                                <span class="text-blue-300 font-semibold">Details & Notes</span>
                                <i class="fas fa-chevron-right text-blue-500 group-hover:translate-x-1 transition-transform"></i>
                            </a>
                        {% endif %}
                        <div class="flex gap-4">
                            <a href="{{ path('etat_mental_new') }}" class="flex-1 text-center py-4 bg-gray-800 hover:bg-gray-700 text-white rounded-xl border border-gray-700 font-bold transition-all">
                                Retake Test
                            </a>
                            <a href="{{ path('etat_mental_index') }}" class="flex-1 text-center py-4 bg-gray-800 hover:bg-gray-700 text-white rounded-xl border border-gray-700 font-bold transition-all">
                                History
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
