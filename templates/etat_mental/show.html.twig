{% extends 'base.html.twig' %}

{% block title %}Résultat - Évaluation Mentale{% endblock %}

{% block stylesheets %}
<style>
:root {
    --blue-light: #38BDF8;
    --violet-light: #A78BFA;
    --dark-bg: #111318;
    --dark-card: #1B1E26;
    --dark-input: #262A35;
    --text-primary: #FFFFFF;
    --text-secondary: #A1A1AA;
    --border-color: #343846;
    --gradient-main: linear-gradient(135deg, #38BDF8, #A78BFA);
    --success-color: #10B981;
    --warning-color: #F59E0B;
    --danger-color: #EF4444;
}

body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--dark-bg);
    color: var(--text-primary);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0;
    padding: 20px;
}

.result-card {
    max-width: 680px;
    width: 100%;
    background: var(--dark-card);
    padding: 48px 40px;
    border-radius: 24px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.5);
    text-align: center;
}

h2 {
    font-size: 32px;
    margin-bottom: 8px;
    background: var(--gradient-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    font-weight: 800;
}

.subtitle {
    color: var(--text-secondary);
    font-size: 15px;
    margin-bottom: 48px;
}

.score-container {
    position: relative;
    width: 200px;
    height: 200px;
    margin: 0 auto 32px;
}

.score-circle {
    width: 100%;
    height: 100%;
    transform: rotate(-90deg);
}

.score-circle-bg {
    fill: none;
    stroke: var(--dark-input);
    stroke-width: 12;
}

.score-circle-progress {
    fill: none;
    stroke: url(#gradient);
    stroke-width: 12;
    stroke-linecap: round;
    stroke-dasharray: 565.48;
    stroke-dashoffset: 565.48;
    animation: fillCircle 1.5s ease-out forwards;
}

@keyframes fillCircle {
    to {
        stroke-dashoffset: calc(565.48 - (565.48 * {{ etat.totalScore }} / 25));
    }
}

.score-text {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 56px;
    font-weight: 800;
    background: var(--gradient-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
}

.score-label {
    position: absolute;
    top: 60%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 14px;
    color: var(--text-secondary);
    margin-top: 20px;
}

.status-badge {
    display: inline-block;
    padding: 12px 32px;
    border-radius: 24px;
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 24px;
}

.status-low {
    background: linear-gradient(135deg, #EF4444, #DC2626);
    color: white;
}

.status-medium {
    background: linear-gradient(135deg, #F59E0B, #D97706);
    color: white;
}

.status-good {
    background: linear-gradient(135deg, #10B981, #059669);
    color: white;
}

.message-box {
    background: var(--dark-input);
    border-radius: 16px;
    padding: 24px;
    margin: 32px 0;
    border-left: 4px solid;
}

.message-box.low {
    border-left-color: var(--danger-color);
}

.message-box.medium {
    border-left-color: var(--warning-color);
}

.message-box.good {
    border-left-color: var(--success-color);
}

.message-box p {
    margin: 0;
    font-size: 16px;
    line-height: 1.6;
    color: var(--text-primary);
}

.recommendations {
    text-align: left;
    background: var(--dark-input);
    border-radius: 16px;
    padding: 24px;
    margin: 24px 0;
}

.recommendations h3 {
    font-size: 18px;
    font-weight: 700;
    margin-bottom: 16px;
    color: var(--text-primary);
}

.recommendations ul {
    list-style: none;
    padding: 0;
    margin: 0;
}

.recommendations li {
    padding: 12px 0;
    padding-left: 32px;
    position: relative;
    color: var(--text-secondary);
    font-size: 15px;
}

.recommendations li:before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--violet-light);
    font-weight: 700;
    font-size: 18px;
}

.action-buttons {
    display: flex;
    gap: 16px;
    margin-top: 32px;
}

.btn {
    flex: 1;
    padding: 16px;
    font-size: 16px;
    font-weight: 700;
    border: none;
    border-radius: 16px;
    cursor: pointer;
    transition: all 0.25s;
    text-decoration: none;
    display: inline-block;
}

.btn-primary {
    background: #DFFF00;
    color: #000;
}

.btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(223,255,0,0.35);
}

.btn-secondary {
    background: var(--dark-input);
    color: var(--text-primary);
    border: 2px solid var(--border-color);
}

.btn-secondary:hover {
    border-color: var(--violet-light);
    transform: translateY(-2px);
}

@media (max-width: 600px) {
    .result-card {
        padding: 32px 24px;
    }
    h2 {
        font-size: 26px;
    }
    .score-container {
        width: 160px;
        height: 160px;
    }
    .score-text {
        font-size: 44px;
    }
    .action-buttons {
        flex-direction: column;
    }
}
</style>
{% endblock %}

{% block body %}
{% block header %}{% endblock %}
<div class="result-card">
    <h2>Votre Évaluation Mentale</h2>
    <p class="subtitle">Résultats de votre état mental</p>

    <div class="score-container">
        <svg class="score-circle" viewBox="0 0 200 200">
            <defs>
                <linearGradient id="gradient" x1="0%" y1="0%" x2="100%" y2="100%">
                    <stop offset="0%" style="stop-color:#38BDF8;stop-opacity:1" />
                    <stop offset="100%" style="stop-color:#A78BFA;stop-opacity:1" />
                </linearGradient>
            </defs>
            <circle class="score-circle-bg" cx="100" cy="100" r="90"></circle>
            {# Calculation based on 25 max score #}
            <circle class="score-circle-progress" cx="100" cy="100" r="90"></circle>
        </svg>
        <div class="score-text">{{ etat.totalScore }}</div>
        <div class="score-label">/ 25</div>
    </div>

    {% if etat.status == 'Low Well-being' %}
        <div class="status-badge status-low">😔 Low Mental State</div>
        <div class="message-box low">
            <p>Score between 5 and 10. Your mental state seems fragile. It is important to slow down, prioritize rest, and consult a professional if this feeling persists.</p>
        </div>
        <div class="recommendations">
            <h3>💡 Recommendations</h3>
            <ul>
                <li>Prioritize sleep and rest</li>
                <li>Try relaxing activities (reading, calm walking)</li>
                <li>Talk to someone you trust</li>
                <li>Reduce workload if possible</li>
            </ul>
        </div>
    {% elseif etat.status == 'Moderate' %}
        <div class="status-badge status-medium">😐 Moderate State</div>
        <div class="message-box medium">
            <p>Score between 11 and 17. Things could be better. You might be going through a period of fatigue or temporary stress. Take some time for yourself.</p>
        </div>
        <div class="recommendations">
            <h3>💡 Recommendations</h3>
            <ul>
                <li>Maintain moderate physical activity</li>
                <li>Structure your days to avoid burnout</li>
                <li>Treat yourself to daily small pleasures</li>
                <li>Watch your diet and hydration</li>
            </ul>
        </div>
    {% else %}
        <div class="status-badge status-good">🎉 Good Mental Health</div>
        <div class="message-box good">
            <p>Score between 18 and 25. You are in great mental shape! Continue to maintain this balance between activity, rest, and social life.</p>
        </div>
        <div class="recommendations">
            <h3>💡 Recommendations</h3>
            <ul>
                <li>Take the opportunity to start new projects</li>
                <li>Share your positive energy</li>
                <li>Maintain your good habits (sport, sleep)</li>
                <li>Stay tuned to your needs</li>
            </ul>
        </div>
    {% endif %}

    <div class="action-buttons">
        <a href="{{ path('etat_mental_exercises', {id: etat.id}) }}" class="btn btn-primary">View Recommended Exercises</a>
        <a href="{{ path('etat_mental_new') }}" class="btn btn-secondary">Retake</a>
        <a href="{{ path('app_home') }}" class="btn btn-secondary">Home</a>
    </div>
</div>
{% block footer %}{% endblock %}
{% endblock %}
