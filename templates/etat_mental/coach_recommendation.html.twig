{% extends 'base_user.html.twig' %}

{% block title %}FitSense - Coach Recommendations{% endblock %}

{% block user_page_title %}Coach's Prescription{% endblock %}
{% block user_page_subtitle %}Personalized exercises from your coach{% endblock %}

{% block user_content %}
<div class="max-w-4xl mx-auto space-y-8">
    <!-- Header Section -->
    <div class="relative overflow-hidden bg-gradient-to-br from-blue-900/40 to-purple-900/40 rounded-3xl p-8 border border-blue-500/20 shadow-2xl">
        <div class="absolute top-0 right-0 w-64 h-64 bg-blue-500/10 rounded-full blur-3xl"></div>
        
        <div class="relative z-10 flex flex-col md:flex-row md:items-center justify-between gap-6">
            <div>
                <h1 class="text-3xl font-extrabold text-white mb-2 flex items-center gap-3">
                    <i class="fas fa-user-md text-blue-400"></i>
                    Coach's Recommendations
                </h1>
                <p class="text-gray-400 flex items-center gap-2">
                    <i class="fas fa-user-tie text-blue-400"></i>
                    Prescribed by Coach {{ recommendation.coach.firstname }} {{ recommendation.coach.lastname }}
                </p>
            </div>
            <div class="bg-blue-500/10 border border-blue-500/20 px-4 py-2 rounded-2xl">
                <span class="text-blue-400 text-sm font-bold">
                    <i class="far fa-calendar-alt mr-2"></i>
                    {{ recommendation.createdAt|date('d M Y') }}
                </span>
            </div>
        </div>
    </div>

    {% if recommendation.notes %}
        <div class="bg-blue-600/5 border border-blue-500/10 rounded-2xl p-6 italic text-gray-300">
             <i class="fas fa-quote-left text-blue-500/30 text-2xl mb-2 block"></i>
             "{{ recommendation.notes }}"
        </div>
    {% endif %}

    <div>
        <h2 class="text-xl font-bold text-white mb-6 flex items-center gap-3">
            <div class="w-1.5 h-6 bg-blue-500 rounded-full"></div>
            Recommended Exercises
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {% for exercise in recommendation.recommendedExercises %}
                <div class="bg-gray-900/60 border border-gray-800 rounded-2xl p-6 hover:border-blue-500/40 transition-all duration-300 group">
                    <div class="flex justify-between items-start mb-4">
                        <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center text-blue-400 text-xl group-hover:bg-blue-500 group-hover:text-white transition-all duration-300">
                            <i class="fas fa-dumbbell"></i>
                        </div>
                    </div>
                    <h3 class="text-lg font-bold text-white mb-2">{{ exercise.title }}</h3>
                    <p class="text-gray-400 text-sm leading-relaxed mb-4">
                        {{ exercise.description }}
                    </p>
                    {% if exercise.duration %}
                        <div class="flex items-center gap-2 text-blue-400 text-sm font-bold">
                            <i class="far fa-clock"></i>
                            {{ exercise.duration }} min
                        </div>
                    {% endif %}
                </div>
            {% else %}
                <div class="col-span-2 text-center py-16 text-gray-500">
                    <i class="fas fa-dumbbell text-4xl mb-4 block"></i>
                    <p>No exercises have been added to this recommendation yet.</p>
                </div>
            {% endfor %}
        </div>
    </div>

    <div class="flex justify-center">
        <a href="{{ path('etat_mental_index') }}" class="inline-flex items-center px-8 py-3 bg-gray-900 border border-gray-700 text-white font-bold rounded-2xl hover:bg-gray-800 transition-all duration-300">
            <i class="fas fa-arrow-left mr-3"></i>
            Back to History
        </a>
    </div>
</div>
{% endblock %}
