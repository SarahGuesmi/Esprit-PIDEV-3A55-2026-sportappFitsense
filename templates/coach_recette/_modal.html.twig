{# MODAL (ONE) #}
<div class="modal-backdrop" id="recipeModalBackdrop" aria-hidden="true">
  <div class="modal" id="recipeModal">
    <div class="modal-header">
      <div style="flex:1">
        <div class="modal-title-row">
          <h2 class="modal-title view-field" id="mTitle">Recipe</h2>

          <div class="edit-field" style="width:100%">
            <label style="font-weight:800; font-size:12px; margin-bottom:6px; display:block;">Title</label>
            <input type="text" name="title" form="updateForm" id="fTitle">
          </div>
        </div>

        <div class="muted view-field" id="mDescSmall"></div>

        <div class="edit-field" style="margin-top:10px">
          <label style="font-weight:800; font-size:12px; margin-bottom:6px; display:block;">Description</label>
          <textarea name="description" form="updateForm" id="fDescription"></textarea>
        </div>

        <div class="chips">
          <span class="chip" id="mKcalChip">🔥 kcal</span>
          <span class="chip" id="mProtChip">💪 proteins</span>
          <span class="chip" id="mTypeChip">🍽️ type</span>
        </div>

        <div class="edit-field row-2" style="margin-top:10px">
          <div>
            <label style="font-weight:800; font-size:12px; margin-bottom:6px; display:block;">Kcal</label>
            <input type="number" min="0" name="kcal" form="updateForm" id="fKcal">
          </div>
          <div>
            <label style="font-weight:800; font-size:12px; margin-bottom:6px; display:block;">Proteins (g)</label>
            <input type="number" min="0" name="proteins" form="updateForm" id="fProteins">
          </div>
        </div>

        <div class="edit-field" style="margin-top:10px">
          <label style="font-weight:800; font-size:12px; margin-bottom:6px; display:block;">Meal type</label>
          <select name="typeMeal" form="updateForm" id="fTypeMeal">
            <option value="BREAKFAST">BREAKFAST</option>
            <option value="LUNCH">LUNCH</option>
            <option value="DINNER">DINNER</option>
            <option value="SNACK">SNACK</option>
          </select>
        </div>
      </div>

      <button class="modal-close" type="button" id="closeModalBtn">×</button>
    </div>

    <div class="modal-body" id="modalBody">
      <div>
        <div class="modal-img">
          <img id="mImg" src="" alt="recipe">
        </div>

        <div class="edit-field" style="margin-top:10px">
          <label style="font-weight:800; font-size:12px; margin-bottom:6px; display:block;">Change image</label>
          <input type="file" name="imageFile" form="updateForm" accept="image/jpeg,image/png,image/webp">
          <div class="help">JPG / PNG / WEBP — max 3MB</div>
        </div>
      </div>

      <div>
        <div class="modal-section">
          <h3>🧾 Ingrédients</h3>

          <div class="view-field">
            <ul class="list" id="mIngredientsList"></ul>
          </div>

          <div class="edit-field">
            <textarea name="ingredients" form="updateForm" id="fIngredients"></textarea>
            <div class="help">Astuce: mets chaque ingrédient dans une nouvelle ligne.</div>
          </div>
        </div>

        <div class="modal-section">
          <h3>🧑‍🍳 Préparation</h3>

          <div class="view-field">
            <ul class="list" id="mPreparationList"></ul>
          </div>

          <div class="edit-field">
            <textarea name="preparation" form="updateForm" id="fPreparation"></textarea>
            <div class="help">Astuce: mets chaque étape dans une nouvelle ligne.</div>
          </div>
        </div>

        <form id="updateForm" method="post" enctype="multipart/form-data" style="display:none;">
          <input type="hidden" name="_token" id="updToken">
        </form>

        <form id="deleteForm" method="post" style="display:none;">
          <input type="hidden" name="_token" id="delToken">
        </form>
      </div>
    </div>

    <div class="modal-footer">
      <button class="btn btn-ghost" type="button" id="toggleEditBtn">✏️ update</button>
      <button class="btn btn-green" type="submit" form="updateForm" id="saveBtn">✅ Save</button>
      <button class="btn btn-danger" type="submit" form="deleteForm"
              onclick="return confirm('Supprimer cette recette ?')">
        🗑️ delete
      </button>
    </div>
  </div>
</div>
