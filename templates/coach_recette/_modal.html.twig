{# MODAL (Tailwind Glass Design) #}
<div class="fixed inset-0 z-50 bg-black/80 backdrop-blur items-center justify-center hidden" id="recipeModalBackdrop" style="display: none;">
  <div class="glass-card max-w-4xl w-full mx-4 overflow-hidden flex flex-col max-h-[90vh]" id="recipeModal">
    <form id="updateForm" method="post" enctype="multipart/form-data" class="recipe-ajax-form flex flex-col h-full overflow-hidden">
        <input type="hidden" name="_token" id="updToken">
        
        <!-- Header -->
        <div class="p-6 border-b border-gray-800 flex justify-between items-start">
          <div class="flex-1">
            <div class="flex items-center gap-3">
              <h2 id="mTitle" class="view-field text-3xl font-bold text-white mb-2">Recipe</h2>
              
              <!-- Edit Title -->
              <div class="edit-field w-full hidden">
                <label class="block text-xs font-bold text-gray-400 mb-1">Title</label>
                <input type="text" name="title" id="fTitle" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500">
                <div class="errors text-red-500 text-xs mt-1" id="f-error-title"></div>
              </div>
            </div>

            <div class="flex gap-3 mb-4 flex-wrap chips">
              <span id="mKcalChip" class="chip px-3 py-1 bg-blue-500/10 rounded-lg text-blue-400 text-xs font-bold border border-blue-500/20">🔥 kcal</span>
              <span id="mProtChip" class="chip px-3 py-1 bg-purple-500/10 rounded-lg text-purple-400 text-xs font-bold border border-purple-500/20">💪 proteins</span>
              <span id="mTypeChip" class="chip px-3 py-1 bg-gray-800 rounded-lg text-gray-400 text-xs font-bold border border-gray-700">🍽️ type</span>
            </div>

            <div id="mObjectifsContainer" class="view-field flex flex-wrap gap-2 mb-4">
              <!-- JS will fill this -->
            </div>

            <!-- Edit Meta -->
            <div class="edit-field grid grid-cols-1 sm:grid-cols-3 gap-3 mt-4 hidden">
              <div>
                <label class="block text-xs font-bold text-gray-400 mb-1">Kcal</label>
                <input type="number" min="0" name="kcal" id="fKcal" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500">
                <div class="errors text-red-500 text-xs mt-1" id="f-error-kcal"></div>
              </div>
               <div>
                <label class="block text-xs font-bold text-gray-400 mb-1">Proteins (g)</label>
                <input type="number" min="0" name="proteins" id="fProteins" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500">
                <div class="errors text-red-500 text-xs mt-1" id="f-error-proteins"></div>
              </div>
               <div>
                <label class="block text-xs font-bold text-gray-400 mb-1">Meal Type</label>
                <select name="typeMeal" id="fTypeMeal" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500">
                   <option value="BREAKFAST">BREAKFAST</option>
                    <option value="LUNCH">LUNCH</option>
                    <option value="DINNER">DINNER</option>
                    <option value="SNACK">SNACK</option>
                </select>
                <div class="errors text-red-500 text-xs mt-1" id="f-error-typeMeal"></div>
              </div>
            </div>
          </div>

          <button id="closeModalBtn" type="button" class="modal-close w-10 h-10 bg-gray-800 hover:bg-gray-700 rounded-xl flex items-center justify-center transition text-white">
            <i class="fas fa-times"></i>
          </button>
        </div>

        <!-- Body -->
        <div class="p-6 overflow-y-auto grid grid-cols-1 md:grid-cols-3 gap-8 modal-body" id="modalBody">
          <div class="md:col-span-1">
            <div class="rounded-2xl overflow-hidden border border-gray-800 bg-gray-900 aspect-square mb-6 modal-img">
              <img id="mImg" src="" alt="Recipe" class="w-full h-full object-cover">
            </div>

            <!-- Edit Image -->
            <div class="edit-field mt-4 hidden">
              <label class="block text-xs font-bold text-gray-400 mb-1">Change Image</label>
              <input type="file" name="imageFile" accept="image/jpeg,image/png,image/webp" class="w-full text-xs text-gray-400">
              <div class="text-[10px] text-gray-500 mt-1">JPG / PNG / WEBP — max 3MB</div>
              <div class="errors text-red-500 text-xs mt-1" id="f-error-imageFile"></div>
            </div>
          </div>

          <div class="md:col-span-2 space-y-8">
            <!-- Description -->
            <div>
              <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-3">Description</h3>
              <div id="mDescSmall" class="view-field text-gray-300 leading-relaxed"></div>
              
              <div class="edit-field hidden">
                <textarea name="description" id="fDescription" rows="3" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500"></textarea>
                <div class="errors text-red-500 text-xs mt-1" id="f-error-description"></div>
              </div>
            </div>

            <!-- Ingredients -->
            <div class="modal-section">
              <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">🧾 Ingredients</h3>
              <ul id="mIngredientsList" class="view-field space-y-2 text-gray-300 list-disc pl-4"></ul>
              
              <div class="edit-field hidden">
                <textarea name="ingredients" id="fIngredients" rows="5" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500"></textarea>
                 <div class="text-[10px] text-gray-500 mt-1">One ingredient per line</div>
                 <div class="errors text-red-500 text-xs mt-1" id="f-error-ingredients"></div>
              </div>
            </div>

            <!-- Preparation -->
            <div class="modal-section">
              <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-2">🧑‍🍳 Preparation</h3>
              <ul id="mPreparationList" class="view-field space-y-4 text-gray-300 list-decimal pl-4"></ul>
              
              <div class="edit-field hidden">
                <textarea name="preparation" id="fPreparation" rows="5" class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-2 text-white focus:outline-none focus:border-blue-500"></textarea>
                 <div class="text-[10px] text-gray-500 mt-1">One step per line</div>
                 <div class="errors text-red-500 text-xs mt-1" id="f-error-preparation"></div>
              </div>
            </div>

            <!-- Edit Objectives -->
            <div class="edit-field modal-section hidden">
              <h3 class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-3">Objectives</h3>
              <div class="grid grid-cols-2 gap-3" id="fObjectifsGrid">
                {% set availableObjs = {
                  'WEIGHT_LOSS': 'Weight Loss',
                  'MUSCLE_GAIN': 'Muscle Gain',
                  'ENDURANCE': 'Endurance',
                  'WELL_BEING': 'Well-being'
                } %}
                {% for val, label in availableObjs %}
                  <label class="flex items-center gap-2 p-3 bg-gray-900 border border-gray-700 rounded-xl cursor-pointer hover:border-blue-500 transition-colors">
                    <input type="checkbox" name="objectifs[]" value="{{ val }}" class="obj-checkbox w-4 h-4 rounded border-gray-700 bg-gray-800 text-blue-500 focus:ring-blue-500">
                    <span class="text-xs text-gray-300">{{ label }}</span>
                  </label>
                {% endfor %}
              </div>
              <div class="errors text-red-500 text-xs mt-1" id="f-error-objectifs"></div>
            </div>
          </div>
        </div>

        <!-- Footer -->
        <div class="p-6 border-t border-gray-800 flex justify-end gap-3 modal-footer bg-gray-900/50 backdrop-blur">
          <button class="px-6 py-2 bg-gray-800 hover:bg-gray-700 text-white rounded-xl font-bold transition border border-gray-700" type="button" id="toggleEditBtn">
            <i class="fas fa-edit mr-2"></i> Edit
          </button>
          
          <button class="hidden px-6 py-2 bg-gradient-to-r from-green-500 to-emerald-600 text-white rounded-xl font-bold shadow-lg hover:shadow-green-500/30 transition" type="submit" id="saveBtn">
            <i class="fas fa-check mr-2"></i> Save Changes
          </button>
          
          <button class="px-6 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 hover:text-red-300 rounded-xl font-bold transition border border-red-500/20" type="button" id="deleteBtn">
            <i class="fas fa-trash mr-2"></i> Delete
          </button>
        </div>
    </form>
  </div>
  <form id="deleteForm" method="post" class="recipe-ajax-form" style="display:none;">
    <input type="hidden" name="_token" id="delToken">
  </form>
</div>

<!-- DELETE CONFIRMATION MODAL -->
<div class="fixed inset-0 z-[60] bg-black/90 backdrop-blur-sm flex items-center justify-center" id="confirmDeleteBackdrop" style="display: none;">
  <div class="glass-card max-w-sm w-full mx-4 p-8 text-center border border-red-500/30">
    <div class="w-20 h-20 bg-red-500/10 rounded-full flex items-center justify-center mx-auto mb-6 border border-red-500/20">
      <i class="fas fa-exclamation-triangle text-3xl text-red-500"></i>
    </div>
    <h3 class="text-xl font-bold text-white mb-2">Delete Recipe?</h3>
    <p class="text-gray-400 text-sm mb-8">This action is permanent and cannot be undone. All data for <span id="confirmRecipeTitle" class="text-white font-bold"></span> will be lost.</p>
    
    <div class="flex gap-3">
      <button type="button" id="cancelDeleteBtn" class="flex-1 px-6 py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-xl font-bold transition border border-gray-700">
        Cancel
      </button>
      <button type="button" id="confirmDeleteBtn" class="flex-1 px-6 py-3 bg-red-600 hover:bg-red-500 text-white rounded-xl font-bold transition shadow-lg shadow-red-500/20">
        Delete
      </button>
    </div>
  </div>
</div>

