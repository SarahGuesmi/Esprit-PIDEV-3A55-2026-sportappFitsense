{% extends 'coach/base_coach.html.twig' %}

{% block title %}FitSense Nutrition - Coach{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/css/coach_recette.css') }}">
    <style>
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        
        #recipe-form-container {
            display: none;
            margin-bottom: 2rem;
            animation: fadeIn 0.3s ease-out;
        }
        
        #recipe-form-container.active {
            display: block;
        }

        #recipe-list-container.hidden {
            display: none;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .form-card {
            margin-top: 0 !important;
        }
    </style>
{% endblock %}

{% block coach_content %}
    <div class="page-header">
        <div>
            <h2 class="text-3xl font-bold gradient-text">Nutrition Management</h2>
            <p class="text-gray-400">Fuel your athletes journey to success</p>
        </div>
        <button id="toggle-recipe-form" class="px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-xl font-bold shadow-lg hover:shadow-blue-500/50 transition-all flex items-center">
            <i class="fas fa-plus mr-2"></i>
            Create New Recipe
        </button>
    </div>

    {% for msg in app.flashes('success') %}
        <div class="mb-6 p-4 bg-green-500/20 border border-green-500/50 text-green-400 rounded-xl">
            <i class="fas fa-check-circle mr-2"></i> {{ msg }}
        </div>
    {% endfor %}

    {# FORM CONTAINER #}
    <div id="recipe-form-container" class="{{ form.vars.errors|length > 0 ? 'active' : '' }}">
        {% include 'coach_recette/_form_create.html.twig' with { form: form } %}
    </div>

    {# LIST CONTAINER (Hidden when form is active) #}
    <div id="recipe-list-container" class="{{ form.vars.errors|length > 0 ? 'hidden' : '' }}">
        <div class="mb-8">
            {% include 'coach_recette/_filters.html.twig' with { q: q|default(''), kcal: kcal|default(''), proteins: proteins|default('') } %}
        </div>
        {% include 'coach_recette/_grid.html.twig' with { recipes: recipes } %}
    </div>

    {% include 'coach_recette/_modal.html.twig' %}
{% endblock %}

{% block scripts %}
    {{ parent() }}
    <script src="{{ asset('assets/js/coach_recette.js') }}"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const toggleBtn = document.getElementById('toggle-recipe-form');
            const formContainer = document.getElementById('recipe-form-container');
            const listContainer = document.getElementById('recipe-list-container');

            if (toggleBtn && formContainer && listContainer) {
                // Determine initial state based on classes
                let isFormActive = formContainer.classList.contains('active');

                // Initial Button Text
                if (isFormActive) {
                    toggleBtn.innerHTML = '<i class="fas fa-times mr-2"></i> Close';
                }

                toggleBtn.addEventListener('click', function() {
                    const isActive = formContainer.classList.toggle('active');
                    listContainer.classList.toggle('hidden', isActive);
                    
                    toggleBtn.innerHTML = isActive 
                        ? '<i class="fas fa-times mr-2"></i> Close' 
                        : '<i class="fas fa-plus mr-2"></i> Create New Recipe';
                    
                    if (isActive) {
                        formContainer.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            }
        });
    </script>
{% endblock %}