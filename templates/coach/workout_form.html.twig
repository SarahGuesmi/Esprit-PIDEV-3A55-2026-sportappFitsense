{% extends 'base.html.twig' %}

{% block title %}{{ isEdit ? 'Edit Workout' : 'Create Workout' }} - FitSense{% endblock %}

{% block stylesheets %}
<script src="https://cdn.tailwindcss.com"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

body {
    font-family: 'Inter', system-ui, sans-serif;
    background: #000000;
    color: #FFFFFF;
}

.gradient-btn {
    background: linear-gradient(135deg, #22C55E, #84CC16);
}

.card-glow {
    transition: all 0.3s ease;
}

.card-glow:hover {
    box-shadow: 0 20px 40px rgba(34, 197, 94, 0.15);
}

/* Form fields */
.form-input {
    width: 100%;
    background: #0D0D0D;
    border: 1px solid #1F1F1F;
    border-radius: 12px;
    padding: 0.75rem 1rem;
    color: white;
    transition: all 0.2s;
}

.form-input:focus {
    outline: none;
    border-color: #22C55E;
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.2);
}

.form-label {
    font-size: 0.85rem;
    font-weight: 600;
    color: #9CA3AF;
    margin-bottom: 0.5rem;
    display: block;
    text-transform: uppercase;
    letter-spacing: 0.05em;
}

/* ---- Validation Errors ---- */
.form-input.error {
    border-color: #EF4444;
    box-shadow: 0 0 0 2px rgba(239, 68, 68, 0.25);
}

.error-message {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #FCA5A5;
    font-size: 0.85rem;
    margin-top: 0.5rem;
}

.error-icon {
    width: 16px;
    height: 16px;
    color: #EF4444;
}
</style>
{% endblock %}

{% block header %}{% endblock %}
{% block navigation %}{% endblock %}
{% block navbar %}{% endblock %}
{% block menu %}{% endblock %}
{% block footer %}{% endblock %}

{% block body %}
<div class="min-h-screen bg-black text-white">

    <!-- Header -->
    <div class="border-b border-gray-900">
        <div class="max-w-[900px] mx-auto px-8 py-6 flex items-center justify-between">
            <div class="flex items-center gap-4">
                <a href="{{ path('coach_workout_catalog') }}"
                   class="px-4 py-2 bg-gray-900 hover:bg-gray-800 rounded-lg border border-gray-800 text-sm font-semibold transition">
                    ← Back
                </a>

                <h1 class="text-3xl font-black tracking-tight">
                    {{ isEdit ? 'Edit Workout' : 'Create Workout' }}
                </h1>
            </div>
        </div>
    </div>

    <!-- Form Card -->
    <div class="max-w-[900px] mx-auto px-8 py-10">

        <div class="bg-[#0D0D0D] border border-gray-900 rounded-2xl p-10 card-glow">

            {{ form_start(form, {'attr': {'id': 'workoutForm', 'novalidate': 'novalidate'}}) }}

                <div class="space-y-6">

                    {% for field in form %}
                        {% if field.vars.name != '_token' %}
                            <div>
                                {{ form_label(field, null, {'label_attr': {'class': 'form-label'}}) }}

                                {{ form_widget(field, {
                                    'attr': {
                                        'class': 'form-input' ~ (field.vars.errors|length ? ' error' : ''),
                                        'placeholder': 'Enter ' ~ field.vars.label|lower,
                                        'type': field.vars.name == 'duree' ? 'number' : null,
                                        'min': field.vars.name == 'duree' ? 1 : null,
                                        'required': field.vars.required ? 'required' : null,
                                        'data-field-name': field.vars.name
                                    }
                                }) }}

                                {# Affiche les erreurs du champ si présentes #}
                                {% if field.vars.errors|length %}
                                    <div class="error-message" data-error-for="{{ field.vars.name }}">
                                        <svg class="error-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                                        </svg>
                                        {{ field.vars.errors[0].message }}
                                    </div>
                                {% endif %}
                            </div>
                        {% endif %}
                    {% endfor %}

                </div>

                <!-- Actions -->
                <div class="flex justify-end gap-4 mt-10">
                    <a href="{{ path('coach_workout_catalog') }}"
                       class="px-6 py-3 bg-gray-900 hover:bg-gray-800 border border-gray-800 rounded-xl font-semibold text-sm transition">
                        Cancel
                    </a>

                    <button type="submit"
                            class="px-8 py-3 gradient-btn text-black rounded-xl font-bold text-sm shadow-lg hover:shadow-xl transition">
                        {{ isEdit ? 'Update Workout' : 'Create Workout' }}
                    </button>
                </div>

            {{ form_end(form) }}

        </div>

    </div>
</div>

<!-- JS pour validation et gestion des erreurs -->
<script>
document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('workoutForm');
    const inputs = document.querySelectorAll('.form-input');

    function showError(input, message) {
        input.classList.add('error');

        const existingError = input.parentElement.querySelector('.error-message');
        if (existingError) {
            existingError.remove();
        }

        const errorDiv = document.createElement('div');
        errorDiv.className = 'error-message';
        errorDiv.setAttribute('data-error-for', input.getAttribute('data-field-name'));
        errorDiv.innerHTML = `
            <svg class="error-icon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                      d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            ${message}
        `;
        input.parentElement.appendChild(errorDiv);
    }

    function clearError(input) {
        input.classList.remove('error');
        const error = input.parentElement.querySelector('.error-message');
        if (error) {
            error.remove();
        }
    }

    function validateField(input) {
        const value = input.value.trim();
        const fieldName = input.getAttribute('data-field-name');
        const isRequired = input.hasAttribute('required');

        // 🔴 Objectif obligatoire
        if (fieldName === 'objectif') {
            if (!value) {
                showError(input, 'Workout objective is required');
                return false;
            }

            if (value.length < 3) {
                showError(input, 'Objective must contain at least 3 characters');
                return false;
            }
        }

        // Champ requis générique
        if (isRequired && !value) {
            showError(input, 'This field is required');
            return false;
        }

        // Durée
        if (fieldName === 'duree' && value) {
            const duration = parseInt(value);
            if (isNaN(duration) || duration < 1) {
                showError(input, 'Duration must be at least 1 minute');
                return false;
            }
        }

        // Textarea détaillée (description par exemple)
        if (input.tagName === 'TEXTAREA' && isRequired && value.length < 10) {
            showError(input, 'Please provide a more detailed description (minimum 10 characters)');
            return false;
        }

        clearError(input);
        return true;
    }

    inputs.forEach(input => {
        input.addEventListener('input', () => {
            clearError(input);
        });

        input.addEventListener('blur', () => {
            validateField(input);
        });
    });

    form.addEventListener('submit', (e) => {
        let isValid = true;

        inputs.forEach(input => {
            if (!validateField(input)) {
                isValid = false;
            }
        });

        if (!isValid) {
            e.preventDefault();

            const firstError = document.querySelector('.form-input.error');
            if (firstError) {
                firstError.scrollIntoView({ behavior: 'smooth', block: 'center' });
                firstError.focus();
            }
        }
    });
});
</script>


{% endblock %}