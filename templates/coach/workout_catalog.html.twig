{% extends 'coach/base_coach.html.twig' %}

{% block title %}Workout Catalog - FitSense{% endblock %}

{% block stylesheets %}
    {{ parent() }}
<style>
@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap');

.card-hover {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(34, 197, 94, 0.15);
}

.search-input:focus {
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.3);
}

.icon-glow {
    filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.4));
}

.shine-effect {
    position: relative;
    overflow: hidden;
}

.shine-effect::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
        to bottom right,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.03) 50%,
        rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(45deg);
    animation: shine 3s infinite;
}

@keyframes shine {
    0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
    100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}

.hidden {
    display: none !important;
}

/* Dropdown Styles */
.dropdown-container {
    position: relative;
}

.dropdown-button {
    cursor: pointer;
    user-select: none;
}

.dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.5rem;
    background: #0D0D0D;
    border: 1px solid #1F1F1F;
    border-radius: 12px;
    padding: 0.5rem;
    z-index: 50;
    max-height: 300px;
    overflow-y: auto;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
}

.dropdown-menu::-webkit-scrollbar {
    width: 8px;
}

.dropdown-menu::-webkit-scrollbar-track {
    background: #1F1F1F;
    border-radius: 4px;
}

.dropdown-menu::-webkit-scrollbar-thumb {
    background: #374151;
    border-radius: 4px;
}

.dropdown-menu::-webkit-scrollbar-thumb:hover {
    background: #4B5563;
}

.dropdown-item {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.dropdown-item:hover {
    background: #1F1F1F;
}

.dropdown-item.selected {
    background: rgba(34, 197, 94, 0.1);
}

.checkbox-custom {
    width: 18px;
    height: 18px;
    border: 2px solid #374151;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.dropdown-item.selected .checkbox-custom {
    background: linear-gradient(135deg, #22C55E, #84CC16);
    border-color: #22C55E;
}

.checkbox-custom svg {
    display: none;
    width: 12px;
    height: 12px;
}

.dropdown-item.selected .checkbox-custom svg {
    display: block;
}

.selected-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #22C55E;
}

.selected-badge button {
    background: none;
    border: none;
    color: #22C55E;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
}

.selected-badge button:hover {
    opacity: 0.7;
}

/* Custom button color */
.btn-create-workout {
    background: linear-gradient(135deg, #22C55E, #84CC16);
    color: black !important;
}
</style>
{% endblock %}

{% block coach_content %}
<div class="space-y-8">
    
    <!-- Top Bar -->
    <div class="flex flex-col md:flex-row items-start md:items-center justify-between gap-6">
        <div>
            <h1 class="text-4xl font-black text-white tracking-tight leading-tight">
                Workout Catalog
            </h1>
            <p class="text-gray-400 mt-2 text-lg">Browse and manage your official training routines.</p>
        </div>

        <div class="flex items-center gap-4">
            <a href="{{ path('coach_exercise_list') }}" 
               class="px-5 py-3 bg-gray-800 hover:bg-gray-700 text-white rounded-xl font-bold text-sm transition-all border border-gray-700 shadow-lg">
                <i class="fas fa-list-ul mr-2"></i> Manage Exercises
            </a>
            <a href="{{ path('coach_workout_create') }}" 
               class="px-6 py-3 btn-create-workout rounded-xl font-bold text-sm shadow-xl hover:shadow-green-500/20 transition-all">
                <i class="fas fa-plus mr-2"></i> Create Workout
            </a>
        </div>
    </div>

    <!-- Main Container -->
    <div class="max-w-[1400px] mx-auto px-8 py-8">
        
        <!-- Page Header -->
        <div class="mb-8">
            <h1 class="text-5xl font-black tracking-tight mb-2">
                Workout Catalog
            </h1>
            <p class="text-gray-500 text-lg">
                Browse and manage your workout routines
            </p>
        </div>

        <!-- Search Bar & Filters -->
        <div class="mb-8 space-y-4">
            <!-- Search Bar and Dropdown Filter -->
            <div class="flex gap-4 items-start">
                <!-- Search Bar -->
                <div class="relative flex-1 max-w-xl">
                    <input type="text" 
                           id="searchInput"
                           placeholder="Search a workout..." 
                           class="w-full px-5 py-4 bg-[#0D0D0D] border border-gray-800 rounded-xl text-white placeholder-gray-600 focus:outline-none focus:border-green-500 search-input transition-all">
                    <svg class="w-5 h-5 absolute right-5 top-1/2 -translate-y-1/2 text-gray-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                    </svg>
                </div>

                <!-- Objectives Dropdown Filter -->
                <div class="dropdown-container w-80">
                    <button id="dropdownButton" class="dropdown-button w-full px-5 py-4 bg-[#0D0D0D] border border-gray-800 rounded-xl text-left flex items-center justify-between hover:border-green-500 transition-all">
                        <span class="text-gray-400" id="dropdownLabel">Filter by objectives</span>
                        <svg class="w-5 h-5 text-gray-600 transition-transform" id="dropdownIcon" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                        </svg>
                    </button>

                    <div id="dropdownMenu" class="dropdown-menu hidden">
                        {% set allObjectives = [] %}
                        {% for workout in workouts %}
                            {% for objectif in workout.objectifs %}
                                {% if objectif.name not in allObjectives %}
                                    {% set allObjectives = allObjectives|merge([objectif.name]) %}
                                {% endif %}
                            {% endfor %}
                        {% endfor %}

                        {% for objectif in allObjectives %}
                            <div class="dropdown-item" data-value="{{ objectif|lower|replace({' ': '-'}) }}">
                                <div class="checkbox-custom">
                                    <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path>
                                    </svg>
                                </div>
                                <span class="text-gray-300 font-medium">{{ objectif }}</span>
                            </div>
                        {% endfor %}
                    </div>
                </div>
            </div>

            <!-- Selected Objectives Tags -->
            <div id="selectedTags" class="flex flex-wrap gap-2"></div>
        </div>

        <!-- Alerts -->
        {% for message in app.flashes('success') %}
            <div class="mb-6 bg-green-500/5 border border-green-500/20 rounded-xl px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                    <span class="text-green-400 font-medium">{{ message }}</span>
                </div>
                <button onclick="this.parentElement.parentElement.remove()" class="text-green-400 hover:text-green-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        {% endfor %}

        {% for message in app.flashes('warning') %}
            <div class="mb-6 bg-amber-500/5 border border-amber-500/20 rounded-xl px-6 py-4 flex items-center justify-between">
                <div class="flex items-center gap-3">
                    <div class="w-2 h-2 bg-amber-500 rounded-full"></div>
                    <span class="text-amber-400 font-medium">{{ message }}</span>
                </div>
                <button onclick="this.parentElement.parentElement.remove()" class="text-amber-400 hover:text-amber-300">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            </div>
        {% endfor %}

        {% if exerciseCount == 0 %}
            <div class="mb-8 bg-blue-500/5 border border-blue-500/20 rounded-xl px-6 py-5">
                <div class="flex items-start gap-4">
                    <svg class="w-6 h-6 text-blue-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"></path>
                    </svg>
                    <div>
                        <h3 class="text-base font-bold text-blue-400 mb-1">No exercises available</h3>
                        <p class="text-gray-400 text-sm">
                            Create at least one exercise before building workouts. 
                            <a href="{{ path('coach_exercise_create') }}" class="text-blue-400 underline hover:text-blue-300">Create exercise</a>
                        </p>
                    </div>
                </div>
            </div>
        {% endif %}

        <!-- Section Title with Results Counter -->
        <div class="mb-6 flex items-center justify-between">
            <h2 class="text-sm font-bold text-gray-500 uppercase tracking-wider">
                Available Routines
            </h2>
            <span id="resultsCounter" class="text-sm text-gray-600">
                {% if workouts is not empty %}
                    {{ workouts|length }} workout(s)
                {% endif %}
            </span>
        </div>

        {% if workouts is empty %}
            <!-- Empty State -->
            <div id="emptyState" class="flex flex-col items-center justify-center py-24 bg-[#0D0D0D] rounded-2xl border border-gray-900">
                <svg class="w-20 h-20 text-gray-800 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"></path>
                </svg>
                <h3 class="text-xl font-bold text-gray-400 mb-2">No workouts yet</h3>
                <p class="text-gray-600">
                    {% if exerciseCount > 0 %}
                        Create your first workout to get started
                    {% else %}
                        Start by creating exercises first
                    {% endif %}
                </p>
            </div>
        {% else %}
            <!-- Workouts List -->
            <div id="workoutsList" class="space-y-4">
                {% for workout in workouts %}
                    <div class="workout-card bg-[#0D0D0D] border border-gray-900 rounded-2xl overflow-hidden card-hover shine-effect"
                         data-name="{{ workout.nom|lower }}"
                         data-description="{{ workout.description|default('')|lower }}"
                         data-objectives="{{ workout.objectifs|map(o => o.name|lower|replace({' ': '-'}))|join(',') }}">
                        <div class="flex items-center justify-between p-6">
                            
                            <!-- Left Section -->
                            <div class="flex items-center gap-5 flex-1">
                                <!-- Icon -->
                                <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-lime-500 rounded-xl flex items-center justify-center flex-shrink-0 icon-glow">
                                    <svg class="w-7 h-7 text-black" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                    </svg>
                                </div>

                                <!-- Info -->
                                <div class="flex-1 min-w-0">
                                    <h3 class="text-xl font-bold mb-2 truncate">{{ workout.nom }}</h3>
                                    
                                    <div class="flex items-center gap-3 flex-wrap">
                                        <!-- Duration -->
                                        <div class="flex items-center gap-2 text-gray-400 text-sm">
                                            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm1-12a1 1 0 10-2 0v4a1 1 0 00.293.707l2.828 2.829a1 1 0 101.415-1.415L11 9.586V6z" clip-rule="evenodd"></path>
                                            </svg>
                                            <span class="font-semibold">{{ workout.duree }} min</span>
                                        </div>

                                        <!-- Level -->
                                        <span class="px-3 py-1 bg-green-500/10 text-green-400 rounded-lg text-xs font-bold uppercase">
                                            {% if workout.niveau == 'BEGINNER' %}
                                                Beginner
                                            {% elseif workout.niveau == 'INTERMEDIATE' %}
                                                Intermediate
                                            {% else %}
                                                Advanced
                                            {% endif %}
                                        </span>

                                        <!-- Objectives -->
                                        {% if workout.objectifs is not empty %}
                                            {% for objectif in workout.objectifs|slice(0, 2) %}
                                                <span class="px-3 py-1 bg-gray-800 text-gray-300 rounded-lg text-xs font-semibold">
                                                    {{ objectif.name }}
                                                </span>
                                            {% endfor %}
                                        {% endif %}
                                    </div>

                                    <!-- Description (mobile hidden) -->
                                    <p class="text-gray-500 text-sm mt-2 hidden lg:block">
                                        {{ workout.description|default('No description')|slice(0, 100) }}{% if workout.description|length > 100 %}...{% endif %}
                                    </p>
                                </div>
                            </div>

                            <!-- Right Section - Actions -->
                            <div class="flex items-center gap-3 ml-4">
                                <a href="{{ path('coach_workout_details', {id: workout.id}) }}" 
                                   class="px-6 py-3 bg-white text-black rounded-xl font-bold text-sm hover:bg-gray-100 transition-all whitespace-nowrap">
                                    View Details
                                </a>
                                
                                <a href="{{ path('coach_workout_edit', {id: workout.id}) }}" 
                                   class="w-11 h-11 bg-gray-900 hover:bg-gray-800 rounded-xl flex items-center justify-center transition-all border border-gray-800">
                                    <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"></path>
                                    </svg>
                                </a>

                                <form method="post" 
                                      action="{{ path('coach_workout_delete', {id: workout.id}) }}"
                                      onsubmit="return confirm('Delete this workout?');">
                                    <button type="submit" 
                                            class="w-11 h-11 bg-red-500/10 hover:bg-red-500/20 rounded-xl flex items-center justify-center transition-all border border-red-500/20">
                                        <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                                        </svg>
                                    </button>
                                </form>
                            </div>
                        </div>

                        <!-- Expandable section for exercises -->
                        <div class="border-t border-gray-900 bg-black/30 px-6 py-4">
                            <div class="flex items-center justify-between text-sm">
                                <div class="flex items-center gap-2 text-gray-500">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20">
                                        <path d="M9 2a1 1 0 000 2h2a1 1 0 100-2H9z"></path>
                                        <path fill-rule="evenodd" d="M4 5a2 2 0 012-2 3 3 0 003 3h2a3 3 0 003-3 2 2 0 012 2v11a2 2 0 01-2 2H6a2 2 0 01-2-2V5zm3 4a1 1 0 000 2h.01a1 1 0 100-2H7zm3 0a1 1 0 000 2h3a1 1 0 100-2h-3zm-3 4a1 1 0 100 2h.01a1 1 0 100-2H7zm3 0a1 1 0 100 2h3a1 1 0 100-2h-3z" clip-rule="evenodd"></path>
                                    </svg>
                                    <span class="font-semibold">{{ workout.exercises|length }} exercise(s) included</span>
                                </div>
                                {% if workout.exercises|length > 0 %}
                                    <div class="flex -space-x-2">
                                        {% for i in 1..min(3, workout.exercises|length) %}
                                            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-green-500 to-lime-500 border-2 border-black flex items-center justify-center text-black text-xs font-bold">
                                                {{ i }}
                                            </div>
                                        {% endfor %}
                                        {% if workout.exercises|length > 3 %}
                                            <div class="w-8 h-8 rounded-full bg-gray-800 border-2 border-black flex items-center justify-center text-gray-400 text-xs font-bold">
                                                +{{ workout.exercises|length - 3 }}
                                            </div>
                                        {% endif %}
                                    </div>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% endfor %}
            </div>

            <!-- No Results State -->
            <div id="noResultsState" class="hidden flex-col items-center justify-center py-24 bg-[#0D0D0D] rounded-2xl border border-gray-900">
                <svg class="w-20 h-20 text-gray-800 mb-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
                </svg>
                <h3 class="text-xl font-bold text-gray-400 mb-2">No workouts found</h3>
                <p class="text-gray-600">Try adjusting your search or filters</p>
            </div>
        {% endif %}
    </div>
</div>

<!-- JavaScript for Search and Multi-Select Filter -->
<script>
document.addEventListener('DOMContentLoaded', function() {
    const searchInput = document.getElementById('searchInput');
    const workoutCards = document.querySelectorAll('.workout-card');
    const resultsCounter = document.getElementById('resultsCounter');
    const noResultsState = document.getElementById('noResultsState');
    const workoutsList = document.getElementById('workoutsList');
    
    // Dropdown elements
    const dropdownButton = document.getElementById('dropdownButton');
    const dropdownMenu = document.getElementById('dropdownMenu');
    const dropdownIcon = document.getElementById('dropdownIcon');
    const dropdownLabel = document.getElementById('dropdownLabel');
    const selectedTags = document.getElementById('selectedTags');
    const dropdownItems = document.querySelectorAll('.dropdown-item');
    
    let selectedObjectives = [];
    let currentSearch = '';

    // Toggle dropdown
    dropdownButton?.addEventListener('click', function(e) {
        e.stopPropagation();
        dropdownMenu.classList.toggle('hidden');
        dropdownIcon.style.transform = dropdownMenu.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', function(e) {
        if (dropdownMenu && !dropdownMenu.contains(e.target) && e.target !== dropdownButton) {
            dropdownMenu.classList.add('hidden');
            dropdownIcon.style.transform = 'rotate(0deg)';
        }
    });

    // Handle dropdown item selection
    dropdownItems.forEach(item => {
        item.addEventListener('click', function(e) {
            e.stopPropagation();
            const value = this.dataset.value;
            const text = this.querySelector('span').textContent;
            
            if (this.classList.contains('selected')) {
                // Deselect
                this.classList.remove('selected');
                selectedObjectives = selectedObjectives.filter(obj => obj.value !== value);
            } else {
                // Select
                this.classList.add('selected');
                selectedObjectives.push({ value: value, text: text });
            }
            
            updateSelectedTags();
            updateDropdownLabel();
            applyFilters();
        });
    });

    // Update selected tags display
    function updateSelectedTags() {
        if (!selectedTags) return;
        selectedTags.innerHTML = '';
        
        selectedObjectives.forEach(obj => {
            const badge = document.createElement('div');
            badge.className = 'selected-badge';
            badge.innerHTML = `
                <span>${obj.text}</span>
                <button onclick="removeObjective('${obj.value}')">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                    </svg>
                </button>
            `;
            selectedTags.appendChild(badge);
        });
    }

    // Update dropdown label
    function updateDropdownLabel() {
        if (!dropdownLabel) return;
        if (selectedObjectives.length === 0) {
            dropdownLabel.textContent = 'Filter by objectives';
            dropdownLabel.classList.add('text-gray-400');
            dropdownLabel.classList.remove('text-white');
        } else {
            dropdownLabel.textContent = `${selectedObjectives.length} objective(s) selected`;
            dropdownLabel.classList.remove('text-gray-400');
            dropdownLabel.classList.add('text-white');
        }
    }

    // Remove objective (global function for onclick)
    window.removeObjective = function(value) {
        selectedObjectives = selectedObjectives.filter(obj => obj.value !== value);
        
        // Update dropdown item
        dropdownItems.forEach(item => {
            if (item.dataset.value === value) {
                item.classList.remove('selected');
            }
        });
        
        updateSelectedTags();
        updateDropdownLabel();
        applyFilters();
    };

    // Search functionality
    if (searchInput) {
        searchInput.addEventListener('input', function(e) {
            currentSearch = e.target.value.toLowerCase().trim();
            applyFilters();
        });
    }

    // Apply filters
    function applyFilters() {
        let visibleCount = 0;
        
        workoutCards.forEach(card => {
            const name = card.dataset.name || '';
            const description = card.dataset.description || '';
            const objectives = card.dataset.objectives ? card.dataset.objectives.split(',') : [];
            
            // Check search match
            const matchesSearch = !currentSearch || 
                                name.includes(currentSearch) || 
                                description.includes(currentSearch);
            
            // Check filter match (if any objectives selected, card must have at least one)
            let matchesFilter = true;
            if (selectedObjectives.length > 0) {
                matchesFilter = selectedObjectives.some(selectedObj => 
                    objectives.includes(selectedObj.value)
                );
            }
            
            // Show or hide card
            if (matchesSearch && matchesFilter) {
                card.classList.remove('hidden');
                visibleCount++;
            } else {
                card.classList.add('hidden');
            }
        });
        
        // Update counter
        if (resultsCounter) {
            resultsCounter.textContent = `${visibleCount} workout(s)`;
        }
        
        // Show/hide no results state
        if (workoutsList && noResultsState) {
            if (visibleCount === 0 && workoutCards.length > 0) {
                workoutsList.style.display = 'none';
                noResultsState.style.display = 'flex';
            } else {
                workoutsList.style.display = 'block';
                noResultsState.style.display = 'none';
            }
        }
    }
});
