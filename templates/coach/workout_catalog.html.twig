{% extends 'coach/base_coach.html.twig' %}

{% block title %}Workout Catalog - FitSense{% endblock %}

{% block coach_page_title %}Workout Catalog{% endblock %}
{% block coach_page_subtitle %}Browse and manage your workout routines{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
.gradient-text {
    background: linear-gradient(135deg, #22C55E, #84CC16);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
}

.gradient-btn {
    background: linear-gradient(135deg, #22C55E, #84CC16);
}

.card-hover {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

.card-hover:hover {
    transform: translateY(-4px);
    box-shadow: 0 20px 40px rgba(34, 197, 94, 0.15);
}

.search-input:focus {
    box-shadow: 0 0 0 2px rgba(34, 197, 94, 0.3);
}

.icon-glow {
    filter: drop-shadow(0 0 8px rgba(34, 197, 94, 0.4));
}

.shine-effect {
    position: relative;
    overflow: hidden;
}

.shine-effect::after {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
        to bottom right,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.03) 50%,
        rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(45deg);
    animation: shine 3s infinite;
}

@keyframes shine {
    0% { transform: translateX(-100%) translateY(-100%) rotate(45deg); }
    100% { transform: translateX(100%) translateY(100%) rotate(45deg); }
}

/* Dropdown Styles */
.dropdown-container {
    position: relative;
}

.dropdown-button {
    cursor: pointer;
    user-select: none;
}

.dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    margin-top: 0.5rem;
    background: #0D0D0D;
    border: 1px solid #1F1F1F;
    border-radius: 12px;
    padding: 0.5rem;
    z-index: 50;
    max-height: 300px;
    overflow-y: auto;
    box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
}

.dropdown-menu::-webkit-scrollbar {
    width: 8px;
}

.dropdown-menu::-webkit-scrollbar-track {
    background: #1F1F1F;
    border-radius: 4px;
}

.dropdown-menu::-webkit-scrollbar-thumb {
    background: #374151;
    border-radius: 4px;
}

.dropdown-menu::-webkit-scrollbar-thumb:hover {
    background: #4B5563;
}

.dropdown-item {
    padding: 0.75rem 1rem;
    border-radius: 8px;
    cursor: pointer;
    transition: all 0.2s;
    display: flex;
    align-items: center;
    gap: 0.75rem;
}

.dropdown-item:hover {
    background: #1F1F1F;
}

.dropdown-item.selected {
    background: rgba(34, 197, 94, 0.1);
}

.checkbox-custom {
    width: 18px;
    height: 18px;
    border: 2px solid #374151;
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
}

.dropdown-item.selected .checkbox-custom {
    background: linear-gradient(135deg, #22C55E, #84CC16);
    border-color: #22C55E;
}

.checkbox-custom svg {
    display: none;
    width: 12px;
    height: 12px;
}

.dropdown-item.selected .checkbox-custom svg {
    display: block;
}

.selected-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.375rem 0.75rem;
    background: rgba(34, 197, 94, 0.15);
    border: 1px solid rgba(34, 197, 94, 0.3);
    border-radius: 8px;
    font-size: 0.875rem;
    font-weight: 600;
    color: #22C55E;
}

.selected-badge button {
    background: none;
    border: none;
    color: #22C55E;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    transition: opacity 0.2s;
}

.selected-badge button:hover {
    opacity: 0.7;
}

/* Confirmation Modal Recovery */
#confirmModal.hidden { display: none; }
.modal-overlay {
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    background: rgba(0, 0, 0, 0.75);
    backdrop-filter: blur(4px);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 1000;
}
.modal-content-delete {
    background: #0D0D0D;
    border: 1px solid #1F1F1F;
    border-radius: 16px;
    max-width: 450px;
    width: 90%;
    padding: 2rem;
}
</style>
{% endblock %}

{% block coach_content %}
<div class="space-y-8">
    <!-- Action Bar -->
    <div class="flex items-center justify-end gap-3 mb-6">
        <a href="{{ path('coach_exercise_list') }}" 
           class="px-5 py-2.5 bg-gray-800 hover:bg-gray-700 rounded-lg font-semibold text-sm transition-all border border-gray-700 text-gray-300">
            <i class="fas fa-list-check mr-2"></i>
            Manage Exercises
        </a>
        <a href="{{ path('coach_workout_create') }}" 
           class="px-6 py-2.5 gradient-btn rounded-lg font-bold text-sm text-black shadow-lg hover:shadow-xl transition-all {{ exerciseCount == 0 ? 'opacity-50 cursor-not-allowed' : '' }}"
           {% if exerciseCount == 0 %}onclick="return false;"{% endif %}>
            <i class="fas fa-plus mr-2"></i>
            Create Workout
        </a>
    </div>

    <!-- Search Bar & Filters -->
    <div class="space-y-4 bg-gray-900/40 p-6 rounded-2xl border border-gray-800">
        <div class="flex flex-col lg:flex-row gap-4">
            <!-- Search Bar -->
            <div class="relative flex-1">
                <input type="text" 
                       id="searchInput"
                       placeholder="Search a workout..." 
                       class="w-full px-5 py-3.5 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-green-500 search-input transition-all">
                <i class="fas fa-search absolute right-5 top-1/2 -translate-y-1/2 text-gray-600"></i>
            </div>

            <!-- Objectives Dropdown Filter -->
            <div class="dropdown-container w-full lg:w-80">
                <button id="dropdownButton" class="dropdown-button w-full px-5 py-3.5 bg-gray-900 border border-gray-700 rounded-xl text-left flex items-center justify-between hover:border-green-500 transition-all text-sm">
                    <span class="text-gray-400" id="dropdownLabel">Filter by objectives</span>
                    <i class="fas fa-chevron-down text-gray-600 transition-transform" id="dropdownIcon"></i>
                </button>

                <div id="dropdownMenu" class="dropdown-menu hidden">
                    {% set allObjectives = [] %}
                    {% for workout in workouts %}
                        {% for objectif in workout.objectifs %}
                            {% if objectif.name not in allObjectives %}
                                {% set allObjectives = allObjectives|merge([objectif.name]) %}
                            {% endif %}
                        {% endfor %}
                    {% endfor %}

                    {% for objectif in allObjectives %}
                        <div class="dropdown-item" data-value="{{ objectif|lower|replace({' ': '-'}) }}">
                            <div class="checkbox-custom">
                                <i class="fas fa-check text-[10px] text-white hidden"></i>
                            </div>
                            <span class="text-gray-300 font-medium text-sm">{{ objectif }}</span>
                        </div>
                    {% endfor %}
                </div>
            </div>
        </div>

        <!-- Selected Objectives Tags -->
        <div id="selectedTags" class="flex flex-wrap gap-2"></div>
    </div>

    <!-- Alerts -->
    {% for message in app.flashes('success') %}
        <div class="bg-green-500/10 border border-green-500/20 rounded-xl px-6 py-4 flex items-center justify-between animate-fadeIn">
            <div class="flex items-center gap-3 text-green-400">
                <i class="fas fa-check-circle"></i>
                <span class="font-medium">{{ message }}</span>
            </div>
            <button onclick="this.parentElement.remove()" class="text-green-400 hover:text-green-300 transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
    {% endfor %}

    {% for message in app.flashes('warning') %}
        <div class="bg-amber-500/10 border border-amber-500/20 rounded-xl px-6 py-4 flex items-center justify-between animate-fadeIn">
            <div class="flex items-center gap-3 text-amber-400">
                <i class="fas fa-exclamation-triangle"></i>
                <span class="font-medium">{{ message }}</span>
            </div>
            <button onclick="this.parentElement.remove()" class="text-amber-400 hover:text-amber-300 transition">
                <i class="fas fa-times"></i>
            </button>
        </div>
    {% endfor %}

    {% if exerciseCount == 0 %}
        <div class="bg-blue-500/10 border border-blue-500/20 rounded-xl px-6 py-5">
            <div class="flex items-start gap-4 text-blue-400">
                <i class="fas fa-info-circle text-xl mt-0.5"></i>
                <div>
                    <h3 class="text-base font-bold mb-1">No exercises available</h3>
                    <p class="text-gray-400 text-sm">
                        Create at least one exercise before building workouts. 
                        <a href="{{ path('coach_exercise_create') }}" class="text-blue-400 underline hover:text-blue-300 font-semibold">Create exercise</a>
                    </p>
                </div>
            </div>
        </div>
    {% endif %}

    <!-- Section Title with Results Counter -->
    <div class="flex items-center justify-between mb-4">
        <h2 class="text-xs font-bold text-gray-500 uppercase tracking-widest flex items-center gap-2">
            <span class="w-2 h-2 bg-green-500 rounded-full"></span>
            Available Routines
        </h2>
        <span id="resultsCounter" class="text-xs font-bold text-gray-600 bg-gray-900 px-3 py-1 rounded-full border border-gray-800">
            {% if workouts is not empty %}
                {{ workouts|length }} workout(s)
            {% endif %}
        </span>
    </div>

    {% if workouts is empty %}
        <!-- Empty State -->
        <div id="emptyState" class="flex flex-col items-center justify-center py-24 bg-gray-900/20 rounded-2xl border border-dashed border-gray-800">
            <div class="w-20 h-20 bg-gray-800/50 rounded-full flex items-center justify-center mb-6">
                <i class="fas fa-dumbbell text-3xl text-gray-600"></i>
            </div>
            <h3 class="text-xl font-bold text-gray-400 mb-2">No workouts yet</h3>
            <p class="text-gray-500 max-w-sm text-center">
                {% if exerciseCount > 0 %}
                    Create your first workout to get started tracking athlete progress
                {% else %}
                    Start by creating exercises first to build your workout variations
                {% endif %}
            </p>
        </div>
    {% else %}
        <!-- Workouts List -->
        <div id="workoutsList" class="grid grid-cols-1 gap-4">
            {% for workout in workouts %}
                <div class="workout-card bg-gray-900/40 border border-gray-800 rounded-2xl overflow-hidden card-hover shine-effect group"
                     data-name="{{ workout.nom|lower }}"
                     data-description="{{ workout.description|default('')|lower }}"
                     data-objectives="{{ workout.objectifs|map(o => o.name|lower|replace({' ': '-'}))|join(',') }}">
                    <div class="flex flex-col lg:flex-row items-center justify-between p-6 gap-6">
                        
                        <!-- Left Section -->
                        <div class="flex items-center gap-5 flex-1 min-w-0 w-full">
                            <!-- Icon -->
                            <div class="w-14 h-14 bg-gradient-to-br from-green-500 to-lime-500 rounded-xl flex items-center justify-center flex-shrink-0 icon-glow transform group-hover:rotate-6 transition">
                                <i class="fas fa-bolt text-black text-2xl"></i>
                            </div>

                            <!-- Info -->
                            <div class="flex-1 min-w-0">
                                <div class="flex items-center gap-3 mb-2">
                                    <h3 class="text-xl font-bold truncate group-hover:text-green-400 transition">{{ workout.nom }}</h3>
                                    <span class="px-2 py-0.5 bg-green-500/10 text-green-400 rounded-lg text-[10px] font-black uppercase tracking-tighter border border-green-500/20">
                                        {% if workout.niveau == 'BEGINNER' %}
                                            Beginner
                                        {% elseif workout.niveau == 'INTERMEDIATE' %}
                                            Intermediate
                                        {% else %}
                                            Advanced
                                        {% endif %}
                                    </span>
                                </div>
                                
                                <div class="flex items-center gap-4 flex-wrap">
                                    <!-- Duration -->
                                    <div class="flex items-center gap-2 text-gray-400 text-xs font-semibold">
                                        <i class="far fa-clock text-green-500"></i>
                                        <span>{{ workout.duree }} min</span>
                                    </div>

                                    <!-- Exercises Count -->
                                    <div class="flex items-center gap-2 text-gray-400 text-xs font-semibold border-l border-gray-800 pl-4">
                                        <i class="fas fa-layer-group text-blue-500"></i>
                                        <span>{{ workout.exercises|length }} Exercises</span>
                                    </div>

                                    <!-- Objectives -->
                                    {% if workout.objectifs is not empty %}
                                        <div class="flex items-center gap-2 flex-wrap border-l border-gray-800 pl-4">
                                            {% for objectif in workout.objectifs|slice(0, 2) %}
                                                <span class="px-2 py-0.5 bg-gray-800 text-gray-400 rounded text-[10px] font-bold uppercase tracking-wider">
                                                    {{ objectif.name }}
                                                </span>
                                            {% endfor %}
                                        </div>
                                    {% endif %}
                                </div>
                            </div>
                        </div>

                        <!-- Right Section - Actions -->
                        <div class="flex items-center gap-3 w-full lg:w-auto justify-end">
                            <a href="{{ path('coach_workout_details', {id: workout.id}) }}" 
                               class="flex-1 lg:flex-none px-6 py-3 bg-white text-black rounded-xl font-bold text-sm hover:bg-gray-100 transition-all text-center whitespace-nowrap">
                                View Details
                            </a>
                            
                            <a href="{{ path('coach_workout_edit', {id: workout.id}) }}" 
                               class="w-11 h-11 bg-gray-800 hover:bg-gray-700 rounded-xl flex items-center justify-center transition-all border border-gray-700 text-gray-400 hover:text-white"
                               title="Edit Workout">
                                <i class="fas fa-edit"></i>
                            </a>

                            <form method="post" 
                                  action="{{ path('coach_workout_delete', {id: workout.id}) }}"
                                  class="delete-form"
                                  data-workout-name="{{ workout.nom }}">
                                <button type="button"
                                        class="delete-btn w-11 h-11 bg-red-500/10 hover:bg-red-500/20 rounded-xl flex items-center justify-center transition-all border border-red-500/20 text-red-400"
                                        title="Delete Workout">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            {% endfor %}
        </div>

        <!-- No Results State -->
        <div id="noResultsState" class="hidden flex-col items-center justify-center py-24 bg-gray-900/20 rounded-2xl border border-gray-800">
            <i class="fas fa-search text-gray-800 text-5xl mb-6"></i>
            <h3 class="text-xl font-bold text-gray-400 mb-2">No workouts found</h3>
            <p class="text-gray-600">Try adjusting your search query or filters</p>
        </div>
    {% endif %}
</div>
{% endblock %}
{% block scripts %}
    {{ parent() }}
    <script>
    document.addEventListener('DOMContentLoaded', function() {
        const searchInput = document.getElementById('searchInput');
        const workoutCards = document.querySelectorAll('.workout-card');
        const resultsCounter = document.getElementById('resultsCounter');
        const noResultsState = document.getElementById('noResultsState');
        const workoutsList = document.getElementById('workoutsList');
        
        // Dropdown elements
        const dropdownButton = document.getElementById('dropdownButton');
        const dropdownMenu = document.getElementById('dropdownMenu');
        const dropdownIcon = document.getElementById('dropdownIcon');
        const dropdownLabel = document.getElementById('dropdownLabel');
        const selectedTags = document.getElementById('selectedTags');
        const dropdownItems = document.querySelectorAll('.dropdown-item');
        
        // Modal elements
        const confirmModal = document.getElementById('confirmModal');
        const workoutNameModal = document.getElementById('workoutNameModal');
        const cancelBtn = document.getElementById('cancelBtn');
        const confirmBtn = document.getElementById('confirmBtn');
        let currentForm = null;
        
        let selectedObjectives = [];
        let currentSearch = '';

        // Delete confirmation modal
        const deleteForms = document.querySelectorAll('.delete-form');
        deleteForms.forEach(form => {
            const deleteBtn = form.querySelector('.delete-btn');
            deleteBtn.addEventListener('click', function(e) {
                e.preventDefault();
                currentForm = form;
                const workoutName = form.dataset.workoutName;
                workoutNameModal.textContent = workoutName;
                confirmModal.classList.remove('hidden');
            });
        });

        // Cancel deletion
        cancelBtn.addEventListener('click', function() {
            confirmModal.classList.add('hidden');
            currentForm = null;
        });

        // Confirm deletion
        confirmBtn.addEventListener('click', function() {
            if (currentForm) {
                currentForm.submit();
            }
        });

        // Close modal on overlay click
        confirmModal.addEventListener('click', function(e) {
            if (e.target === confirmModal) {
                confirmModal.classList.add('hidden');
                currentForm = null;
            }
        });

        // Close modal on Escape key
        document.addEventListener('keydown', function(e) {
            if (e.key === 'Escape' && !confirmModal.classList.contains('hidden')) {
                confirmModal.classList.add('hidden');
                currentForm = null;
            }
        });

        // Toggle dropdown
        dropdownButton.addEventListener('click', function(e) {
            e.stopPropagation();
            dropdownMenu.classList.toggle('hidden');
            if (dropdownIcon) {
                dropdownIcon.style.transform = dropdownMenu.classList.contains('hidden') ? 'rotate(0deg)' : 'rotate(180deg)';
            }
        });

        // Close dropdown when clicking outside
        document.addEventListener('click', function(e) {
            if (dropdownMenu && !dropdownMenu.contains(e.target) && e.target !== dropdownButton) {
                dropdownMenu.classList.add('hidden');
                if (dropdownIcon) dropdownIcon.style.transform = 'rotate(0deg)';
            }
        });

        // Handle dropdown item selection
        dropdownItems.forEach(item => {
            item.addEventListener('click', function(e) {
                e.stopPropagation();
                const value = this.dataset.value;
                const text = this.querySelector('span').textContent;
                
                if (this.classList.contains('selected')) {
                    // Deselect
                    this.classList.remove('selected');
                    selectedObjectives = selectedObjectives.filter(obj => obj.value !== value);
                } else {
                    // Select
                    this.classList.add('selected');
                    selectedObjectives.push({ value: value, text: text });
                }
                
                updateSelectedTags();
                updateDropdownLabel();
                applyFilters();
            });
        });

        // Update selected tags display
        function updateSelectedTags() {
            selectedTags.innerHTML = '';
            
            selectedObjectives.forEach(obj => {
                const badge = document.createElement('div');
                badge.className = 'selected-badge';
                badge.innerHTML = `
                    <span>${obj.text}</span>
                    <button onclick="removeObjective('${obj.value}')">
                        <i class="fas fa-times text-xs"></i>
                    </button>
                `;
                selectedTags.appendChild(badge);
            });
        }

        // Update dropdown label
        function updateDropdownLabel() {
            if (selectedObjectives.length === 0) {
                dropdownLabel.textContent = 'Filter by objectives';
                dropdownLabel.classList.add('text-gray-400');
                dropdownLabel.classList.remove('text-white');
            } else {
                dropdownLabel.textContent = `${selectedObjectives.length} objective(s) selected`;
                dropdownLabel.classList.remove('text-gray-400');
                dropdownLabel.classList.add('text-white');
            }
        }

        // Remove objective (global function for onclick)
        window.removeObjective = function(value) {
            selectedObjectives = selectedObjectives.filter(obj => obj.value !== value);
            
            // Update dropdown item
            dropdownItems.forEach(item => {
                if (item.dataset.value === value) {
                    item.classList.remove('selected');
                }
            });
            
            updateSelectedTags();
            updateDropdownLabel();
            applyFilters();
        };

        // Search functionality
        if (searchInput) {
            searchInput.addEventListener('input', function(e) {
                currentSearch = e.target.value.toLowerCase().trim();
                applyFilters();
            });
        }

        // Apply filters
        function applyFilters() {
            let visibleCount = 0;
            
            workoutCards.forEach(card => {
                const name = card.dataset.name || '';
                const description = card.dataset.description || '';
                const objectives = card.dataset.objectives ? card.dataset.objectives.split(',') : [];
                
                // Check search match
                const matchesSearch = !currentSearch || 
                                    name.includes(currentSearch) || 
                                    description.includes(currentSearch);
                
                // Check filter match (if any objectives selected, card must have at least one)
                let matchesFilter = true;
                if (selectedObjectives.length > 0) {
                    matchesFilter = selectedObjectives.some(selectedObj => 
                        objectives.includes(selectedObj.value)
                    );
                }
                
                // Show or hide card
                if (matchesSearch && matchesFilter) {
                    card.classList.remove('hidden');
                    visibleCount++;
                } else {
                    card.classList.add('hidden');
                }
            });
            
            // Update counter
            if (resultsCounter) {
                resultsCounter.textContent = `${visibleCount} workout(s)`;
            }
            
            // Show/hide no results state
            if (workoutsList && noResultsState) {
                if (visibleCount === 0 && workoutCards.length > 0) {
                    workoutsList.style.display = 'none';
                    noResultsState.style.display = 'flex';
                } else {
                    workoutsList.style.display = 'grid';
                    noResultsState.style.display = 'none';
                }
            }
        }
    });
    </script>
{% endblock %}
