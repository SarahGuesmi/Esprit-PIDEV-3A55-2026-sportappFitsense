{% extends 'base.html.twig' %}

{% block title %}Gestion des exercices - FitSense{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="display-4">Gestion des exercices</h1>
        <div>
            <a href="{{ path('coach_workout_catalog') }}" class="btn btn-outline-secondary me-2">
                <i class="bi bi-arrow-left"></i> Retour au catalogue
            </a>
            <a href="{{ path('coach_exercise_create') }}" class="btn btn-success">
                <i class="bi bi-plus-circle"></i> Créer un exercice
            </a>
        </div>
    </div>

    {% for message in app.flashes('success') %}
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            {{ message }}
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    {% endfor %}

    {% if exercises is empty %}
        <div class="alert alert-info text-center">
            <h4><i class="bi bi-info-circle"></i> Aucun exercice créé</h4>
            <p>Commencez par créer votre premier exercice !</p>
            <a href="{{ path('coach_exercise_create') }}" class="btn btn-primary">
                Créer un exercice
            </a>
        </div>
    {% else %}
        <div class="card shadow-sm">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-light">
                            <tr>
                                <th>Nom</th>
                                <th>Type</th>
                                <th>Durée</th>
                                <th>Description</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for exercise in exercises %}
                                <tr>
                                    <td class="fw-bold">{{ exercise.nom }}</td>
                                    <td><span class="badge bg-info">{{ exercise.type }}</span></td>
                                    <td>{{ exercise.duree }} sec</td>
                                    <td>{{ exercise.description|default('—')|slice(0, 50) }}{% if exercise.description|length > 50 %}...{% endif %}</td>
                                    <td>
                                        <a href="{{ path('coach_exercise_edit', {id: exercise.id}) }}" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" 
                                            action="{{ path('coach_exercise_delete', {id: exercise.id}) }}"
                                            onsubmit="return confirm('Êtes-vous sûr de vouloir supprimer cet exercice ?');"
                                            class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            {% endfor %}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="mt-3 text-muted">
            <i class="bi bi-info-circle"></i> Total : {{ exercises|length }} exercice(s)
        </div>
    {% endif %}
</div>
{% endblock %}
