<script>
(function() {
    function loadChatUnread() {
        var req = new XMLHttpRequest();
        req.open('GET', '{{ path('app_chat_unread_count') }}', true);
        req.setRequestHeader('X-Requested-With', 'XMLHttpRequest');
        req.onreadystatechange = function() {
            if (req.readyState === 4 && req.status === 200) {
                try {
                    var d = JSON.parse(req.responseText);
                    var el = document.getElementById('chat-sidebar-unread');
                    if (el) {
                        el.textContent = d.total > 99 ? '99+' : d.total;
                        el.style.display = d.total > 0 ? 'inline-flex' : 'none';
                    }
                } catch (e) {}
            }
        };
        req.send();
    }
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', loadChatUnread);
    } else {
        loadChatUnread();
    }
})();
</script>
