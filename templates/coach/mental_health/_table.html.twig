{% for etat in evaluations %}
    <tr class="table-row hover:bg-blue-500/5 transition-all duration-200 group">
        <td class="px-6 py-5 whitespace-nowrap">
            <div class="flex items-center">
                <div class="flex-shrink-0 h-10 w-10">
                    <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center font-bold text-white shadow-lg shadow-blue-500/20">
                        {{ etat.user.firstname|first|upper }}{{ etat.user.lastname|first|upper }}
                    </div>
                </div>
                <div class="ml-4">
                    <div class="text-sm font-bold text-white group-hover:text-blue-400 transition">{{ etat.user.firstname }} {{ etat.user.lastname }}</div>
                    <div class="text-xs text-gray-500 font-medium">Athlete</div>
                </div>
            </div>
        </td>
        <td class="px-6 py-5 whitespace-nowrap text-sm text-gray-300">
            <div class="flex flex-col">
                <span class="text-white">{{ etat.createdAt|date('d/m/Y') }}</span>
                <span class="text-xs font-medium text-gray-500">{{ etat.createdAt|date('H:i') }}</span>
            </div>
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            <span class="text-sm text-gray-300">{{ etat.stressLevel }}/5</span>
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            <span class="text-sm text-gray-300">{{ etat.sleepQuality }}/5</span>
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            <span class="text-sm text-gray-300">{{ etat.mood }}/5</span>
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            <span class="text-sm text-gray-300">{{ etat.motivation }}/5</span>
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            <span class="text-sm font-bold text-blue-400 bg-blue-500/10 px-3 py-1 rounded-lg">{{ etat.totalScore }}</span>
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            {% set status = etat.status %}
            {% if status == 'Good' %}
                <span class="px-3 py-1 text-xs font-bold rounded-lg bg-green-500/20 text-green-400 border border-green-500/30">Good</span>
            {% elseif status == 'Moderate' %}
                <span class="px-3 py-1 text-xs font-bold rounded-lg bg-yellow-500/20 text-yellow-400 border border-yellow-500/30">Moderate</span>
            {% else %}
                <span class="px-3 py-1 text-xs font-bold rounded-lg bg-red-500/20 text-red-400 border border-red-500/30">Low</span>
            {% endif %}
        </td>
        <td class="px-6 py-5 text-center whitespace-nowrap">
            <button type="button" 
                    onclick="openRecommendationModal('{{ etat.user.id }}', '{{ etat.user.firstname }} {{ etat.user.lastname }}')"
                    class="inline-flex items-center px-3 py-2 text-xs font-bold text-white bg-blue-600 hover:bg-blue-700 rounded-lg transition-colors duration-200">
                <i class="fas fa-plus mr-2"></i> Recommendation
            </button>
        </td>
    </tr>
{% else %}
    <tr>
        <td colspan="9" class="px-6 py-20 text-center">
            <div class="flex flex-col items-center justify-center">
                <div class="bg-gray-800/50 rounded-2xl p-8 mb-4 border border-gray-700">
                    <i class="fas fa-brain text-gray-600 text-5xl"></i>
                </div>
                <h3 class="text-xl font-semibold text-gray-300 mb-2">No assessments found</h3>
                <p class="text-gray-500">There are no mental health evaluations to display yet.</p>
            </div>
        </td>
    </tr>
{% endfor %}
