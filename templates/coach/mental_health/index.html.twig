{% extends 'coach/base_coach.html.twig' %}

{% block title %}FitSense - Mental Health Management{% endblock %}

{% block coach_content %}
    <div class="space-y-6">
        <!-- Header Card -->
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl p-8 border border-gray-700">
            <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-blue-500/20 to-transparent rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/20 to-transparent rounded-full blur-3xl"></div>

            <div class="relative">
                <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                    <div class="w-1.5 h-10 bg-gradient-to-b from-blue-400 to-purple-400 rounded-full"></div>
                    Mental Health Overview
                </h1>
                <p class="text-gray-400 ml-6">Monitor the wellbeing of all users on the platform</p>
            </div>
        </div>

        <!-- Assessments Table -->
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl border border-gray-700">
            <div class="relative p-6 border-b border-gray-700/50 flex justify-between items-center bg-gray-900/50">
                <h2 class="text-xl font-semibold text-white flex items-center gap-3">
                    <div class="w-1 h-6 bg-gradient-to-b from-blue-400 to-purple-400 rounded-full"></div>
                    Latest Assessments
                </h2>
                
                <div class="flex items-center gap-4">
                    <div class="relative">
                        <input type="text" id="searchInput" placeholder="Search user..." class="bg-gray-800 border-gray-700 text-gray-300 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block w-64 pl-10 p-2.5 transition-all duration-300">
                        <i class="fas fa-search absolute left-3.5 top-3.5 text-gray-500"></i>
                    </div>
                    <select id="statusFilter" class="bg-gray-800 border-gray-700 text-gray-300 text-sm rounded-xl focus:ring-blue-500 focus:border-blue-500 block p-2.5 outline-none transition-all duration-300">
                        <option value="">All Statuses</option>
                        <option value="Good">Good</option>
                        <option value="Moderate">Moderate</option>
                        <option value="Low">Low</option>
                    </select>
                </div>
            </div>

            <div class="relative overflow-x-auto">
                <table class="min-w-full divide-y divide-gray-700/50">
                    <thead class="bg-gray-900/50 backdrop-blur">
                        <tr>
                            <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">User</th>
                            <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">Date</th>
                            <th class="px-6 py-5 text-center text-xs font-bold text-gray-300 uppercase tracking-wider">Stress</th>
                            <th class="px-6 py-5 text-center text-xs font-bold text-gray-300 uppercase tracking-wider">Sleep</th>
                            <th class="px-6 py-5 text-center text-xs font-bold text-gray-300 uppercase tracking-wider">Mood</th>
                            <th class="px-6 py-5 text-center text-xs font-bold text-gray-300 uppercase tracking-wider">Motivation</th>
                            <th class="px-6 py-5 text-center text-xs font-bold text-gray-300 uppercase tracking-wider">Score</th>
                            <th class="px-6 py-5 text-center text-xs font-bold text-gray-300 uppercase tracking-wider">Status</th>
                        </tr>
                    </thead>
                    <tbody id="assessmentsTableBody" class="divide-y divide-gray-700/50 backdrop-blur">
                        {% for etat in evaluations %}
                            <tr class="table-row hover:bg-blue-500/5 transition-all duration-200 group">
                                <td class="px-6 py-5 whitespace-nowrap">
                                    <div class="flex items-center">
                                        <div class="flex-shrink-0 h-10 w-10">
                                            <div class="h-10 w-10 rounded-xl bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center font-bold text-white shadow-lg shadow-blue-500/20">
                                                {{ etat.user.firstname|first|upper }}{{ etat.user.lastname|first|upper }}
                                            </div>
                                        </div>
                                        <div class="ml-4">
                                            <div class="text-sm font-bold text-white group-hover:text-blue-400 transition">{{ etat.user.firstname }} {{ etat.user.lastname }}</div>
                                            <div class="text-xs text-gray-500 font-medium">Athlete</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="px-6 py-5 whitespace-nowrap text-sm text-gray-300">
                                    <div class="flex flex-col">
                                        <span class="text-white">{{ etat.createdAt|date('d/m/Y') }}</span>
                                        <span class="text-xs font-medium text-gray-500">{{ etat.createdAt|date('H:i') }}</span>
                                    </div>
                                </td>
                                <td class="px-6 py-5 text-center whitespace-nowrap">
                                    <span class="text-sm text-gray-300">{{ etat.stressLevel }}/5</span>
                                </td>
                                <td class="px-6 py-5 text-center whitespace-nowrap">
                                    <span class="text-sm text-gray-300">{{ etat.sleepQuality }}/5</span>
                                </td>
                                <td class="px-6 py-5 text-center whitespace-nowrap">
                                    <span class="text-sm text-gray-300">{{ etat.mood }}/5</span>
                                </td>
                                <td class="px-6 py-5 text-center whitespace-nowrap">
                                    <span class="text-sm text-gray-300">{{ etat.motivation }}/5</span>
                                </td>
                                <td class="px-6 py-5 text-center whitespace-nowrap">
                                    <span class="text-sm font-bold text-blue-400 bg-blue-500/10 px-3 py-1 rounded-lg">{{ etat.totalScore }}</span>
                                </td>
                                <td class="px-6 py-5 text-center whitespace-nowrap">
                                    {% set status = etat.status %}
                                    {% if status == 'Good' %}
                                        <span class="px-3 py-1 text-xs font-bold rounded-lg bg-green-500/20 text-green-400 border border-green-500/30">Good</span>
                                    {% elseif status == 'Moderate' %}
                                        <span class="px-3 py-1 text-xs font-bold rounded-lg bg-yellow-500/20 text-yellow-400 border border-yellow-500/30">Moderate</span>
                                    {% else %}
                                        <span class="px-3 py-1 text-xs font-bold rounded-lg bg-red-500/20 text-red-400 border border-red-500/30">Low</span>
                                    {% endif %}
                                </td>
                            </tr>
                        {% else %}
                            <tr>
                                <td colspan="8" class="px-6 py-20 text-center">
                                    <div class="flex flex-col items-center justify-center">
                                        <div class="bg-gray-800/50 rounded-2xl p-8 mb-4 border border-gray-700">
                                            <i class="fas fa-brain text-gray-600 text-5xl"></i>
                                        </div>
                                        <h3 class="text-xl font-semibold text-gray-300 mb-2">No assessments found</h3>
                                        <p class="text-gray-500">There are no mental health evaluations to display yet.</p>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const searchInput = document.getElementById('searchInput');
            const statusFilter = document.getElementById('statusFilter');
            const tableRows = document.querySelectorAll('#assessmentsTableBody .table-row');

            function filterTable() {
                const searchTerm = searchInput.value.toLowerCase();
                const selectedStatus = statusFilter.value;

                tableRows.forEach(row => {
                    const userName = row.querySelector('.text-sm.font-bold').textContent.toLowerCase();
                    const status = row.querySelector('.px-3.py-1').textContent.trim();
                    
                    const matchesSearch = userName.includes(searchTerm);
                    const matchesStatus = selectedStatus === "" || status === selectedStatus;

                    if (matchesSearch && matchesStatus) {
                        row.style.display = '';
                    } else {
                        row.style.display = 'none';
                    }
                });
            }

            searchInput.addEventListener('input', filterTable);
            statusFilter.addEventListener('change', filterTable);
        });
    </script>
{% endblock %}
