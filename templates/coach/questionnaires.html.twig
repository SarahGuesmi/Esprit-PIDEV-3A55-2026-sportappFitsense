{% extends 'coach/base_coach.html.twig' %}

{% block title %}Quiz Management - FitSense Coach{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .quiz-card {
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.05);
            transition: all 0.3s ease;
        }
        .quiz-card:hover {
            transform: translateY(-2px);
            background: rgba(255, 255, 255, 0.05);
            border-color: rgba(34, 197, 94, 0.3);
        }
        .option-item {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(255, 255, 255, 0.1);
        }
        .modal {
            transition: opacity 0.3s ease;
            background: rgba(0, 0, 0, 0.8);
            backdrop-filter: blur(4px);
        }
    </style>
{% endblock %}

{% block coach_content %}
<div class="space-y-8">
    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="p-4 rounded-xl {% if label == 'success' %}bg-green-500/10 border border-green-500/20 text-green-400{% else %}bg-red-500/10 border border-red-500/20 text-red-400{% endif %} flex items-center gap-3 animate-in fade-in slide-in-from-top-4 duration-300">
                <i class="fas {% if label == 'success' %}fa-check-circle{% else %}fa-exclamation-circle{% endif %}"></i>
                <span class="text-sm font-medium">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Header Section -->
    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
        <div>
            <h1 class="text-4xl font-black text-white tracking-tight">Feedback Management</h1>
            <p class="text-gray-400 mt-1">Create and manage feedback questionnaires for your athletes.</p>
        </div>
        <button onclick="openModal('create')" class="px-6 py-3 bg-gradient-to-r from-[#38BDF8] to-[#A78BFA] text-white font-bold rounded-xl shadow-lg hover:shadow-[#38BDF8]/20 transition-all flex items-center gap-2">
            <i class="fas fa-plus"></i> Add Feedback
        </button>
    </div>

    <!-- Search Bar -->
    <div class="relative max-w-md">
        <form method="get" action="{{ path('coach_questionnaire_index') }}">
            <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-500"></i>
            <input type="text" name="search" value="{{ search }}" placeholder="Search by title..." 
                   class="w-full pl-12 pr-4 py-3 bg-white/5 border border-white/10 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-[#38BDF8]/50 transition-all">
        </form>
    </div>

    <!-- Quiz Table -->
    <div class="bg-white/5 rounded-2xl border border-white/10 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white/5 text-gray-400 text-xs font-bold uppercase tracking-wider">
                        <th class="px-6 py-4">Title</th>
                        <th class="px-6 py-4">Linked Workouts</th>
                        <th class="px-6 py-4 text-center">Options</th>
                        <th class="px-6 py-4 text-right pr-10">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    {% for quiz in quizzes %}
                        <tr class="group hover:bg-white/[0.02] transition-colors">
                            <td class="px-6 py-4">
                                <span class="text-white font-semibold">{{ quiz.titre }}</span>
                            </td>
                            <td class="px-6 py-4">
                                {% if quiz.workouts|length > 0 %}
                                    <div class="flex flex-wrap gap-1">
                                        {% for workout in quiz.workouts %}
                                            <span class="px-2 py-0.5 bg-[#38BDF8]/10 border border-[#38BDF8]/20 text-[#38BDF8] text-xs rounded-full flex items-center gap-1">
                                                <i class="fas fa-dumbbell text-[10px] opacity-50"></i>
                                                {{ workout.nom }}
                                            </span>
                                        {% endfor %}
                                    </div>
                                {% else %}
                                    <span class="text-gray-500 text-sm">No workout linked</span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4 text-center">
                                <span class="px-3 py-1 bg-white/5 rounded-full text-xs text-gray-300">{{ quiz.options|length }} options</span>
                            </td>
                            <td class="px-6 py-4 text-right pr-6">
                                <div class="flex items-center justify-end gap-2">
                                    {% set workoutIds = [] %}
                                    {% for w in quiz.workouts %}{% set workoutIds = workoutIds|merge([w.id]) %}{% endfor %}
                                    <button onclick="openEditModal(this)"
                                            data-id="{{ quiz.id }}"
                                            data-titre="{{ quiz.titre|e('html_attr') }}"
                                            data-workout-ids="{{ workoutIds|json_encode|e('html_attr') }}"
                                            data-options="{{ quiz.options|json_encode|e('html_attr') }}"
                                            class="p-2 text-gray-400 hover:text-blue-400 transition-colors">
                                        <i class="fas fa-edit"></i>
                                    </button>
                                    <button onclick="openDeleteModal({{ quiz.id }})"
                                            class="p-2 text-gray-400 hover:text-red-400 transition-colors">
                                        <i class="fas fa-trash"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center gap-4">
                                    <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center">
                                        <i class="fas fa-clipboard-list text-2xl text-gray-600"></i>
                                    </div>
                                    <p class="text-gray-500 italic">No Feedbacks found. Start by creating one!</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>

<!-- User Feedback Responses Section - New Feedback System -->
    <div class="mt-12">
        <div class="flex items-center justify-between gap-3 mb-6">
            <div class="flex items-center gap-3">
                <h2 class="text-2xl font-black text-white tracking-tight">Recent Feedback</h2>
                <span class="px-3 py-1 bg-green-500/20 border border-green-500/30 text-green-400 text-xs font-bold rounded-full">
                    {{ (userResponses|length + feedbackResponses|length) }} {{ (userResponses|length + feedbackResponses|length) == 1 ? 'response' : 'responses' }}
                </span>
            </div>
            <a href="{{ path('coach_send_daily_report') }}" class="px-5 py-2.5 bg-gradient-to-r from-[#667eea] to-[#764ba2] text-white font-bold rounded-xl shadow-lg hover:shadow-[#667eea]/30 transition-all flex items-center gap-2 text-sm">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                    <path d="M.05 3.555A2 2 0 0 1 2 2h12a2 2 0 0 1 1.95 1.555L8 8.414.05 3.555ZM0 4.697v7.104l5.803-3.558L0 4.697ZM6.761 8.83l-6.57 4.027A2 2 0 0 0 2 14h12a2 2 0 0 0 1.808-1.144l-6.57-4.027L8 9.586l-1.239-.757Zm3.436-.586L16 11.801V4.697l-5.803 3.546Z"/>
                </svg>
                Send Daily Report
            </a>
        </div>
        
        {% set allResponses = [] %}
        
        {# Combine old-style responses #}
        {% for response in userResponses %}
            {% set allResponses = allResponses|merge([{
                'id': response.id,
                'source': 'questionnaire',
                'type': 'questionnaire',
                'title': response.titre,
                'userName': response.userName,
                'rating': response.options[0] ?? 'N/A',
                'comment': response.commentaire,
                'workout': response.workouts|length > 0 ? response.workouts[0].nom : 'N/A',
                'date': response.dateSoumission
            }]) %}
        {% endfor %}
        
        {# Add new FeedbackResponse entities #}
        {% for feedback in feedbackResponses %}
            {% set allResponses = allResponses|merge([{
                'id': feedback.id,
                'source': 'feedback',
                'type': 'feedback',
                'title': 'Workout Feedback',
                'userName': feedback.userName,
                'rating': feedback.rating,
                'comment': feedback.comment,
                'workout': feedback.workout.nom,
                'date': feedback.createdAt
            }]) %}
        {% endfor %}
        
        {# Sort by date descending #}
        {% set allResponses = allResponses|sort((a, b) => b.date <=> a.date) %}
        
        {% if allResponses|length > 0 %}
            <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for response in allResponses %}
                    <div class="glass-card p-5 border-l-4 
                        {% if response.rating == 'Excellent' or response.rating == 'Good' %}border-green-500
                        {% elseif response.rating == 'Average' %}border-yellow-500
                        {% else %}border-red-500{% endif %}">
                        <div class="flex items-start justify-between mb-3">
                            <div>
                                <h4 class="text-white font-bold text-sm">{{ response.title }}</h4>
                                <p class="text-gray-500 text-xs mt-1">
                                    <i class="fas fa-user mr-1"></i>{{ response.userName }}
                                </p>
                            </div>
                            <div class="flex items-center gap-2">
                                <span class="px-2 py-1 rounded-lg text-xs font-bold
                                    {% if response.rating == 'Excellent' %}bg-green-500/20 text-green-400
                                    {% elseif response.rating == 'Good' %}bg-blue-500/20 text-blue-400
                                    {% elseif response.rating == 'Average' %}bg-yellow-500/20 text-yellow-400
                                    {% else %}bg-red-500/20 text-red-400{% endif %}">
                                    {{ response.rating }}
                                </span>
                                <button type="button"
                                        class="text-gray-500 hover:text-red-400 transition-colors text-xs"
                                        onclick="deleteResponse({{ response.id }}, '{{ response.source }}')">
                                    <i class="fas fa-trash"></i>
                                </button>
                            </div>
                        </div>
                        
                        <div class="flex flex-wrap gap-1 mb-3">
                            <span class="px-2 py-0.5 bg-[#38BDF8]/10 border border-[#38BDF8]/20 text-[#38BDF8] text-xs rounded-full">
                                <i class="fas fa-dumbbell mr-1"></i>{{ response.workout }}
                            </span>
                        </div>
                        
                        {% if response.comment %}
                            <p class="text-gray-400 text-xs italic mb-3">
                                <i class="fas fa-quote-left mr-1"></i>{{ response.comment }}
                            </p>
                        {% endif %}
                        
                        <p class="text-gray-600 text-xs">
                            <i class="fas fa-clock mr-1"></i>
                            {{ response.date ? response.date|date('M d, Y H:i') : 'N/A' }}
                        </p>
                    </div>
                {% endfor %}
            </div>
        {% else %}
            <div class="glass-card p-12 text-center">
                <div class="w-16 h-16 bg-white/5 rounded-full flex items-center justify-center mx-auto mb-4">
                    <i class="fas fa-comments text-2xl text-gray-600"></i>
                </div>
                <p class="text-gray-500 italic">No user feedback responses yet.</p>
                <p class="text-gray-600 text-sm mt-2">User responses will appear here after they complete workouts.</p>
            </div>
        {% endif %}
    </div>
</div>

<!-- Modal Create/Edit -->
<div id="quizModal" class="modal">
    <div class="bg-[#1B1E26] border border-[#343846] rounded-[1.5rem] w-full max-w-lg max-h-[90vh] shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300 flex flex-col">
        <div class="px-8 py-5 border-b border-[#343846] flex justify-between items-center bg-white/5 flex-shrink-0">
            <h2 id="modalTitle" class="text-xl font-bold text-white">Add Feedback</h2>
            <button onclick="closeModal()" class="text-gray-400 hover:text-white transition-colors">
                <i class="fas fa-times"></i>
            </button>
        </div>
        
        <form id="quizForm" method="POST" action="" class="p-8 space-y-6 overflow-y-auto custom-scrollbar flex-1">
            <div class="space-y-4">
                <div class="space-y-2">
                    <label class="text-sm font-semibold text-gray-400">Feedback Title</label>
                    <input type="text" name="titre" id="quizTitre" placeholder="e.g. Session Evaluation"
                           class="w-full bg-[#262A35] border border-[#343846] rounded-xl px-4 py-3 text-white focus:outline-none focus:border-[#38BDF8] transition-all">
                    <span id="error-titre" class="text-red-400 text-xs mt-1 block h-4"></span>
                </div>

                <div class="space-y-2">
                    <label class="text-sm font-semibold text-gray-400">Linked Workouts (Select at least one)</label>
                    <div class="w-full bg-[#262A35] border border-[#343846] rounded-xl px-4 py-3 max-h-48 overflow-y-auto custom-scrollbar space-y-2">
                        {% for workout in workouts %}
                            <label class="flex items-center gap-3 group cursor-pointer">
                                <div class="relative flex items-center">
                                    <input type="checkbox" name="workout_ids[]" value="{{ workout.id }}" class="workout-checkbox peer appearance-none w-5 h-5 border-2 border-[#343846] rounded-md checked:bg-[#38BDF8] checked:border-[#38BDF8] transition-all cursor-pointer">
                                    <i class="fas fa-check absolute scale-0 peer-checked:scale-100 left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 text-white text-[10px] pointer-events-none transition-transform"></i>
                                </div>
                                <span class="text-sm text-gray-300 group-hover:text-white transition-colors">{{ workout.nom }}</span>
                            </label>
                        {% endfor %}
                    </div>
                    <span id="error-workouts" class="text-red-400 text-xs mt-1 block h-4"></span>
                </div>
            </div>

            <div class="space-y-4">
                <div class="flex justify-between items-center">
                    <label class="text-sm font-semibold text-gray-400">Response Options</label>
                    <button type="button" onclick="addOption()" class="text-xs font-bold text-[#38BDF8] hover:text-[#38BDF8]/80 transition-colors">
                        <i class="fas fa-plus mr-1"></i> Add Option
                    </button>
                </div>
                <div id="optionsContainer" class="space-y-2 max-h-32 overflow-y-auto pr-2 custom-scrollbar">
                    <!-- Dynamic Options -->
                </div>
                <span id="error-options" class="text-red-400 text-xs mt-1 block h-4"></span>
            </div>

            <div class="flex gap-3 pt-6 border-t border-[#343846] mt-6">
                <button type="button" onclick="closeModal()" class="flex-1 px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold">
                    Cancel
                </button>
                <button type="submit" id="submitBtn" class="flex-1 px-6 py-3 bg-gradient-to-r from-[#38BDF8] to-[#A78BFA] text-white rounded-xl hover:shadow-lg hover:shadow-[#38BDF8]/30 transition font-semibold group flex items-center justify-center gap-2">
                    <span class="submit-text">Save Changes</span>
                    <i class="fas fa-circle-notch fa-spin hidden"></i>
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteModal" class="modal">
    <div class="bg-[#1B1E26] border border-[#343846] rounded-[1.5rem] w-full max-w-md shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300">
        <div class="p-8 text-center space-y-6">
            <div class="bg-red-500/20 rounded-full w-20 h-20 flex items-center justify-center mx-auto">
                <i class="fas fa-exclamation-triangle text-red-400 text-3xl"></i>
            </div>
            
            <div class="space-y-2">
                <h3 class="text-2xl font-bold text-white">Delete Feedback?</h3>
                <p class="text-gray-400">This action is irreversible. Do you really want to delete this questionnaire?</p>
            </div>
            
            <form id="deleteForm" method="POST" action="" class="flex gap-3">
                <button type="button" onclick="closeDeleteModal()" class="flex-1 px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold">
                    Cancel
                </button>
                <button type="submit" class="flex-1 px-6 py-3 bg-red-500 text-white rounded-xl hover:bg-red-600 transition font-semibold shadow-lg shadow-red-500/20">
                    Delete
                </button>
            </form>
        </div>
    </div>
</div>

<script>
    const modal = document.getElementById('quizModal');
    const deleteModal = document.getElementById('deleteModal');
    const form = document.getElementById('quizForm');
    const deleteForm = document.getElementById('deleteForm');
    const optionsContainer = document.getElementById('optionsContainer');
    const modalTitle = document.getElementById('modalTitle');
    const quizTitre = document.getElementById('quizTitre');
    const submitBtn = document.getElementById('submitBtn');

    function openModal(mode) {
        modal.classList.add('active');
        optionsContainer.innerHTML = '';
        clearErrors();
        form.reset();
        
        setTimeout(() => {
            modal.querySelector('.transform').classList.remove('scale-95');
            modal.querySelector('.transform').classList.add('scale-100');
        }, 10);

        if (mode === 'create') {
            modalTitle.textContent = 'Add New Feedback';
            form.action = "{{ path('coach_questionnaire_create') }}";
            
            document.querySelectorAll('.workout-checkbox').forEach(cb => cb.checked = false);
            ['1 Very poor', '2 Poor', '3 Average', '4 Good', '5 Excellent'].forEach(opt => addOption(opt));
        }
    }

    function openEditModal(btn) {
        modal.classList.add('active');
        optionsContainer.innerHTML = '';
        clearErrors();
        form.reset();

        const id = btn.getAttribute('data-id');
        const titre = btn.getAttribute('data-titre');
        const workoutIds = JSON.parse(btn.getAttribute('data-workout-ids') || '[]');
        const options = JSON.parse(btn.getAttribute('data-options') || '[]');

        setTimeout(() => {
            modal.querySelector('.transform').classList.remove('scale-95');
            modal.querySelector('.transform').classList.add('scale-100');
        }, 10);

        modalTitle.textContent = 'Edit Feedback';
        form.action = `/coach/questionnaire/${id}/edit`;
        quizTitre.value = titre;
        
        const checkboxes = document.querySelectorAll('.workout-checkbox');
        checkboxes.forEach(cb => {
            cb.checked = workoutIds.includes(parseInt(cb.value));
        });

        if (options && options.length > 0) {
            options.forEach(opt => addOption(opt));
        } else {
            addOption();
        }
    }

    function closeModal() {
        modal.querySelector('.transform').classList.remove('scale-100');
        modal.querySelector('.transform').classList.add('scale-95');
        modal.classList.remove('active');
    }

    function openDeleteModal(id) {
        deleteModal.classList.add('active');
        deleteForm.action = `/coach/questionnaire/${id}/delete`;
        
        setTimeout(() => {
            deleteModal.querySelector('.transform').classList.remove('scale-95');
            deleteModal.querySelector('.transform').classList.add('scale-100');
        }, 10);
    }

    function closeDeleteModal() {
        deleteModal.querySelector('.transform').classList.remove('scale-100');
        deleteModal.querySelector('.transform').classList.add('scale-95');
        deleteModal.classList.remove('active');
    }

    function addOption(val = '') {
        const div = document.createElement('div');
        div.className = 'flex items-center gap-2 group';
        div.innerHTML = `
            <input type="text" name="options[]" placeholder="Option text..."
                   class="flex-1 bg-[#262A35]/50 border border-[#343846] rounded-lg px-4 py-2 text-sm text-white focus:outline-none focus:border-[#38BDF8]/50 transition-all">
            <button type="button" onclick="this.parentElement.remove()" class="p-2 text-gray-500 hover:text-red-500 transition-colors">
                <i class="fas fa-times"></i>
            </button>
        `;
        div.querySelector('input').value = val;
        optionsContainer.appendChild(div);
    }

    function clearErrors() {
        document.querySelectorAll('[id^="error-"]').forEach(el => el.textContent = '');
    }

    form.addEventListener('submit', async (e) => {
        e.preventDefault();
        clearErrors();
        
        const formData = new FormData(form);
        const submitText = submitBtn.querySelector('.submit-text');
        const spinner = submitBtn.querySelector('.fa-circle-notch');

        submitBtn.disabled = true;
        submitText.classList.add('opacity-0');
        spinner.classList.remove('hidden');

        try {
            const response = await fetch(form.action, {
                method: 'POST',
                body: formData
            });

            const result = await response.json();

            if (result.success) {
                window.location.reload();
            } else {
                if (result.errors) {
                    Object.keys(result.errors).forEach(key => {
                        const errorEl = document.getElementById(`error-${key}`);
                        if (errorEl) errorEl.textContent = result.errors[key];
                    });
                } else if (result.message) {
                    alert(result.message);
                }
            }
        } catch (error) {
            console.error('Error:', error);
            alert('An unexpected error occurred. Please try again.');
        } finally {
            submitBtn.disabled = false;
            submitText.classList.remove('opacity-0');
            spinner.classList.add('hidden');
        }
    });

    // Close on escape
    window.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') {
            closeModal();
            closeDeleteModal();
        }
    });

    // Close on click outside
    [modal, deleteModal].forEach(m => {
        m.addEventListener('click', (e) => {
            if (e.target === m) {
                if (m === modal) closeModal();
                else closeDeleteModal();
            }
        });
    });

    async function deleteFeedback(id) {
        if (!confirm('Are you sure you want to delete this feedback?')) {
            return;
        }
        try {
            const response = await fetch(`/coach/questionnaire/feedback/${id}/delete`, {
                method: 'POST'
            });
            if (response.ok) {
                window.location.reload();
            } else {
                alert('Error deleting feedback.');
            }
        } catch (e) {
            console.error(e);
            alert('An unexpected error occurred while deleting feedback.');
        }
    }

    async function deleteResponse(id, source) {
        if (!confirm('Are you sure you want to delete this response?')) {
            return;
        }
        try {
            let url;
            if (source === 'feedback') {
                url = `/coach/questionnaire/feedback/${id}/delete`;
            } else {
                url = `/coach/questionnaire/response/${id}/delete`;
            }
            
            const response = await fetch(url, {
                method: 'POST'
            });
            if (response.ok) {
                window.location.reload();
            } else {
                alert('Error deleting response.');
            }
        } catch (e) {
            console.error(e);
            alert('An unexpected error occurred while deleting response.');
        }
    }
</script>
{% endblock %}
