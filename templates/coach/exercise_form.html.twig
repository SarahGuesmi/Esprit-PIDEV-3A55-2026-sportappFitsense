{% extends 'coach/base_coach.html.twig' %}

{% block title %}
    {{ isEdit ? 'Edit Exercise' : 'Create Exercise' }} - FitSense
{% endblock %}

{% block coach_page_title %}{{ isEdit ? 'Edit Exercise' : 'Create Exercise' }}{% endblock %}
{% block coach_page_subtitle %}{{ isEdit ? 'Modify exercise details' : 'Add a new exercise to your library' }}{% endblock %}

{% block stylesheets %}
{{ parent() }}
<link href="https://cdn.quilljs.com/1.3.7/quill.snow.css" rel="stylesheet">
<style>
.gradient-btn {
    background: linear-gradient(135deg, #22C55E, #84CC16);
}
.form-input,
.form-select,
.form-textarea {
    width: 100%;
    padding: 1rem 1.25rem;
    background: #0D0D0D;
    border: 1px solid #1F1F1F;
    border-radius: 12px;
    color: #fff;
    transition: border-color .2s, box-shadow .2s;
}
.form-input:focus,
.form-select:focus,
.form-textarea:focus {
    outline: none;
    border-color: #22C55E;
    box-shadow: 0 0 0 3px rgba(34,197,94,0.15);
}
.form-label {
    font-weight: 600;
    font-size: 0.875rem;
    color: #D1D5DB;
    margin-bottom: .5rem;
    display: block;
    text-transform: uppercase;
    letter-spacing: .05em;
}
.form-group { margin-bottom: 1.5rem; }
.form-error {
    color: #EF4444;
    font-size: 0.8rem;
    margin-top: 0.5rem;
}
.error { border-color: #EF4444 !important; }

/* ── Quill dark mode ── */
.ql-toolbar {
    background: #1a1a1a !important;
    border: 1px solid #1F1F1F !important;
    border-bottom: none !important;
    border-radius: 12px 12px 0 0 !important;
}
.ql-container {
    background: #0D0D0D !important;
    border: 1px solid #1F1F1F !important;
    border-top: none !important;
    border-radius: 0 0 12px 12px !important;
    color: #fff !important;
    font-size: 0.95rem !important;
    min-height: 180px !important;
}
.ql-editor { min-height: 180px; color: #e5e7eb; }
.ql-toolbar .ql-stroke { stroke: #9ca3af !important; }
.ql-toolbar .ql-fill   { fill:   #9ca3af !important; }
.ql-toolbar .ql-picker  { color: #9ca3af !important; }
.ql-toolbar button:hover .ql-stroke,
.ql-toolbar .ql-active  .ql-stroke { stroke: #22C55E !important; }
.ql-toolbar button:hover .ql-fill,
.ql-toolbar .ql-active  .ql-fill   { fill:   #22C55E !important; }
.ql-toolbar .ql-picker-options { background: #1a1a1a !important; border-color: #374151 !important; }

/* ── YouTube widget ── */
.yt-search-input {
    width: 100%;
    padding: .85rem 1.25rem .85rem 3rem;
    background: #0D0D0D;
    border: 1px solid #1F1F1F;
    border-radius: 12px;
    color: #fff;
    font-size: .95rem;
    transition: border-color .2s, box-shadow .2s;
}
.yt-search-input::placeholder { color: #4b5563; }
.yt-search-input:focus {
    outline: none;
    border-color: #ff4444;
    box-shadow: 0 0 0 3px rgba(255,68,68,0.15);
}
.yt-results-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 12px;
    margin-top: 14px;
}
.yt-card {
    background: #111;
    border: 2px solid transparent;
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    transition: border-color .2s, transform .2s, box-shadow .2s;
}
.yt-card:hover {
    border-color: rgba(255,68,68,0.5);
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(255,68,68,0.15);
}
.yt-card.selected {
    border-color: #ff4444;
    box-shadow: 0 0 0 3px rgba(255,68,68,0.25);
}
.yt-card img {
    width: 100%;
    height: 110px;
    object-fit: cover;
    display: block;
}
.yt-card-info {
    padding: 8px 10px;
}
.yt-card-title {
    font-size: .75rem;
    font-weight: 600;
    color: #e5e7eb;
    line-height: 1.3;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
}
.yt-card-channel {
    font-size: .68rem;
    color: #6b7280;
    margin-top: 3px;
    display: flex;
    align-items: center;
    gap: 4px;
}
.yt-selected-preview {
    margin-top: 14px;
    background: rgba(255,68,68,0.08);
    border: 1px solid rgba(255,68,68,0.3);
    border-radius: 12px;
    padding: 12px 16px;
    display: flex;
    align-items: center;
    gap: 12px;
}
.yt-selected-preview img {
    width: 100px;
    height: 60px;
    object-fit: cover;
    border-radius: 8px;
    flex-shrink: 0;
}
.yt-loader {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #6b7280;
    font-size: .85rem;
    margin-top: 10px;
}
.yt-spinner {
    width: 16px;
    height: 16px;
    border: 2px solid #374151;
    border-top-color: #ff4444;
    border-radius: 50%;
    animation: spin .7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.yt-clear-btn {
    background: rgba(239,68,68,0.1);
    border: 1px solid rgba(239,68,68,0.3);
    border-radius: 8px;
    color: #f87171;
    font-size: .75rem;
    font-weight: 700;
    padding: 4px 10px;
    cursor: pointer;
    transition: background .2s;
    margin-left: auto;
    flex-shrink: 0;
}
.yt-clear-btn:hover { background: rgba(239,68,68,0.2); }
</style>
{% endblock %}

{% block coach_content %}
<div class="max-w-4xl mx-auto py-8">

    <!-- Back Button -->
    <div class="mb-8">
        <a href="{{ path('coach_exercise_list') }}"
           class="inline-flex items-center text-gray-400 hover:text-white transition group font-semibold">
            <i class="fas fa-arrow-left mr-2 transform group-hover:-translate-x-1 transition-transform"></i>
            Back to Exercise List
        </a>
    </div>

    <!-- GLOBAL ALERT -->
    <div id="formAlert" class="hidden mb-6 bg-red-500/10 border border-red-500/30 text-red-400 rounded-xl px-6 py-4 flex items-center gap-4">
        <i class="fas fa-exclamation-triangle text-xl"></i>
        <div>
            <strong class="block mb-1">Missing required fields</strong>
            Please fill in all required fields before submitting the form.
        </div>
    </div>

    <div class="bg-gray-900/40 border border-gray-800 rounded-2xl p-8 md:p-12 shadow-2xl">
        {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'exerciseForm', 'enctype': 'multipart/form-data'}}) }}

        <!-- Name -->
        <div class="form-group">
            <label class="form-label">Exercise Name *</label>
            {{ form_widget(form.nom, {'attr': {'class': 'form-input required', 'placeholder': 'e.g. Push Ups'}}) }}
            {% if form.nom.vars.errors|length %}
                <div class="form-error flex items-center gap-2">
                    <i class="fas fa-exclamation-circle"></i>
                    {{ form.nom.vars.errors[0].message }}
                </div>
            {% endif %}
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <!-- Type -->
            <div class="form-group">
                <label class="form-label">Exercise Type *</label>
                {{ form_widget(form.type, {'attr': {'class': 'form-select required'}}) }}
                {% if form.type.vars.errors|length %}
                    <div class="form-error flex items-center gap-2">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form.type.vars.errors[0].message }}
                    </div>
                {% endif %}
            </div>

            <!-- Duration -->
            <div class="form-group">
                <label class="form-label">Duration (seconds) *</label>
                {{ form_widget(form.duree, {'attr': {'class': 'form-input required', 'min': 1, 'max': 3600, 'placeholder': '60'}}) }}
                {% if form.duree.vars.errors|length %}
                    <div class="form-error flex items-center gap-2">
                        <i class="fas fa-exclamation-circle"></i>
                        {{ form.duree.vars.errors[0].message }}
                    </div>
                {% endif %}
            </div>
        </div>

        <!-- ✅ Description avec Quill Editor — UNE SEULE FOIS en HTML pur -->
        <div class="form-group">
            <label class="form-label">Description</label>

            {% do form.description.setRendered() %}


            {# ✅ HTML pur pour éviter "already rendered" et le problème de troncature #}
            <input type="hidden"
                   name="{{ form.description.vars.full_name }}"
                   data-role="description-hidden">

            {# ✅ Valeur existante passée via JSON pour éviter la troncature des guillemets #}
            <script>
                var EXISTING_DESCRIPTION = {{ form.description.vars.value|default('')|json_encode|raw }};
            </script>

            {# Éditeur Quill visible #}
            <div id="quillEditor"></div>
        </div>

        <!-- Image Upload -->
        <div class="form-group">
            <label class="form-label">Exercise Image</label>
            {% if form.vars.data.imageName %}
                <div class="mb-3">
                    <img src="/uploads/exercises/{{ form.vars.data.imageName }}"
                         alt="Current image"
                         class="w-32 h-32 object-cover rounded-xl border border-gray-700">
                    <p class="text-xs text-gray-500 mt-1">Current image</p>
                </div>
            {% endif %}
            {{ form_widget(form.imageFile, {'attr': {'class': 'block w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-lg file:border-0 file:bg-green-500/20 file:text-green-400 hover:file:bg-green-500/30 cursor-pointer'}}) }}
        </div>

        <!-- ══════════════════════════════════════
             YOUTUBE VIDEO PICKER
        ══════════════════════════════════════ -->
        <div class="form-group">
            <label class="form-label">
                <i class="fab fa-youtube mr-2" style="color:#ff4444;"></i>
                Tutorial Video YouTube
                <span class="text-gray-600 font-normal normal-case ml-1">(optional)</span>
            </label>

            {{ form_widget(form.youtubeVideoId, {'attr': {'data-role': 'yt-video-id'}}) }}

            {# Barre de recherche #}
            <div style="position:relative;">
                <i class="fab fa-youtube" style="color:#ff4444; position:absolute; left:16px; top:50%; transform:translateY(-50%); pointer-events:none;"></i>
                <input type="text"
                       id="ytSearchInput"
                       class="yt-search-input"
                       placeholder="Rechercher une vidéo… ex: Push Up technique"
                       autocomplete="off">
            </div>

            {# Loader #}
            <div id="ytLoader" class="yt-loader hidden">
                <div class="yt-spinner"></div>
                Recherche en cours…
            </div>

            {# Grille de résultats #}
            <div id="ytResults" class="yt-results-grid"></div>

            {# Vidéo sélectionnée — preview #}
            <div id="ytSelectedPreview" class="yt-selected-preview hidden">
                <img id="ytSelectedThumb" src="" alt="">
                <div class="flex-1 min-w-0">
                    <p id="ytSelectedTitle" class="text-sm font-bold text-white leading-snug"></p>
                    <p id="ytSelectedChannel" class="text-xs text-gray-500 mt-1 flex items-center gap-1">
                        <i class="fab fa-youtube" style="color:#ff4444;"></i>
                        <span></span>
                    </p>
                </div>
                <button type="button" class="yt-clear-btn" id="ytClearBtn">
                    <i class="fas fa-times mr-1"></i> Supprimer
                </button>
            </div>

            {# Si en mode edit et vidéo déjà sauvegardée #}
            {% if isEdit and form.vars.data.youtubeVideoId %}
                <div class="mt-3 rounded-xl overflow-hidden border border-red-500/20" style="position:relative;padding-bottom:40%;height:0;">
                    <iframe src="https://www.youtube.com/embed/{{ form.vars.data.youtubeVideoId }}?rel=0&modestbranding=1"
                            frameborder="0" allowfullscreen
                            style="position:absolute;top:0;left:0;width:100%;height:100%;border:none;">
                    </iframe>
                </div>
                <p class="text-xs text-gray-500 mt-2">
                    <i class="fas fa-info-circle mr-1 text-blue-400"></i>
                    Vidéo actuelle — recherchez ci-dessus pour la remplacer.
                </p>
            {% endif %}
        </div>

        <!-- Buttons -->
        <div class="flex flex-col sm:flex-row gap-4 mt-8 pt-8 border-t border-gray-800/50">
            <button type="submit" class="flex-1 gradient-btn text-black font-black py-4 rounded-xl shadow-lg hover:shadow-green-500/20 transition transform hover:scale-[1.01] active:scale-[0.99]">
                <i class="fas fa-{{ isEdit ? 'save' : 'plus-circle' }} mr-2"></i>
                {{ isEdit ? 'Save Changes' : 'Create Exercise' }}
            </button>
            <a href="{{ path('coach_exercise_list') }}"
               class="flex-1 text-center py-4 bg-gray-800 hover:bg-gray-700 text-gray-300 rounded-xl border border-gray-700 font-bold transition">
                Annuler
            </a>
        </div>

        {{ form_end(form) }}
    </div>
</div>
{% endblock %}

{% block scripts %}
{{ parent() }}
<script src="https://cdn.quilljs.com/1.3.7/quill.min.js"></script>
<script>
document.addEventListener('DOMContentLoaded', () => {

    // ── Quill Editor ──
    const descriptionHidden = document.querySelector('[data-role="description-hidden"]');

    const quill = new Quill('#quillEditor', {
        theme: 'snow',
        placeholder: 'Décrivez comment effectuer l\'exercice (étapes, conseils, positions...)...',
        modules: {
            toolbar: [
                [{ 'header': [1, 2, 3, false] }],
                ['bold', 'italic', 'underline'],
                [{ 'color': [] }, { 'background': [] }],
                [{ 'list': 'ordered'}, { 'list': 'bullet' }],
                [{ 'align': [] }],
                ['clean']
            ]
        }
    });

    // ✅ Charger le contenu existant via JSON (évite la troncature)
    if (typeof EXISTING_DESCRIPTION !== 'undefined' && EXISTING_DESCRIPTION) {
        quill.root.innerHTML = EXISTING_DESCRIPTION;
        if (descriptionHidden) descriptionHidden.value = EXISTING_DESCRIPTION;
    }

    // ── Validation formulaire ──
    const form      = document.getElementById('exerciseForm');
    const alertBox  = document.getElementById('formAlert');
    const reqFields = form.querySelectorAll('.required');

    form.addEventListener('submit', (e) => {
        // ✅ Copier le HTML de Quill dans le champ caché avant envoi
        if (descriptionHidden) {
            descriptionHidden.value = quill.root.innerHTML;
        }

        let hasError = false;
        alertBox.classList.add('hidden');
        reqFields.forEach(f => {
            f.classList.remove('error');
            if (!f.value || f.value.trim() === '') {
                f.classList.add('error');
                hasError = true;
            }
        });
        if (hasError) {
            e.preventDefault();
            alertBox.classList.remove('hidden');
            alertBox.scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
    });

    // ── YouTube Search Widget ──
    const searchInput    = document.getElementById('ytSearchInput');
    const resultsGrid    = document.getElementById('ytResults');
    const loader         = document.getElementById('ytLoader');
    const preview        = document.getElementById('ytSelectedPreview');
    const previewThumb   = document.getElementById('ytSelectedThumb');
    const previewTitle   = document.getElementById('ytSelectedTitle');
    const previewChannel = document.getElementById('ytSelectedChannel').querySelector('span');
    const clearBtn       = document.getElementById('ytClearBtn');

    const hiddenInput = document.querySelector('[data-role="yt-video-id"]')
                     || document.querySelector('input[name*="youtubeVideoId"]')
                     || document.querySelector('input[name*="youtube_video_id"]');

    console.log('🔍 hiddenInput trouvé :', hiddenInput);

    let searchTimeout = null;

    searchInput.addEventListener('input', () => {
        clearTimeout(searchTimeout);
        const q = searchInput.value.trim();

        if (q.length < 2) {
            resultsGrid.innerHTML = '';
            loader.classList.add('hidden');
            return;
        }

        loader.classList.remove('hidden');
        resultsGrid.innerHTML = '';

        searchTimeout = setTimeout(() => {
            fetch(`/coach/youtube-search?q=${encodeURIComponent(q)}`)
                .then(r => {
                    if (!r.ok) throw new Error(`Erreur HTTP ${r.status}`);
                    return r.json();
                })
                .then(videos => {
                    loader.classList.add('hidden');
                    renderResults(videos);
                })
                .catch(err => {
                    loader.classList.add('hidden');
                    console.error('Erreur YouTube :', err);
                    resultsGrid.innerHTML = `<p style="color:#ef4444;font-size:.85rem;">Erreur : ${err.message}</p>`;
                });
        }, 300);
    });

    function renderResults(videos) {
        resultsGrid.innerHTML = '';

        if (!videos.length) {
            resultsGrid.innerHTML = '<p style="color:#6b7280;font-size:.85rem;margin-top:8px;">Aucune vidéo trouvée.</p>';
            return;
        }

        videos.forEach(v => {
            const card = document.createElement('div');
            card.className = 'yt-card';

            card.innerHTML = `
                <img src="${v.thumbnail}" alt="${v.title}" loading="lazy">
                <div class="yt-card-info">
                    <div class="yt-card-title">${v.title}</div>
                    <div class="yt-card-channel">
                        <i class="fab fa-youtube" style="color:#ff4444;font-size:10px;"></i>
                        ${v.channelName}
                    </div>
                </div>
            `;

            card.addEventListener('click', () => selectVideo(v, card));
            resultsGrid.appendChild(card);
        });
    }

    function selectVideo(v, card) {
        resultsGrid.querySelectorAll('.yt-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');

        if (hiddenInput) hiddenInput.value = v.videoId;

        previewThumb.src           = v.thumbnail;
        previewTitle.textContent   = v.title;
        previewChannel.textContent = v.channelName;
        preview.classList.remove('hidden');
    }

    clearBtn.addEventListener('click', () => {
        if (hiddenInput) hiddenInput.value = '';
        preview.classList.add('hidden');
        resultsGrid.querySelectorAll('.yt-card').forEach(c => c.classList.remove('selected'));
        searchInput.value = '';
        resultsGrid.innerHTML = '';
    });

});
</script>
{% endblock %}