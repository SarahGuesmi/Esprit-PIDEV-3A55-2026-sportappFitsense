{% for workout in workouts %}
    <div class="bg-gray-800 rounded-xl p-5 border border-gray-700 mb-3 hover:border-blue-500 transition">
        <div class="flex justify-between items-start">
            <div>
                <h3 class="font-bold text-white text-lg">{{ workout.nom }}</h3>
                <div class="flex gap-3 mt-1 text-sm text-gray-400">
                    <span>⏱ {{ workout.duree }} min</span>
                    <span>📊 {{ workout.niveau }}</span>
                    <span>💪 {{ workout.exercises|length }} exercices</span>
                </div>
            </div>
            <a href="{{ path('user_workout_view', {id: workout.id}) }}"
               class="bg-blue-600 hover:bg-blue-700 text-white px-4 py-2 rounded-lg text-sm font-semibold transition">
                Voir →
            </a>
        </div>
    </div>
{% else %}
    <div class="text-center py-12 text-gray-500">
        <p class="text-4xl mb-3">🏋️</p>
        <p>Aucun workout trouvé pour ces filtres.</p>
    </div>
{% endfor %}