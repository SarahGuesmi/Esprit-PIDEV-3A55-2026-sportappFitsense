{% extends base_template is defined and base_template ? base_template : 'base_user.html.twig' %}

{% block title %}Enable Two-Factor Authentication | FitSense{% endblock %}

{% block user_content %}
    {{ block('security_enable_content') }}
{% endblock %}

{% block coach_content %}
    {{ block('security_enable_content') }}
{% endblock %}

{% block admin_content %}
    {{ block('security_enable_content') }}
{% endblock %}

{% block security_enable_content %}
<div class="max-w-lg mx-auto px-4 py-12">
    <div class="text-center mb-10">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-3xl bg-violet-600/10 mb-6 text-violet-500 shadow-inner">
            <i class="fas fa-qrcode text-2xl"></i>
        </div>
        <h1 class="text-3xl font-black text-white tracking-tight mb-3">Enable 2FA</h1>
        <p class="text-gray-400 text-sm leading-relaxed px-4">Secure your account by linking it to an authenticator app like Google Authenticator or Authy.</p>
    </div>

    {% for message in app.flashes('error') %}
        <div class="mb-6 p-4 rounded-2xl bg-red-500/10 text-red-400 border border-red-500/20 flex items-center gap-3 animate-shake">
            <i class="fas fa-exclamation-circle"></i>
            <span class="text-sm font-medium">{{ message }}</span>
        </div>
    {% endfor %}

    <div class="glass-card p-10 mb-8 border border-white/5 relative group transition-all">
        <div class="flex flex-col items-center">
            <div class="relative mb-8 p-3 bg-white rounded-[2rem] shadow-2xl group-hover:scale-105 transition-transform duration-500">
                <img src="{{ qr_code_data_uri }}" alt="QR Code" class="w-48 h-48 block">
                <div class="absolute inset-0 border-4 border-violet-500/20 rounded-[2rem] pointer-events-none"></div>
            </div>
            
            <div class="w-full space-y-4">
                <p class="text-gray-500 text-[10px] font-black uppercase tracking-[0.2em] text-center">Manual Secret Key</p>
                <div class="flex items-center gap-2 p-4 rounded-2xl bg-black/20 border border-white/5 font-mono text-xs text-violet-300 break-all select-all justify-center cursor-help" title="Click to select all">
                    {{ secret|split('')|batch(4)|map(chunk => chunk|join(''))|join(' ') }}
                </div>
            </div>
        </div>
    </div>

    <form method="post" action="{{ path('security_2fa_enable') }}" class="glass-card p-8 mb-6 border border-white/5">
        <div class="mb-6">
            <label class="block text-[10px] font-black text-gray-500 uppercase tracking-[0.2em] mb-3 text-center">6-Digit Verification Code</label>
            <input type="text" name="_code" inputmode="numeric" pattern="[0-9]*" maxlength="6" placeholder="000 000"
                   class="w-full rounded-2xl bg-black/20 border border-white/10 px-4 py-5 text-3xl font-black tracking-[0.5em] text-center text-white placeholder-gray-700 focus:border-violet-500/50 focus:ring-4 focus:ring-violet-500/10 transition-all outline-none"
                   autocomplete="one-time-code" required autofocus>
        </div>
        
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa_enable') }}">
        
        <button type="submit" class="w-full py-4 rounded-2xl bg-gradient-to-r from-violet-600 to-cyan-600 text-white font-black uppercase tracking-widest text-[11px] hover:shadow-xl hover:shadow-violet-600/30 hover:scale-[1.02] active:scale-[0.98] transition-all">
            Secure My Account
        </button>
    </form>

    <form method="post" action="{{ path('security_2fa_cancel_setup') }}" class="text-center">
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('2fa_cancel') }}">
        <button type="submit" class="text-gray-500 hover:text-white text-[11px] font-bold uppercase tracking-widest transition-colors">
            <i class="fas fa-times mr-1"></i> Cancel Setup
        </button>
    </form>
</div>

<style>
@keyframes shake {
    0%, 100% { transform: translateX(0); }
    10%, 30%, 50%, 70%, 90% { transform: translateX(-2px); }
    20%, 40%, 60%, 80% { transform: translateX(2px); }
}
.animate-shake { animation: shake 0.5s cubic-bezier(.36,.07,.19,.97) both; }
</style>
{% endblock %}
