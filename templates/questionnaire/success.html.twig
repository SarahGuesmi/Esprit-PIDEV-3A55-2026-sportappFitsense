{% extends 'base.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/css/questionnaire.css') }}">
    <style>
/* ================================= */
/* QUESTIONNAIRE SUCCESS - DARK MODE */
/* ================================= */

.questionnaire-page {
    background:
        radial-gradient(circle at 20% 80%, rgba(120, 119, 198, 0.3) 0%, transparent 50%),
        radial-gradient(circle at 80% 20%, rgba(255, 119, 198, 0.3) 0%, transparent 50%),
        #0b0b0b;
    min-height: 100vh;
    position: relative;
    overflow: hidden;
}

/* ANIMATIONS PARTICULES */
.questionnaire-page::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-image:
        radial-gradient(2px 2px at 20px 30px, #10b981, transparent),
        radial-gradient(2px 2px at 40px 70px, rgba(16,185,129,0.6), transparent),
        radial-gradient(1px 1px at 90px 40px, rgba(16,185,129,0.8), transparent),
        radial-gradient(1px 1px at 130px 80px, #10b981, transparent);
    background-repeat: repeat;
    background-size: 200px 100px;
    animation: float 20s ease-in-out infinite;
    opacity: 0.1;
}

@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    33% { transform: translateY(-20px) rotate(120deg); }
    66% { transform: translateY(-10px) rotate(240deg); }
}

/* CARD */
.questionnaire-success-card {
    background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f0f23 100%);
    backdrop-filter: blur(20px);
    border: 1px solid rgba(16, 185, 129, 0.2);
    border-radius: 24px;
    box-shadow:
        0 25px 50px -12px rgba(0, 0, 0, 0.7),
        0 0 0 1px rgba(16, 185, 129, 0.1),
        inset 0 1px 0 rgba(255, 255, 255, 0.1);
    transform: translateY(0);
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    overflow: hidden;
    position: relative;
}

.questionnaire-success-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, #10b981, transparent, #10b981);
    animation: shimmer 3s infinite;
}

@keyframes shimmer {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
}

.questionnaire-success-card:hover {
    transform: translateY(-8px);
    box-shadow:
        0 35px 70px -12px rgba(0, 0, 0, 0.8),
        0 0 0 1px #10b981,
        inset 0 1px 0 rgba(255, 255, 255, 0.15);
}

/* ICON */
.success-icon {
    position: relative;
}

.success-icon i {
    filter: drop-shadow(0 0 20px #10b981);
    animation: pulse-glow 2s ease-in-out infinite;
}

@keyframes pulse-glow {
    0%, 100% {
        filter: drop-shadow(0 0 20px #10b981);
        transform: scale(1);
    }
    50% {
        filter: drop-shadow(0 0 40px #10b981);
        transform: scale(1.05);
    }
}

/* TYPO */
.card-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 800;
    background: linear-gradient(135deg, #10b981 0%, #34d399 50%, #059669 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1.5rem;
}

.card-text {
    color: #b3b3b3;
    font-size: 1.125rem;
    line-height: 1.6;
    max-width: 500px;
    margin: 0 auto 2rem;
}

/* BUTTON */
.btn-primary {
    background: linear-gradient(135deg, #10b981 0%, #34d399 50%, #059669 100%);
    border: none;
    font-weight: 700;
    font-size: 1.1rem;
    padding: 1rem 3rem;
    border-radius: 50px;
    position: relative;
    overflow: hidden;
    box-shadow: 0 10px 30px rgba(16, 185, 129, 0.4);
    transition: all 0.3s ease;
}

.btn-primary::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 100%;
    height: 100%;
    background: linear-gradient(90deg, transparent, rgba(255,255,255,0.3), transparent);
    transition: left 0.5s;
}

.btn-primary:hover::before {
    left: 100%;
}

.btn-primary:hover {
    transform: translateY(-3px);
    box-shadow: 0 20px 40px rgba(16, 185, 129, 0.5);
}

/* RESPONSIVE */
@media (max-width: 768px) {
    .questionnaire-success-card {
        margin: 1rem;
        border-radius: 20px;
    }

    .card-body {
        padding: 2rem 1.5rem !important;
    }
}

/* SCROLLBAR CUSTOM */
::-webkit-scrollbar {
    width: 8px;
}

::-webkit-scrollbar-track {
    background: #1e1e1e;
}

::-webkit-scrollbar-thumb {
    background: #10b981;
    border-radius: 4px;
}
    </style>
{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<div class="container-fluid py-5 questionnaire-page">
    <div class="container-xl">
        <div class="row justify-content-center">
            <div class="col-lg-8">
                <div class="card shadow-lg text-center questionnaire-success-card">
                    <div class="card-body p-5">
                        <div class="success-icon mb-4">
                            <i class="fas fa-check-circle text-success" style="font-size: 4rem;"></i>
                        </div>
                        <h1 class="card-title mb-4">Questionnaire soumis avec succès !</h1>
                        <p class="card-text fs-5 mb-4">
                            Votre questionnaire a été soumis avec succès. Merci pour votre retour !
                        </p>
                        <a href="{{ path('app_home') }}" class="btn btn-primary btn-lg px-5 rounded-pill shadow">
                            Retour à l'accueil
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}
