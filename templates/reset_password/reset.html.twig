{% extends 'base.html.twig' %}

{% block title %}Reset Your Password - FitSense{% endblock %}

{% block stylesheets %}
<style>
:root {
    --violet-primary: #8B5CF6;
    --violet-light: #A78BFA;
    --violet-dark: #6D28D9;
    --dark-bg: #030405;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --text-primary: #FFFFFF;
    --text-secondary: #94A3B8;
    --gradient-main: linear-gradient(135deg, #8B5CF6, #D8B4FE);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--dark-bg);
    color: var(--text-primary);
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
}

body::before {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(216, 180, 254, 0.1) 0%, transparent 40%);
    z-index: -1;
}

.auth-wrapper {
    width: 95%;
    max-width: 1000px;
    min-height: 600px;
    max-height: 95vh;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    background: var(--glass-bg);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    overflow: hidden;
    animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.auth-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center; 
    text-align: center;
    padding: 60px;
    position: relative;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(216, 180, 254, 0.05));
    border-right: 1px solid var(--glass-border);
}

.auth-left img.hero-img { 
    width: 250px; 
    margin-bottom: 35px; 
    filter: drop-shadow(0 20px 40px rgba(139, 92, 246, 0.3));
    animation: float 4s ease-in-out infinite; 
}

@keyframes float { 
    0%,100% { transform: translateY(0); } 
    50% { transform: translateY(-20px); } 
}

.auth-left h1 { 
    font-size: 38px; 
    font-weight: 900; 
    margin-bottom: 15px; 
    background: var(--gradient-main); 
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent; 
}

.auth-left p { 
    font-size: 16px; 
    color: var(--text-secondary); 
    line-height: 1.6;
    max-width:300px;
}

.auth-right { 
    padding: 60px; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    background: rgba(0,0,0,0.2);
    overflow-y: auto;
    max-height: 95vh;
}

.form-header h2 { 
    font-size: 36px; 
    font-weight: 800;
    margin-bottom: 8px; 
}

.form-header p { 
    color: var(--text-secondary); 
    margin-bottom: 40px; 
}

.form-group { margin-bottom: 25px; }

.form-group label {
    display: block;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    color: var(--violet-light);
}

.form-group input {
    width: 100%;
    padding: 16px 20px;
    border-radius: 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    font-size: 16px;
    transition: all 0.3s ease;
}

.form-group input:focus {
    outline: none;
    background: rgba(255,255,255,0.05);
    border-color: var(--violet-primary);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
}

.btn-signin {
    width: 100%;
    padding: 18px;
    border-radius: 14px;
    border: none;
    background: var(--gradient-main);
    color: white;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

.btn-signin:hover { 
    transform: translateY(-4px); 
    box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5); 
}

.back-home {
    position: absolute;
    top: 30px;
    left: 30px;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 14px;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 10px 18px;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    transition: all 0.3s ease;
    z-index: 10;
}

.back-home:hover { 
    background: rgba(255,255,255,0.1); 
    border-color: var(--violet-light);
}

.back-home svg { width: 18px; height: 18px; fill: var(--text-primary); }

.text-center a { color: var(--violet-light); text-decoration: none; font-weight: 800; transition: 0.3s; }
.text-center a:hover { color: #fff; text-shadow: 0 0 10px var(--violet-light); }

@media (max-width: 900px) {
    .auth-wrapper { grid-template-columns: 1fr; min-height: auto; height: auto; }
    .auth-left { display: none; }
    body { overflow: auto; height: auto; padding: 40px 0; }
}
</style>
{% endblock %}

{% block body %}
{% block header %}{% endblock %}
<div class="auth-wrapper">
    <!-- LEFT -->
    <div class="auth-left">
        <a href="{{ path('app_home') }}" class="back-home">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
            Home
        </a>
        <img src="{{ asset('assets/images/sport-hero.png') }}" class="hero-img" alt="Athlete">
        <h1>Push your limits</h1>
        <p>Feel the energy. Train smarter. Stay consistent.</p>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="form-header">
            <h2>Set New Password</h2>
            <p>Choose a strong new password for your account</p>
        </div>

        {{ form_start(changePasswordForm) }}
            <div class="form-group">
                <label>New Password</label>
                {{ form_widget(changePasswordForm.plainPassword.first, {attr: {placeholder: 'New password'}}) }}
                {{ form_errors(changePasswordForm.plainPassword.first) }}
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                {{ form_widget(changePasswordForm.plainPassword.second, {attr: {placeholder: 'Confirm new password'}}) }}
                {{ form_errors(changePasswordForm.plainPassword.second) }}
            </div>

            <button type="submit" class="btn-signin">Update Password</button>
        {{ form_end(changePasswordForm) }}

        <div class="text-center mt-6">
            <a href="{{ path('auth_sign_in') }}">Back to Sign In</a>
        </div>
    </div>
</div>
{% block footer%}{% endblock %}
{% endblock %}