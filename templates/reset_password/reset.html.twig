{% extends 'base.html.twig' %}

{% block title %}Reset Your Password - FitSense{% endblock %}

{% block stylesheets %}
<style>
/* Again — copy the full CSS block from sign-in or request page here */
:root {
    --blue-light: #38BDF8;
    --violet-light: #A78BFA;
    --dark-bg: #111318;
    --dark-card: #1B1E26;
    --dark-input: #262A35;
    --text-primary: #FFFFFF;
    --text-secondary: #A1A1AA;
    --border-color: #343846;
    --gradient-main: linear-gradient(135deg, #38BDF8, #A78BFA);
}
/* ... paste the entire CSS ... */
</style>
{% endblock %}

{% block body %}
{% block header %}{% endblock %}
<div class="auth-wrapper">
    <!-- LEFT -->
    <div class="auth-left">
        <a href="{{ path('app_home') }}" class="back-home">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
            Home
        </a>
        <img src="{{ asset('assets/images/sport-hero.png') }}" class="hero-img" alt="Athlete">
        <h1>Push your limits</h1>
        <p>Feel the energy. Train smarter. Stay consistent.</p>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="form-header">
            <h2>Set New Password</h2>
            <p>Choose a strong new password for your account</p>
        </div>

        {{ form_start(changePasswordForm) }}
    <div class="form-group">
        <label>New Password</label>
        {{ form_widget(changePasswordForm.plainPassword.first, {attr: {placeholder: 'New password'}}) }}
        {{ form_errors(changePasswordForm.plainPassword.first) }}
    </div>

    <div class="form-group">
        <label>Confirm Password</label>
        {{ form_widget(changePasswordForm.plainPassword.second, {attr: {placeholder: 'Confirm new password'}}) }}
        {{ form_errors(changePasswordForm.plainPassword.second) }}
    </div>

    <button type="submit" class="btn-signin">Update Password</button>
{{ form_end(changePasswordForm) }}

        <div class="text-center mt-6">
            <a href="{{ path('auth_sign_in') }}">Back to Sign In</a>
        </div>
    </div>
</div>
{% block footer%}{% endblock %}
{% endblock %}