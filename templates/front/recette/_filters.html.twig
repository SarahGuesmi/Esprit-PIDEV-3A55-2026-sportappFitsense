{# SEARCH & FILTERS (USER) #}
<form method="get" class="glass-card p-6 mb-8 border-none ring-1 ring-white/10" id="filtersForm">
  <div class="text-xl font-bold mb-6">🔎 Discover Recipes</div>

  <div class="flex flex-col md:flex-row gap-6 mb-6">
    <div class="flex-1">
      <label class="block text-gray-400 text-sm font-medium mb-2 uppercase tracking-wider">Search by name</label>
      <input type="text" name="q" value="{{ q|default('') }}" placeholder="Ex: Avocado Power Toast" 
             class="w-full bg-gray-900 border border-gray-700 rounded-xl px-4 py-3 text-white focus:border-blue-500 focus:ring-1 focus:ring-blue-500 outline-none transition">
    </div>

    <div class="flex items-end gap-3">
      <button class="px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-500 rounded-xl font-bold hover:shadow-lg hover:shadow-blue-500/30 transition transform hover:-translate-y-0.5" type="submit">
        Search
      </button>
      <a class="px-6 py-3 bg-gray-800 hover:bg-gray-700 rounded-xl font-bold transition" href="{{ path('user_nutrition') }}">
        Reset
      </a>
    </div>
  </div>

  <input type="hidden" name="kcal" id="kcalHidden" value="{{ kcal|default('') }}">
  <input type="hidden" name="proteins" id="protHidden" value="{{ proteins|default('') }}">

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div class="bg-gray-900/50 p-4 rounded-2xl border border-gray-800">
      <div class="flex justify-between items-center mb-3">
        <span class="text-gray-400 text-xs font-bold uppercase tracking-wider">Max Calories</span>
        <span class="text-xl font-bold text-blue-400">
          <span id="kcalVal">{{ kcal is not empty ? kcal : '—' }}</span> <small class="text-xs">kcal</small>
        </span>
      </div>
      <div class="flex items-center gap-3">
        <input id="kcalRange" class="flex-1 h-1.5 bg-gray-800 rounded-full appearance-none cursor-pointer accent-blue-500" type="range" min="0" max="1200" step="10" value="{{ kcal is not empty ? kcal : 1200 }}">
      </div>
    </div>

    <div class="bg-gray-900/50 p-4 rounded-2xl border border-gray-800">
      <div class="flex justify-between items-center mb-3">
        <span class="text-gray-400 text-xs font-bold uppercase tracking-wider">Min Proteins</span>
        <span class="text-xl font-bold text-purple-400">
          <span id="protVal">{{ proteins is not empty ? proteins : '—' }}</span> <small class="text-xs">g</small>
        </span>
      </div>
      <div class="flex items-center gap-3">
        <input id="protRange" class="flex-1 h-1.5 bg-gray-800 rounded-full appearance-none cursor-pointer accent-purple-500" type="range" min="0" max="150" step="1" value="{{ proteins is not empty ? proteins : 0 }}">
      </div>
    </div>
  </div>
</form>
