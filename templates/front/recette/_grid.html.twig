{# GRID RECIPES (USER) #}
<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
  {% for r in recipes %}
    {% set imgUrl = r.image ? asset('uploads/recipes/' ~ r.image) : 'https://images.unsplash.com/photo-1512621776951-a57141f2eefd?auto=format&fit=crop&w=1200&q=60' %}

    <div class="glass-card group cursor-pointer overflow-hidden transition transform hover:-translate-y-1 hover:shadow-2xl hover:shadow-blue-500/10 js-open-modal"
         data-id="{{ r.id }}"
         data-title="{{ r.title|e('html_attr') }}"
         data-description="{{ (r.description ?? '')|e('html_attr') }}"
         data-kcal="{{ r.kcal ?? '' }}"
         data-proteins="{{ r.proteins ?? '' }}"
         data-type="{{ r.typeMeal ?? '' }}"
         data-ingredients="{{ (r.ingredients ?? '')|e('html_attr') }}"
         data-preparation="{{ (r.preparation ?? '')|e('html_attr') }}"
         data-image="{{ imgUrl }}"
    >
     <div class="relative h-48 overflow-hidden">
  <img src="{{ imgUrl }}" alt="{{ r.title }}" class="w-full h-full object-cover transition duration-500 group-hover:scale-110">
  <div class="absolute inset-0 bg-gradient-to-t from-gray-900 via-transparent to-transparent opacity-60"></div>

  <div class="absolute top-4 left-4 px-3 py-1 bg-white/10 backdrop-blur-md rounded-full text-xs font-bold border border-white/20">
    {{ r.typeMeal }}
  </div>

  {# ❤️ Favorite button #}
  <button
    type="button"
    class="js-fav-btn absolute top-4 right-4 w-10 h-10 rounded-full bg-gray-900/50 backdrop-blur-md border border-white/10 flex items-center justify-center transition hover:scale-105"
    data-recipe-id="{{ r.id }}"
    data-fav="{{ app.user and r.favoritedBy.contains(app.user) ? '1' : '0' }}"
    aria-label="Toggle favorite"
  >
    <i class="fa-heart {{ app.user and r.favoritedBy.contains(app.user) ? 'fas text-red-500' : 'far text-gray-300' }}"></i>
  </button>
</div>

      <div class="p-6">
        <h3 class="text-xl font-bold mb-2 group-hover:text-blue-400 transition">{{ r.title }}</h3>
        <p class="text-gray-400 text-sm line-clamp-2 mb-6">
          {{ r.description ? r.description : 'A delicious and healthy meal choice for your fitness journey.' }}
        </p>

        <div class="flex items-center gap-4 pt-4 border-t border-gray-800">
          <div class="flex items-center gap-2 px-3 py-1 bg-blue-500/10 rounded-lg text-blue-400 text-xs font-bold border border-blue-500/20">
            <i class="fas fa-fire-alt"></i> {{ r.kcal }} KCAL
          </div>
          {% if r.proteins is not null %}
            <div class="flex items-center gap-2 px-3 py-1 bg-purple-500/10 rounded-lg text-purple-400 text-xs font-bold border border-purple-500/20">
              <i class="fas fa-muscle"></i> {{ r.proteins }}g PROT
            </div>
          {% endif %}
        </div>
      </div>
    </div>
  {% else %}
    <div class="col-span-full py-20 text-center glass-card border-dashed">
      <div class="w-20 h-20 bg-gray-800/50 rounded-full flex items-center justify-center mx-auto mb-4 text-gray-600">
        <i class="fas fa-utensils text-3xl"></i>
      </div>
      <h4 class="text-xl font-bold text-gray-400">No matching recipes</h4>
      <p class="text-gray-500">
        {% if userObjectifs is defined and userObjectifs|length > 0 %}
          No recipes found matching your specific goals. Try adjusting search or check back later!
        {% else %}
          Try adjusting your filters or search terms.
        {% endif %}
      </p>
    </div>
  {% endfor %}
</div>
