{% extends 'base.html.twig' %}

{% block title %}FitSense - My Dashboard{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --blue-light: #38BDF8;
            --violet-light: #A78BFA;
            --dark-bg: #111318;
            --dark-card: #1B1E26;
            --dark-input: #262A35;
            --text-primary: #FFFFFF;
            --text-secondary: #A1A1AA;
            --border-color: #343846;
        }

        body {
            background: var(--dark-bg);
            color: var(--text-primary);
            font-family: 'Inter', system-ui, sans-serif;
        }

        .glass-card {
            background: rgba(27, 30, 38, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 1.5rem;
        }

        .sidebar {
            background: linear-gradient(180deg, #1B1E26 0%, #111318 100%);
            border-right: 1px solid var(--border-color);
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 0.875rem 1.25rem;
            color: var(--text-secondary);
            border-radius: 0.75rem;
            transition: all 0.3s;
            margin: 0.25rem 0.75rem;
        }

        .sidebar-link:hover {
            background: rgba(56, 189, 248, 0.1);
            color: var(--blue-light);
            transform: translateX(4px);
        }

        .sidebar-link.active {
            background: linear-gradient(135deg, #38BDF8, #A78BFA);
            color: white;
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(56, 189, 248, 0.3);
        }

        .stat-card {
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .stat-card:hover {
            transform: translateY(-5px);
            border-color: var(--blue-light);
            box-shadow: 0 10px 30px -10px rgba(56, 189, 248, 0.2);
        }

        .progress-ring {
            transition: stroke-dashoffset 0.35s;
            transform: rotate(-90deg);
            transform-origin: 50% 50%;
        }
    </style>
{% endblock %}

{% block body %}
    <!-- Sidebar -->
    {% include 'partials/sidebaruser.html.twig' %}

    <!-- Main Content -->
    <div class="lg:ml-64 min-h-screen">
        <!-- Navbar -->
        {% embed 'admin/partials/navbar.html.twig' with {
            'role_label': 'Member'
        } %}
            {% block page_title %}My Dashboard{% endblock %}
            {% block page_subtitle %}Personal training portal{% endblock %}
        {% endembed %}

        <main class="p-8">
            <!-- Welcome Section -->
            <div class="relative overflow-hidden glass-card p-10 mb-8 border-none ring-1 ring-white/10">
                <div class="absolute top-0 right-0 w-96 h-96 bg-blue-500/10 rounded-full blur-3xl -mr-32 -mt-32"></div>
                <div class="absolute bottom-0 left-0 w-64 h-64 bg-purple-500/10 rounded-full blur-3xl -ml-24 -mb-24"></div>
                
                <div class="relative flex flex-col md:flex-row justify-between items-center gap-8">
                    <div>
                        <h1 class="text-4xl font-extrabold mb-3">Welcome back, {{ app.user.firstname }}! 👋</h1>
                        <p class="text-gray-400 text-lg max-w-xl">
                            Ready to crush your goals today? Your training schedule is waiting for you. 
                            Let's maintain that momentum!
                        </p>
                        <div class="mt-8 flex gap-4">
                            <a href="#" class="px-6 py-3 bg-gradient-to-r from-blue-500 to-purple-500 rounded-xl font-bold hover:shadow-lg hover:shadow-blue-500/30 transition transform hover:-translate-y-1">
                                Start Training
                            </a>
                            <a href="{{ path('etat_mental_new') }}" class="px-6 py-3 bg-gray-800 hover:bg-gray-700 rounded-xl font-bold transition">
                                Mental Check
                            </a>
                        </div>
                    </div>
                    <div class="hidden lg:block">
                        <img src="/assets/images/sport-hero.png" class="w-64 h-auto drop-shadow-2xl animate-bounce-slow" style="animation: bounce 6s ease-in-out infinite;">
                    </div>
                </div>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                <!-- Left Column -->
                <div class="lg:col-span-2 space-y-8">
                    <!-- Progress Section -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                        <div class="glass-card p-6 stat-card text-center">
                            <p class="text-gray-400 text-sm font-medium mb-2 uppercase tracking-wider">Daily Goal</p>
                            <div class="text-3xl font-bold text-blue-400 mb-1">85%</div>
                            <div class="w-full bg-gray-800 h-1.5 rounded-full">
                                <div class="bg-blue-400 h-1.5 rounded-full" style="width: 85%"></div>
                            </div>
                        </div>
                        <div class="glass-card p-6 stat-card text-center">
                            <p class="text-gray-400 text-sm font-medium mb-2 uppercase tracking-wider">Workouts</p>
                            <div class="text-3xl font-bold text-purple-400 mb-1">12</div>
                            <p class="text-xs text-gray-500">Completed this month</p>
                        </div>
                        <div class="glass-card p-6 stat-card text-center">
                            <p class="text-gray-400 text-sm font-medium mb-2 uppercase tracking-wider">Calories</p>
                            <div class="text-3xl font-bold text-orange-400 mb-1">2,450</div>
                            <p class="text-xs text-gray-500">Burned this week</p>
                        </div>
                    </div>

                    <!-- Upcoming Workouts -->
                    <div class="glass-card overflow-hidden">
                        <div class="p-6 border-b border-gray-800 flex justify-between items-center">
                            <h3 class="text-xl font-bold">Recommended Sessions</h3>
                            <a href="#" class="text-blue-400 hover:text-blue-300 text-sm font-bold">View All</a>
                        </div>
                        <div class="p-6">
                            <div class="space-y-4">
                                <div class="flex items-center p-4 bg-gray-800/50 rounded-2xl hover:bg-gray-800 transition group">
                                    <div class="w-12 h-12 bg-blue-500/20 rounded-xl flex items-center justify-center text-blue-400 mr-4">
                                        <i class="fas fa-dumbbell"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-bold group-hover:text-blue-400 transition">Upper Body Blast</h4>
                                        <p class="text-xs text-gray-500">Strength • 45 mins • Intermediate</p>
                                    </div>
                                    <button class="px-4 py-2 bg-gray-700 rounded-lg text-xs font-bold hover:bg-white hover:text-black transition">
                                        Join
                                    </button>
                                </div>
                                <div class="flex items-center p-4 bg-gray-800/50 rounded-2xl hover:bg-gray-800 transition group">
                                    <div class="w-12 h-12 bg-purple-500/20 rounded-xl flex items-center justify-center text-purple-400 mr-4">
                                        <i class="fas fa-heartbeat"></i>
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="font-bold group-hover:text-purple-400 transition">HIIT Cardio Burn</h4>
                                        <p class="text-xs text-gray-500">Cardio • 30 mins • Advanced</p>
                                    </div>
                                    <button class="px-4 py-2 bg-gray-700 rounded-lg text-xs font-bold hover:bg-white hover:text-black transition">
                                        Join
                                    </button>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Right Column -->
                <div class="space-y-8">
                    <!-- Mental Health Status -->
                    <div class="glass-card p-8 bg-gradient-to-br from-indigo-900/40 to-purple-900/40 border-indigo-500/20">
                        <h3 class="text-xl font-bold mb-6">Mental Wellbeing</h3>
                        <div class="flex items-center gap-4 mb-2">
                            <div class="px-3 py-1 bg-green-500/20 text-green-400 rounded-lg text-xs font-bold border border-green-500/30">
                                Positive
                            </div>
                            <span class="text-xs text-gray-400">Last check: Today</span>
                        </div>
                        <p class="text-gray-300 text-sm mb-6">
                            You're feeling stable and motivated. Remember to stay hydrated during your sessions!
                        </p>
                        <a href="{{ path('etat_mental_new') }}" class="block text-center py-3 bg-white/10 hover:bg-white/20 rounded-xl text-sm font-bold transition">
                            Take New Assessment
                        </a>
                    </div>

                    <!-- Nutrition Tip -->
                    <div class="glass-card p-6">
                        <div class="flex items-center gap-3 mb-4">
                            <i class="fas fa-leaf text-green-400"></i>
                            <h3 class="font-bold">Nutrition Tip</h3>
                        </div>
                        <p class="text-sm text-gray-400 italic">
                            "Consume protein within 30 minutes of your workout to maximize muscle recovery."
                        </p>
                    </div>

                    <!-- Upgrade Banner -->
                    <div class="p-6 rounded-2xl bg-indigo-600 relative overflow-hidden group">
                        <div class="absolute -right-4 -bottom-4 w-24 h-24 bg-white/10 rounded-full group-hover:scale-150 transition-transform duration-700"></div>
                        <h4 class="text-white font-extrabold mb-1">Upgrade to PRO</h4>
                        <p class="text-indigo-100 text-xs mb-4">Unlock personalized meal plans and 1-on-1 coaching.</p>
                        <button class="bg-white text-indigo-600 px-4 py-2 rounded-lg text-xs font-bold hover:bg-indigo-50 transition">
                            Learn More
                        </button>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <!-- Modals (Reuse Logout from Admin if needed, or simple version here) -->
    <div id="logoutModal" class="modal fixed inset-0 z-50 bg-black/80 backdrop-blur items-center justify-center" style="display: none;">
        <div class="glass-card p-8 max-w-sm w-full mx-4 text-center transform scale-90 active-modal:scale-100 transition-transform">
            <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-sign-out-alt text-red-500 text-2xl"></i>
            </div>
            <h3 class="text-2xl font-bold mb-2">Logout</h3>
            <p class="text-gray-400 mb-8">Are you sure you want to exit the platform?</p>
            <div class="flex gap-4">
                <button id="cancelLogout" class="flex-1 py-3 bg-gray-800 rounded-xl font-bold hover:bg-gray-700 transition font-medium">Cancel</button>
                <a href="{{ path('app_logout') }}" class="flex-1 py-3 bg-red-600 rounded-xl font-bold hover:bg-red-700 transition">Logout</a>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const logoutLinks = document.querySelectorAll('.logout-link');
            const logoutModal = document.getElementById('logoutModal');
            const cancelLogout = document.getElementById('cancelLogout');

            logoutLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    logoutModal.style.display = 'flex';
                });
            });

            cancelLogout.addEventListener('click', () => {
                logoutModal.style.display = 'none';
            });
            
            logoutModal.addEventListener('click', (e) => {
                if(e.target === logoutModal) logoutModal.style.display = 'none';
            });
        });
    </script>
{% endblock %}
