{% extends 'base.html.twig' %}

{% block title %}FitSense - User Portal{% endblock %}

{% block header %}{% endblock %}
{% block footer %}{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        :root {
            --blue-light: #38BDF8;
            --violet-light: #A78BFA;
            --dark-bg: #111318;
            --dark-card: #1B1E26;
            --dark-input: #262A35;
            --text-primary: #FFFFFF;
            --text-secondary: #A1A1AA;
            --border-color: #343846;
        }

        body {
            background: var(--dark-bg);
            color: var(--text-primary);
            font-family: 'Inter', system-ui, sans-serif;
        }

        .glass-card {
            background: rgba(27, 30, 38, 0.7);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255, 255, 255, 0.05);
            border-radius: 1.5rem;
        }

        .sidebar {
            background: linear-gradient(180deg, #1B1E26 0%, #111318 100%);
            border-right: 1px solid var(--border-color);
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            padding: 0.875rem 1.25rem;
            color: var(--text-secondary);
            border-radius: 0.75rem;
            transition: all 0.3s;
            margin: 0.25rem 0.75rem;
        }

        .sidebar-link:hover {
            background: rgba(56, 189, 248, 0.1);
            color: var(--blue-light);
            transform: translateX(4px);
        }

        .sidebar-link.active {
            background: linear-gradient(135deg, #38BDF8, #A78BFA);
            color: white;
            font-weight: 600;
            box-shadow: 0 4px 12px rgba(56, 189, 248, 0.3);
        }

        .table-row:hover {
            background-color: rgba(56, 189, 248, 0.05);
        }

        /* Scrollbar styling */
        ::-webkit-scrollbar {
            width: 10px;
        }

        ::-webkit-scrollbar-track {
            background: var(--dark-bg);
        }

        ::-webkit-scrollbar-thumb {
            background: #343846;
            border-radius: 5px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #38BDF8;
        }
    </style>
{% endblock %}

{% block body %}
    <!-- Sidebar -->
    {% include 'partials/sidebaruser.html.twig' %}

    <!-- Main Content Area -->
    <div class="lg:ml-64 min-h-screen flex flex-col">
        <!-- Navbar -->
        {% embed 'admin/partials/navbar.html.twig' with {
            'role_label': 'Member'
        } %}
            {% block page_title %}{% block user_page_title %}Dashboard{% endblock %}{% endblock %}
            {% block page_subtitle %}{% block user_page_subtitle %}Personal training portal{% endblock %}{% endblock %}
        {% endembed %}

        <main class="p-6 lg:p-8 flex-1">
            {% block user_content %}{% endblock %}
        </main>
    </div>

    <!-- Global Logout Modal -->
    <div id="logoutModal" class="modal fixed inset-0 z-50 bg-black/80 backdrop-blur items-center justify-center" style="display: none;">
        <div class="glass-card p-8 max-w-sm w-full mx-4 text-center transform scale-90 active-modal:scale-100 transition-transform">
            <div class="w-16 h-16 bg-red-500/20 rounded-full flex items-center justify-center mx-auto mb-4">
                <i class="fas fa-sign-out-alt text-red-500 text-2xl"></i>
            </div>
            <h3 class="text-2xl font-bold mb-2">Logout</h3>
            <p class="text-gray-400 mb-8">Are you sure you want to exit the platform?</p>
            <div class="flex gap-4">
                <button id="cancelLogout" class="flex-1 py-3 bg-gray-800 rounded-xl font-bold hover:bg-gray-700 transition">Cancel</button>
                <a href="{{ path('app_logout') }}" class="flex-1 py-3 bg-red-600 rounded-xl font-bold hover:bg-red-700 transition">Logout</a>
            </div>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const logoutLinks = document.querySelectorAll('.logout-link');
            const logoutModal = document.getElementById('logoutModal');
            const cancelLogout = document.getElementById('cancelLogout');

            logoutLinks.forEach(link => {
                link.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (logoutModal) logoutModal.style.display = 'flex';
                });
            });

            if (cancelLogout && logoutModal) {
                cancelLogout.addEventListener('click', () => {
                    logoutModal.style.display = 'none';
                });
                
                logoutModal.addEventListener('click', (e) => {
                    if(e.target === logoutModal) logoutModal.style.display = 'none';
                });
            }
        });
    </script>
{% endblock %}
