{% extends base_template %}

{% block title %}Security & Login History - FitSense{% endblock %}

{% block user_page_title %}Security Settings{% endblock %}
{% block user_page_subtitle %}Monitor your account access and login history{% endblock %}

{% block user_content %}
<div class="max-w-6xl mx-auto px-4">
    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        {% for message in messages %}
            <div class="mb-6 p-4 rounded-2xl flex items-center gap-3 animate-fadeIn {{ label == 'error' ? 'bg-red-500/10 text-red-400 border border-red-500/20' : (label == 'success' ? 'bg-emerald-500/10 text-emerald-400 border border-emerald-500/20' : 'bg-blue-500/10 text-blue-400 border border-blue-500/20') }}">
                <i class="fas {{ label == 'error' ? 'fa-exclamation-circle' : (label == 'success' ? 'fa-check-circle' : 'fa-info-circle') }}"></i>
                <span class="text-sm font-medium">{{ message }}</span>
            </div>
        {% endfor %}
    {% endfor %}

    <!-- Security Overview Cards -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 mb-8">
        <!-- 2FA Status Card -->
        <div class="glass-card p-6 border-l-4 {{ two_factor_enabled ? 'border-emerald-500' : 'border-amber-500' }} relative overflow-hidden group">
            <div class="absolute top-0 right-0 -mt-2 -mr-2 w-20 h-20 {{ two_factor_enabled ? 'bg-emerald-500/5' : 'bg-amber-500/5' }} blur-2xl rounded-full"></div>
            <div class="flex items-center justify-between gap-4 relative z-10">
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-xl {{ two_factor_enabled ? 'bg-emerald-500/10' : 'bg-amber-500/10' }} flex items-center justify-center shadow-inner">
                        <i class="fas fa-shield-alt {{ two_factor_enabled ? 'text-emerald-500' : 'text-amber-500' }} text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-gray-400 text-[10px] font-bold uppercase tracking-wider mb-1">2FA Security</h3>
                        <p class="text-white text-base font-bold">{{ two_factor_enabled ? 'Protected' : 'Unprotected' }}</p>
                    </div>
                </div>
                
                {% if two_factor_enabled %}
                    <button type="button" data-modal-toggle="disable-2fa-modal" class="p-2 rounded-lg bg-red-500/10 text-red-400 hover:bg-red-500/20 transition-all cursor-pointer" title="Manage 2FA">
                        <i class="fas fa-cog"></i>
                    </button>
                {% else %}
                    <a href="{{ path('security_2fa_enable') }}" class="p-2 rounded-lg bg-violet-600/20 text-violet-400 hover:bg-violet-600/30 transition-all" title="Enable 2FA">
                        <i class="fas fa-plus"></i>
                    </a>
                {% endif %}
            </div>
            
            {% if not two_factor_enabled %}
                <div class="mt-4 pt-4 border-t border-white/5">
                    <a href="{{ path('security_2fa_enable') }}" class="text-[10px] font-bold text-violet-400 hover:text-violet-300 transition-colors flex items-center gap-2">
                        ENABLE TWO-FACTOR AUTH <i class="fas fa-arrow-right"></i>
                    </a>
                </div>
            {% endif %}
        </div>
        
        <div class="glass-card p-6 border-l-4 border-blue-500">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-blue-500/10 flex items-center justify-center">
                    <i class="fas fa-map-marker-alt text-blue-500 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-gray-400 text-[10px] font-bold uppercase tracking-wider mb-1">Last Login Location</h3>
                    <p class="text-white text-base font-bold">
                        {% if attempts|length > 0 %}
                            {{ attempts[0].city }}, {{ attempts[0].country.value|default('N/A') }}
                        {% else %}
                            N/A
                        {% endif %}
                    </p>
                </div>
            </div>
        </div>

        <div class="glass-card p-6 border-l-4 border-purple-500">
            <div class="flex items-center gap-4">
                <div class="w-12 h-12 rounded-xl bg-purple-500/10 flex items-center justify-center">
                    <i class="fas fa-clock text-purple-500 text-xl"></i>
                </div>
                <div>
                    <h3 class="text-gray-400 text-[10px] font-bold uppercase tracking-wider mb-1">Recent Activity</h3>
                    <p class="text-white text-base font-bold">{{ attempts|length }} Logins</p>
                </div>
            </div>
        </div>
    </div>

    <!-- 2FA Detailed Management (Hidden if disabled to keep it clean) -->
    {% if two_factor_enabled %}
    <div class="glass-card p-8 mb-8 border border-white/5 relative overflow-hidden group">
        <div class="absolute top-0 right-0 -mt-8 -mr-8 w-48 h-48 bg-emerald-500/5 blur-3xl rounded-full"></div>
        <div class="flex flex-col md:flex-row items-center justify-between gap-6 relative z-10">
            <div class="flex-1 text-center md:text-left">
                <h2 class="text-xl font-bold text-white mb-2">Authenticator App Status</h2>
                <p class="text-gray-400 text-sm leading-relaxed max-w-xl">
                    Your account is currently secured with Two-Factor Authentication. You will be asked for a verification code from your authenticator app cada vez que inicie sesión.
                </p>
            </div>
            <button type="button" data-modal-toggle="disable-2fa-modal" class="px-6 py-3 rounded-xl bg-red-500/10 text-red-400 border border-red-500/20 hover:bg-red-500/20 transition-all font-bold text-xs">
                <i class="fas fa-trash-alt mr-2"></i> Disable 2FA
            </button>
        </div>
    </div>
    {% endif %}

    <!-- Login History Table -->
    <div class="glass-card overflow-hidden">
        <div class="p-6 border-b border-white/5 flex items-center justify-between">
            <h3 class="text-xl font-bold text-white flex items-center gap-3">
                <i class="fas fa-history text-blue-400"></i>
                Login History
            </h3>
            <span class="text-xs text-gray-400 bg-white/5 px-3 py-1 rounded-full border border-white/5">
                Showing last 50 attempts
            </span>
        </div>
        
        <div class="overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-white/5 text-gray-400 text-xs uppercase tracking-wider">
                        <th class="px-6 py-4 font-semibold">Status</th>
                        <th class="px-6 py-4 font-semibold">Location</th>
                        <th class="px-6 py-4 font-semibold">IP Address</th>
                        <th class="px-6 py-4 font-semibold">ISP / Network</th>
                        <th class="px-6 py-4 font-semibold">Date & Time</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-white/5">
                    {% for attempt in attempts %}
                        <tr class="hover:bg-white/[0.02] transition-colors group">
                            <td class="px-6 py-4">
                                {% if attempt.status.value == 'success' %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-emerald-500/10 text-emerald-500 border border-emerald-500/20">
                                        <i class="fas fa-check-circle text-[10px]"></i>
                                        Success
                                    </span>
                                {% else %}
                                    <span class="inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-xs font-medium bg-red-500/10 text-red-500 border border-red-500/20">
                                        <i class="fas fa-times-circle text-[10px]"></i>
                                        Failed
                                    </span>
                                {% endif %}
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-white text-sm font-medium line-clamp-1">
                                        {{ attempt.city ?: 'Unknown' }}, {{ attempt.region ?: 'Unknown' }}
                                    </span>
                                    <span class="text-gray-500 text-[11px] flex items-center gap-1">
                                        <i class="fas fa-globe-africa"></i>
                                        {{ attempt.country.value|default('N/A') }}
                                    </span>
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <code class="text-blue-400 text-xs bg-blue-500/5 px-2 py-1 rounded border border-blue-500/10">
                                    {{ attempt.ipAddress }}
                                </code>
                            </td>
                            <td class="px-6 py-4">
                                <span class="text-gray-400 text-sm font-medium line-clamp-1 truncate max-w-[200px]" title="{{ attempt.isp }}">
                                    {{ attempt.isp ?: 'Private Network' }}
                                </span>
                            </td>
                            <td class="px-6 py-4 whitespace-nowrap">
                                <span class="text-gray-300 text-sm">
                                    {{ attempt.timestamp|date('M d, Y') }}
                                </span>
                                <span class="text-gray-500 text-xs block">
                                    {{ attempt.timestamp|date('H:i:s') }}
                                </span>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="5" class="px-6 py-12 text-center">
                                <div class="flex flex-col items-center gap-3">
                                    <div class="w-16 h-16 rounded-full bg-white/5 flex items-center justify-center mb-2">
                                        <i class="fas fa-shield-alt text-gray-600 text-2xl"></i>
                                    </div>
                                    <p class="text-gray-400 font-medium">No login history recorded yet.</p>
                                    <p class="text-gray-500 text-xs">Successfully logged in attempts will appear here.</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    
    <!-- Security Tips -->
    <div class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="glass-card p-6 bg-gradient-to-br from-purple-500/5 to-transparent border border-purple-500/10">
            <h4 class="text-white font-bold mb-4 flex items-center gap-2">
                <i class="fas fa-lightbulb text-yellow-400"></i>
                Security Recommendations
            </h4>
            <ul class="space-y-3">
                <li class="flex items-start gap-3 text-sm text-gray-400">
                    <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-500 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <i class="fas fa-check text-[10px]"></i>
                    </span>
                    Regularly check your login history for unusual locations or IP addresses.
                </li>
                <li class="flex items-start gap-3 text-sm text-gray-400">
                    <span class="w-5 h-5 rounded-full bg-emerald-500/20 text-emerald-500 flex items-center justify-center flex-shrink-0 mt-0.5">
                        <i class="fas fa-check text-[10px]"></i>
                    </span>
                    Ensure you have a strong, unique password for your FitSense account.
                </li>
            </ul>
    </div>
</div>

{# Disable 2FA confirmation modal #}
{% if two_factor_enabled %}
<div id="disable-2fa-modal" class="fixed inset-0 z-[60] hidden overflow-y-auto overflow-x-hidden flex items-center justify-center p-4" aria-hidden="true">
    <div class="fixed inset-0 bg-black/80 backdrop-blur-md" data-modal-close="disable-2fa-modal" aria-label="Close"></div>
    <div class="relative z-10 w-full max-w-md rounded-3xl bg-[#1B1E26] border border-white/10 shadow-2xl overflow-hidden animate-zoomIn">
        <div class="p-1 w-full bg-gradient-to-r from-red-500 to-transparent"></div>
        <div class="p-8">
            <div class="w-16 h-16 rounded-2xl bg-red-500/10 flex items-center justify-center mb-6">
                <i class="fas fa-exclamation-triangle text-red-500 text-2xl"></i>
            </div>
            <h3 class="text-2xl font-bold text-white mb-2">Disable 2FA?</h3>
            <p class="text-gray-400 text-sm mb-6 leading-relaxed">This will reduce your account security. Please enter your password to confirm this action.</p>
            
            <form method="post" action="{{ path('security_2fa_disable') }}">
                <input type="hidden" name="_csrf_token" value="{{ csrf_token('disable_2fa') }}">
                <div class="mb-6">
                    <label for="disable-2fa-password" class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Account Password</label>
                    <input type="password" id="disable-2fa-password" name="_password" placeholder="••••••••"
                        class="w-full rounded-2xl bg-black/20 border border-white/10 px-4 py-4 text-white focus:border-red-500/50 focus:ring-4 focus:ring-red-500/10 transition-all outline-none"
                        autocomplete="current-password">
                </div>
                
                <div class="flex gap-3">
                    <button type="button" data-modal-close="disable-2fa-modal"
                        class="flex-1 px-6 py-4 rounded-2xl bg-white/5 text-gray-400 hover:text-white transition-all font-bold text-sm">
                        Keep Secure
                    </button>
                    <button type="submit"
                        class="flex-1 px-6 py-4 rounded-2xl bg-red-600 text-white font-bold text-sm hover:bg-red-700 shadow-lg shadow-red-600/20 transition-all">
                        Confirm Disable
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<style>
@keyframes zoomIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
}
.animate-zoomIn { animation: zoomIn 0.3s cubic-bezier(0.16, 1, 0.3, 1); }
</style>

<script>
(function () {
    var modal = document.getElementById('disable-2fa-modal');
    if (!modal) return;
    var toggles = document.querySelectorAll('[data-modal-toggle="disable-2fa-modal"]');
    var closers = document.querySelectorAll('[data-modal-close="disable-2fa-modal"]');
    function openModal() {
        modal.classList.remove('hidden');
        modal.classList.add('flex');
        document.body.style.overflow = 'hidden';
    }
    function closeModal() {
        modal.classList.add('hidden');
        modal.classList.remove('flex');
        document.body.style.overflow = '';
    }
    toggles.forEach(function (el) { el.addEventListener('click', openModal); });
    closers.forEach(function (el) { el.addEventListener('click', closeModal); });
    modal.addEventListener('click', function (e) {
        if (e.target === modal) closeModal();
    });
})();
</script>
{% endif %}
{% endblock %}
