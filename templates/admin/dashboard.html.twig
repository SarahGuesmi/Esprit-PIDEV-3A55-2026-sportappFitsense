{% extends 'admin/base_admin.html.twig' %}

{% block title %}Dashboard - FitSense Admin{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        /* Chart.js canvas styling */
        canvas {
            max-height: 100% !important;
            max-width: 100% !important;
        }
        
        /* Enhanced chart containers with glass effect */
        .chart-container {
            position: relative;
            width: 100%;
            background: rgba(255, 255, 255, 0.02);
            border-radius: 16px;
            padding: 20px;
            backdrop-filter: blur(10px);
        }
        
        /* Chart card hover effects */
        .chart-card {
            transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
            position: relative;
            overflow: hidden;
        }
        
        .chart-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.1), transparent);
            transition: left 0.5s;
        }
        
        .chart-card:hover::before {
            left: 100%;
        }
        
        .chart-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
            border-color: rgba(139, 92, 246, 0.4) !important;
        }
        
        /* Chart title glow effect */
        .chart-title {
            position: relative;
            display: inline-flex;
            align-items: center;
            gap: 0.5rem;
        }
        
        .chart-title i {
            filter: drop-shadow(0 0 8px currentColor);
            animation: iconPulse 2s ease-in-out infinite;
        }
        
        @keyframes iconPulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.1); opacity: 0.8; }
        }
        
        /* Chart loading animation */
        @keyframes chartFadeIn {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }
        
        .chart-card {
            animation: chartFadeIn 0.6s ease-out forwards;
        }
        
        .chart-card:nth-child(1) { animation-delay: 0.1s; }
        .chart-card:nth-child(2) { animation-delay: 0.2s; }
        .chart-card:nth-child(3) { animation-delay: 0.3s; }
        
        /* Gradient border animation */
        @keyframes borderGlow {
            0%, 100% { border-color: rgba(139, 92, 246, 0.3); }
            50% { border-color: rgba(56, 189, 248, 0.5); }
        }
        
        .chart-card {
            animation: chartFadeIn 0.6s ease-out forwards, borderGlow 3s ease-in-out infinite;
        }
        
        /* Chart wrapper with subtle grid background */
        .chart-wrapper {
            position: relative;
            background-image: 
                linear-gradient(rgba(139, 92, 246, 0.02) 1px, transparent 1px),
                linear-gradient(90deg, rgba(139, 92, 246, 0.02) 1px, transparent 1px);
            background-size: 20px 20px;
            border-radius: 12px;
        }
        
        /* Fix for Chart.js in dark theme */
        .chartjs-render-monitor {
            animation: chartjs-render-animation 0.001s;
        }
        
        /* Stat badge styling */
        .stat-badge {
            background: rgba(139, 92, 246, 0.1);
            border: 1px solid rgba(139, 92, 246, 0.3);
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            font-size: 0.75rem;
            font-weight: 600;
            color: rgba(167, 139, 250, 1);
            backdrop-filter: blur(8px);
        }
        
        /* Chart section headers */
        .section-divider {
            position: relative;
            margin: 2rem 0;
        }
        
        .section-divider::before {
            content: '';
            position: absolute;
            left: 0;
            right: 0;
            top: 50%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.3), transparent);
        }
    </style>
{% endblock %}

{% block admin_content %}

<div class="space-y-8">
    <!-- Header -->
    <div>
        <h1 class="text-3xl font-bold text-white">Dashboard</h1>
        <p class="mt-2 text-gray-400">Welcome to the admin panel</p>
    </div>

    <!-- Stats Cards -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-6">
        <!-- Total Users Card -->
        <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700 hover:border-blue-500 transition-all duration-300 hover:transform hover:scale-105">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-400 uppercase tracking-wide">Total Users</p>
                    <p class="text-4xl font-bold text-white mt-3">{{ userCount ?? 0 }}</p>
                    <p class="text-xs text-green-400 mt-2 flex items-center gap-1">
                        <i class="fas fa-arrow-up"></i>
                        <span>+12% this month</span>
                    </p>
                </div>
                <div class="bg-gradient-to-br from-blue-500 to-blue-600 rounded-2xl p-4 shadow-lg">
                    <i class="fas fa-users text-white text-3xl"></i>
                </div>
            </div>
        </div>

        <!-- Active Sessions Card -->
        <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700 hover:border-green-500 transition-all duration-300 hover:transform hover:scale-105">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-400 uppercase tracking-wide">Active Sessions</p>
                    <p class="text-4xl font-bold text-white mt-3">24</p>
                    <p class="text-xs text-green-400 mt-2 flex items-center gap-1">
                        <i class="fas fa-circle text-green-400 text-xs animate-pulse"></i>
                        <span>Live now</span>
                    </p>
                </div>
                <div class="bg-gradient-to-br from-green-500 to-green-600 rounded-2xl p-4 shadow-lg">
                    <i class="fas fa-chart-line text-white text-3xl"></i>
                </div>
            </div>
        </div>

        <!-- Notifications Card -->
        <a href="{{ path('admin_notifications') }}" class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700 hover:border-purple-500 transition-all duration-300 hover:transform hover:scale-105 block group">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-400 uppercase tracking-wide group-hover:text-purple-400 transition-colors">Notifications</p>
                    <p class="text-4xl font-bold text-white mt-3">{{ unreadNotifications ?? 0 }}</p>
                    <p class="text-xs text-yellow-400 mt-2 flex items-center gap-1">
                        <i class="fas fa-exclamation-circle"></i>
                        <span>Check alerts</span>
                    </p>
                </div>
                <div class="bg-gradient-to-br from-purple-500 to-purple-600 rounded-2xl p-4 shadow-lg group-hover:shadow-purple-500/50 transition-all">
                    <i class="fas fa-bell text-white text-3xl"></i>
                </div>
            </div>
        </a>

        <!-- 2FA Protected Accounts Card -->
        <div class="bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-emerald-600/60 hover:border-emerald-400 transition-all duration-300 hover:transform hover:scale-105">
            <div class="flex items-center justify-between">
                <div>
                    <p class="text-sm font-medium text-gray-400 uppercase tracking-wide">2FA Protected</p>
                    <p class="text-4xl font-bold text-white mt-3">{{ twoFaEnabled ?? 0 }}</p>
                    <p class="text-xs text-emerald-400 mt-2 flex items-center gap-1">
                        <i class="fas fa-shield-alt"></i>
                        <span>Users with Google Authenticator</span>
                    </p>
                </div>
                <div class="bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-2xl p-4 shadow-lg">
                    <i class="fas fa-lock text-white text-3xl"></i>
                </div>
            </div>
        </div>
    </div>

    <!-- User & Security Charts -->
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <div class="lg:col-span-2 chart-card bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
            <div class="flex items-center justify-between mb-6">
                <h2 class="chart-title text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-users-cog text-blue-400"></i>
                    <span>Users by Role</span>
                </h2>
                <span class="stat-badge">Active Users</span>
            </div>
            <div class="chart-wrapper" style="position: relative; height: 300px;">
                {{ render_chart(userRoleChart) }}
            </div>
        </div>

        <div class="chart-card bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
            <div class="flex items-center justify-between mb-6">
                <h2 class="chart-title text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-shield-alt text-emerald-400"></i>
                    <span>2FA Protection</span>
                </h2>
                <span class="stat-badge">Security</span>
            </div>
            <div class="chart-wrapper" style="position: relative; height: 300px;">
                {{ render_chart(twoFaChart) }}
            </div>
        </div>
    </div>

    <!-- Activity & Messaging Charts -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div class="chart-card bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
            <div class="flex items-center justify-between mb-6">
                <h2 class="chart-title text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-sign-in-alt text-red-400"></i>
                    <span>Login Attempts</span>
                </h2>
                <span class="stat-badge">Last 30 Days</span>
            </div>
            <div class="chart-wrapper" style="position: relative; height: 300px;">
                {{ render_chart(loginChart) }}
            </div>
        </div>

        <div class="chart-card bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
            <div class="flex items-center justify-between mb-6">
                <h2 class="chart-title text-lg font-bold text-white flex items-center gap-2">
                    <i class="fas fa-comments text-indigo-400"></i>
                    <span>Messages per Day</span>
                </h2>
                <span class="stat-badge">Total: {{ totalMessages ?? 0 }}</span>
            </div>
            <div class="chart-wrapper" style="position: relative; height: 300px;">
                {{ render_chart(messageChart) }}
            </div>
        </div>
    </div>

    <!-- Notifications Chart -->
    <div class="chart-card bg-gradient-to-br from-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
        <div class="flex items-center justify-between mb-6">
            <h2 class="chart-title text-lg font-bold text-white flex items-center gap-2">
                <i class="fas fa-bell text-purple-400"></i>
                <span>Notifications by Type</span>
            </h2>
            <span class="stat-badge">Total: {{ totalNotifications ?? 0 }}</span>
        </div>
        <div class="chart-wrapper" style="position: relative; height: 350px;">
            {{ render_chart(notificationChart) }}
        </div>
    </div>
</div>

{% endblock %}
