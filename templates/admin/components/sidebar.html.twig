<aside class="w-60 bg-white flex flex-col border-r border-gray-200">
    <div class="p-6 pb-0 flex items-center justify-between">
        <h1 class="text-lg font-semibold text-gray-900">Material Shadcn</h1>
    </div>

    <nav class="flex-1 p-4 space-y-2">
        {% set navItems = [
            {'title': 'Dashboard', 'href': '/admin', 'icon': 'layout-dashboard'},
            {'title': 'Profile', 'href': '/admin/profile', 'icon': 'user'},
            {'title': 'Tables', 'href': '/admin/tables', 'icon': 'table'},
            {'title': 'Notifications', 'href': '/admin/notifications', 'icon': 'bell'},
            {'title': 'Subscriptions', 'href': '/admin/subscriptions', 'icon': 'credit-card'}
        ] %}

        {% for item in navItems %}
            <a href="{{ item.href }}" class="flex items-center px-3 py-2 text-sm font-normal rounded-lg hover:bg-gray-100">
                <i class="icon-{{ item.icon }} mr-3 w-4 h-4"></i>
                {{ item.title }}
            </a>
        {% endfor %}

        <div class="pt-4 border-t border-gray-200 mt-4">
            <p class="px-4 text-xs font-semibold text-gray-500 uppercase tracking-wide mb-2">Auth Pages</p>
            <a href="/auth/sign-in" class="flex items-center px-3 py-2 text-sm rounded-lg hover:bg-gray-100">
                <i class="icon-log-in mr-3 w-4 h-4"></i> Sign In
            </a>
            <a href="/auth/sign-up" class="flex items-center px-3 py-2 text-sm rounded-lg hover:bg-gray-100">
                <i class="icon-user-plus mr-3 w-4 h-4"></i> Sign Up
            </a>
        </div>
    </nav>
</aside>
