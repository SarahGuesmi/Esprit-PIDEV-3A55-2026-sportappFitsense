{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}

    <!-- Flash Messages -->
    {% for label, messages in app.flashes %}
        <div class="mb-6 px-6 py-4 rounded-xl {% if label == 'success' %}bg-green-500/20 border border-green-500/40 text-green-300{% else %}bg-red-500/20 border border-red-500/40 text-red-300{% endif %} backdrop-blur">
            {% for message in messages %}
                <div class="flex items-center">
                    <i class="fas {% if label == 'success' %}fa-check-circle{% else %}fa-exclamation-circle{% endif %} mr-3"></i>
                    <span>{{ message }}</span>
                </div>
            {% endfor %}
        </div>
    {% endfor %}

    <div class="space-y-6 relative z-10">
        <!-- Tech Grid Background -->
        <div class="tech-grid"></div>

        <!-- Header -->
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl p-8 border border-gray-700">
            <!-- Purple accent corner -->
            <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-purple-500/20 to-transparent rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-tr from-blue-500/20 to-transparent rounded-full blur-3xl"></div>

            <div class="relative flex justify-between items-center">
                <div class="group/header-title">
                    <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3 transition-all duration-500 group-hover/header-title:tracking-tight">
                        <div class="w-1.5 h-10 bg-gradient-to-b from-purple-400 to-blue-400 rounded-full shadow-[0_0_15px_rgba(167,139,250,0.5)]"></div>
                        <span class="bg-gradient-to-r from-white via-purple-200 to-white bg-[length:200%_auto] animate-gradient-x bg-clip-text text-transparent">User Management</span>
                    </h1>
                    <p class="text-gray-400 ml-6 flex items-center gap-2">
                        <i class="fas fa-microchip text-purple-500/50 text-xs"></i>
                        Browse and manage all users in the system
                    </p>
                </div>
                <button id="openAddCoachModal" class="relative group/add-btn bg-gradient-to-r from-purple-500 to-blue-500 text-white px-6 py-3 rounded-xl font-semibold overflow-hidden transition-all duration-300 shadow-lg hover:shadow-purple-500/50 hover:transform hover:scale-105 active:scale-95">
                    <div class="absolute inset-0 bg-white/20 translate-y-full group-hover/add-btn:translate-y-0 transition-transform duration-300"></div>
                    <span class="relative flex items-center gap-2">
                        <i class="fas fa-plus-circle transition-transform group-hover/add-btn:rotate-90"></i>
                        Add Coach
                    </span>
                </button>
            </div>
        </div>

        <!-- Search & Filter Section -->
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
            <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-500/30 rounded-full blur-3xl"></div>

            <div class="relative flex flex-col md:flex-row gap-4">
                <!-- Search -->
                <div class="flex-1">
                    <label for="searchUsers" class="block text-sm font-medium text-gray-300 mb-2">Search Users</label>
                    <div class="relative group">
                        <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                            <i class="fas fa-search text-gray-500 group-focus-within:text-purple-400 transition"></i>
                        </div>
                        <input
                            type="text"
                            id="searchUsers"
                            class="block w-full pl-12 pr-4 py-3.5 bg-gray-900/40 backdrop-blur-md border border-gray-700/50 rounded-xl text-white placeholder-gray-500 focus:border-purple-500/80 focus:outline-none focus:ring-4 focus:ring-purple-500/10 transition-all duration-300"
                            placeholder="Search by name or email..."
                        >
                        <div class="search-scan-line"></div>
                    </div>
                </div>

                <!-- Filters -->
                <div class="flex gap-2 items-end">
                    <div>
                        <label for="filterStatus" class="block text-sm font-medium text-gray-300 mb-2">Status</label>
                        <select
                            id="filterStatus"
                            class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        >
                            <option value="">All</option>
                            <option value="active">Active</option>
                            <option value="inactive">Inactive</option>
                        </select>
                    </div>
                    <div>
                        <label for="filterRole" class="block text-sm font-medium text-gray-300 mb-2">Role</label>
                        <select
                            id="filterRole"
                            class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        >
                            <option value="">All</option>
                            <option value="ROLE_USER">User</option>
                            <option value="ROLE_COACH">Coach</option>
                            <option value="ROLE_ADMIN">Admin</option>
                        </select>
                    </div>
                </div>

                <!-- Clear -->
                <div class="pt-7">
                    <button id="clearSearch" class="px-6 py-3.5 bg-gray-900/80 backdrop-blur border border-gray-700 rounded-xl text-gray-300 hover:text-white hover:border-purple-500 transition font-medium">
                        Clear
                    </button>
                </div>
            </div>

            <div id="searchResults" class="relative mt-3 text-sm text-gray-400"></div>
        </div>

        <!-- Users Table -->
        <form id="bulkDeleteForm" action="{{ path('admin_users_bulk_delete') }}" method="POST">
            <input type="hidden" name="_token" value="{{ csrf_token('admin_user_bulk_delete') }}">
            
            <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl border border-gray-700">
                <div class="absolute top-0 right-0 w-96 h-96 bg-gradient-to-bl from-purple-500/10 to-transparent rounded-full blur-3xl pointer-events-none"></div>
                <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-tr from-blue-500/10 to-transparent rounded-full blur-3xl pointer-events-none"></div>

                <div class="relative p-6 border-b border-gray-700/50 flex justify-between items-center">
                    <h2 class="text-xl font-semibold text-white flex items-center gap-3">
                        <div class="w-1 h-6 bg-gradient-to-b from-purple-400 to-blue-400 rounded-full"></div>
                        Users Table
                    </h2>
                    
                    <!-- Bulk Action Button (Initially Hidden) -->
                    <button type="button" id="bulkDeleteBtn" class="hidden px-4 py-2 bg-red-500/10 hover:bg-red-500 text-red-500 hover:text-white border border-red-500/30 rounded-lg transition-all flex items-center gap-2 group/bulk">
                        <i class="fas fa-trash-alt group-hover/bulk:rotate-12 transition-transform"></i>
                        Delete Selected (<span id="selectedCount">0</span>)
                    </button>
                </div>

                <div class="relative overflow-x-auto">
                    <table class="min-w-full divide-y divide-gray-700/50">
                        <thead class="bg-gray-900/50 backdrop-blur">
                            <tr>
                                <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider w-10">
                                    <input type="checkbox" id="selectAllUsers" class="w-4 h-4 bg-gray-900 border-gray-700 rounded text-purple-500 focus:ring-purple-500/20 transition-all cursor-pointer">
                                </th>
                                <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-user text-purple-400"></i>
                                        User
                                    </div>
                                </th>
                                <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-briefcase text-purple-400"></i>
                                        Function
                                    </div>
                                </th>
                                <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-toggle-on text-purple-400"></i>
                                        Status
                                    </div>
                                </th>
                                <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                                    <div class="flex items-center gap-2">
                                        <i class="fas fa-calendar text-purple-400"></i>
                                        Date creation
                                    </div>
                                </th>
                                <th class="px-6 py-5 text-right text-xs font-bold text-gray-300 uppercase tracking-wider">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-700/50 backdrop-blur">
                            {% include 'admin/users/_table.html.twig' %}
                        </tbody>
                    </table>
                </div>
            </div>
        </form>
    </div>

    <!-- Add Coach Modal -->
    <div id="addCoachModal" class="modal fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[60] opacity-0 pointer-events-none transition-all duration-500 overflow-hidden">
        <div class="modal-content relative bg-[#1B1E26]/90 border border-purple-500/30 rounded-[2.5rem] shadow-[0_0_50px_rgba(139,92,246,0.2)] max-w-4xl w-[95%] max-h-[90vh] flex flex-col transform scale-95 transition-all duration-500 overflow-hidden">
            
            <!-- Modal Header -->
            <div class="relative p-8 border-b border-white/5 bg-gradient-to-r from-purple-500/10 to-transparent">
                <div class="absolute top-0 right-0 p-8">
                    <button id="closeAddCoachModal" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-red-500/20 transition-all duration-300">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center shadow-lg shadow-purple-500/30">
                        <i class="fas fa-user-plus text-white text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold text-white tracking-tight">Initiate System Coach</h3>
                        <p class="text-sm text-gray-400">Deploy a new administrative entity to coordinates</p>
                    </div>
                </div>
            </div>

            <!-- Modal Body (Scrollable) -->
            <form id="addCoachForm" action="{{ path('admin_users_add_coach') }}" method="POST" class="flex-1 overflow-y-auto custom-scrollbar p-8" novalidate>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- First Name -->
                    <div class="space-y-2 group/input stagger-field" style="animation-delay: 0.1s">
                        <label for="firstname" class="block text-xs font-bold text-purple-400/80 uppercase tracking-widest px-1">Forename Signature</label>
                        <div class="relative">
                            <i class="fas fa-id-card absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-purple-500 transition-colors"></i>
                            <input type="text" id="firstname" name="firstname" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white placeholder-gray-700 focus:border-purple-500/50 focus:ring-4 focus:ring-purple-500/10 transition-all duration-300 outline-none" 
                                   placeholder="e.g. MARCUS">
                        </div>
                    </div>

                    <!-- Last Name -->
                    <div class="space-y-2 group/input stagger-field" style="animation-delay: 0.2s">
                        <label for="lastname" class="block text-xs font-bold text-purple-400/80 uppercase tracking-widest px-1">Surname Identity</label>
                        <div class="relative">
                            <i class="fas fa-signature absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-purple-500 transition-colors"></i>
                            <input type="text" id="lastname" name="lastname" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white placeholder-gray-700 focus:border-purple-500/50 focus:ring-4 focus:ring-purple-500/10 transition-all duration-300 outline-none" 
                                   placeholder="e.g. AURELIUS">
                        </div>
                    </div>

                    <!-- Email -->
                    <div class="space-y-2 group/input stagger-field col-span-full" style="animation-delay: 0.3s">
                        <label for="email" class="block text-xs font-bold text-blue-400/80 uppercase tracking-widest px-1">Network Communication Hub (Email)</label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-blue-500 transition-colors"></i>
                            <input type="email" id="email" name="email" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white placeholder-gray-700 focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/10 transition-all duration-300 outline-none" 
                                   placeholder="coach.alpha@fitsense.tech">
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="space-y-2 group/input stagger-field" style="animation-delay: 0.4s">
                        <label for="password" class="block text-xs font-bold text-red-400/80 uppercase tracking-widest px-1">Encription Key (Password)</label>
                        <div class="relative">
                            <i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-red-500 transition-colors"></i>
                            <input type="password" id="password" name="password" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white placeholder-gray-700 focus:border-red-500/50 focus:ring-4 focus:ring-red-500/10 transition-all duration-300 outline-none" 
                                   placeholder="••••••••">
                        </div>
                    </div>

                    <!-- Account Status -->
                    <div class="space-y-2 group/input stagger-field" style="animation-delay: 0.5s">
                        <label for="accountStatus" class="block text-xs font-bold text-green-400/80 uppercase tracking-widest px-1">Deployment Status</label>
                        <div class="relative">
                            <i class="fas fa-power-off absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-green-500 transition-colors"></i>
                            <select id="accountStatus" name="accountStatus" 
                                    class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white focus:border-green-500/50 focus:ring-4 focus:ring-green-500/10 transition-all duration-300 outline-none appearance-none">
                                <option value="" class="bg-gray-900">SELECT STATE...</option>
                                <option value="active" class="bg-gray-900">GO LIVE (ACTIVE)</option>
                                <option value="inactive" class="bg-gray-900">STANDBY (INACTIVE)</option>
                            </select>
                            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-600 pointer-events-none"></i>
                        </div>
                    </div>
                </div>

                <!-- Form Footer Buttons -->
                <div class="flex flex-col md:flex-row justify-end gap-4 mt-12 pt-8 border-t border-white/5 stagger-field" style="animation-delay: 0.6s">
                    <button type="button" id="cancelAddCoach" class="px-8 py-4 bg-white/5 text-gray-400 rounded-2xl hover:bg-white/10 hover:text-white transition-all duration-300 font-bold uppercase tracking-widest text-xs border border-white/5">
                        Abort Mission
                    </button>
                    <button type="submit" class="relative group/submit-btn px-10 py-4 bg-gradient-to-r from-purple-500 to-blue-500 text-white rounded-2xl font-black uppercase tracking-widest text-xs shadow-xl shadow-purple-500/20 hover:shadow-purple-500/40 hover:scale-105 active:scale-95 transition-all duration-500 overflow-hidden">
                        <div class="absolute inset-0 bg-white/20 -translate-x-full group-hover/submit-btn:translate-x-0 transition-transform duration-500"></div>
                        <span class="relative flex items-center gap-2">
                            <i class="fas fa-rocket"></i> Activate Coach
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Edit User Modal -->
    <div id="editUserModal" class="modal fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[60] opacity-0 pointer-events-none transition-all duration-500 overflow-hidden">
        <div class="modal-content relative bg-[#1B1E26]/90 border border-blue-500/30 rounded-[2.5rem] shadow-[0_0_50px_rgba(56,189,248,0.2)] max-w-4xl w-[95%] max-h-[90vh] flex flex-col transform scale-95 transition-all duration-500 overflow-hidden">
            
            <!-- Modal Header -->
            <div class="relative p-8 border-b border-white/5 bg-gradient-to-r from-blue-500/10 to-transparent">
                <div class="absolute top-0 right-0 p-8">
                    <button id="closeEditUserModal" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-red-500/20 transition-all duration-300">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="flex items-center gap-4">
                    <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-blue-500 to-purple-500 flex items-center justify-center shadow-lg shadow-blue-500/30">
                        <i class="fas fa-user-edit text-white text-xl"></i>
                    </div>
                    <div>
                        <h3 class="text-2xl font-bold text-white tracking-tight">Sync User Entity</h3>
                        <p class="text-sm text-gray-400">Reconfiguring data parameters for subject</p>
                    </div>
                </div>
            </div>

            <!-- Modal Body (Scrollable) -->
            <form id="editUserForm" method="POST" class="flex-1 overflow-y-auto custom-scrollbar p-8" novalidate>
                <input type="hidden" id="edit_user_id" name="user_id">

                <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                    <!-- First Name -->
                    <div class="space-y-2 group/input stagger-field">
                        <label for="edit_firstname" class="block text-xs font-bold text-blue-400/80 uppercase tracking-widest px-1">Forename Signature</label>
                        <div class="relative">
                            <i class="fas fa-id-card absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-blue-500 transition-colors"></i>
                            <input type="text" id="edit_firstname" name="firstname" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/10 transition-all duration-300 outline-none">
                        </div>
                    </div>

                    <!-- Last Name -->
                    <div class="space-y-2 group/input stagger-field">
                        <label for="edit_lastname" class="block text-xs font-bold text-blue-400/80 uppercase tracking-widest px-1">Surname Identity</label>
                        <div class="relative">
                            <i class="fas fa-signature absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-blue-500 transition-colors"></i>
                            <input type="text" id="edit_lastname" name="lastname" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white focus:border-blue-500/50 focus:ring-4 focus:ring-blue-500/10 transition-all duration-300 outline-none">
                        </div>
                    </div>

                    <!-- Email (Full Width) -->
                    <div class="space-y-2 group/input stagger-field col-span-full">
                        <label for="edit_email" class="block text-xs font-bold text-purple-400/80 uppercase tracking-widest px-1">Communication Hub (Email)</label>
                        <div class="relative">
                            <i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-purple-500 transition-colors"></i>
                            <input type="email" id="edit_email" name="email" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white focus:border-purple-500/50 focus:ring-4 focus:ring-purple-500/10 transition-all duration-300 outline-none">
                        </div>
                    </div>

                    <!-- Password -->
                    <div class="space-y-2 group/input stagger-field">
                        <label for="edit_password" class="block text-xs font-bold text-red-400/80 uppercase tracking-widest px-1">Security Override (Password)</label>
                        <div class="relative">
                            <i class="fas fa-key absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-red-500 transition-colors"></i>
                            <input type="password" id="edit_password" name="password" 
                                   class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white placeholder-gray-700/50 focus:border-red-500/50 focus:ring-4 focus:ring-red-500/10 transition-all duration-300 outline-none" 
                                   placeholder="Leave blank to maintain state">
                        </div>
                    </div>

                    <!-- Role Selection -->
                    <div class="space-y-2 group/input stagger-field">
                        <label for="edit_role" class="block text-xs font-bold text-yellow-400/80 uppercase tracking-widest px-1">Authority Level</label>
                        <div class="relative">
                            <i class="fas fa-shield-alt absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-yellow-500 transition-colors"></i>
                            <select id="edit_role" name="role" 
                                    class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white focus:border-yellow-500/50 focus:ring-4 focus:ring-yellow-500/10 transition-all duration-300 outline-none appearance-none">
                                <option value="ROLE_USER" class="bg-gray-900">CITIZEN (USER)</option>
                                <option value="ROLE_COACH" class="bg-gray-900">OPERATIVE (COACH)</option>
                                <option value="ROLE_ADMIN" class="bg-gray-900">COMMANDER (ADMIN)</option>
                            </select>
                            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-600 pointer-events-none"></i>
                        </div>
                    </div>

                    <!-- Account Status (Full Width) -->
                    <div class="space-y-2 group/input stagger-field col-span-full">
                        <label for="edit_accountStatus" class="block text-xs font-bold text-green-400/80 uppercase tracking-widest px-1">Current Lifecycle Phase</label>
                        <div class="relative">
                            <i class="fas fa-sync-alt absolute left-4 top-1/2 -translate-y-1/2 text-gray-600 group-focus-within/input:text-green-500 transition-colors"></i>
                            <select id="edit_accountStatus" name="accountStatus" 
                                    class="w-full pl-12 pr-4 py-4 bg-gray-900/50 border border-white/10 rounded-2xl text-white focus:border-green-500/50 focus:ring-4 focus:ring-green-500/10 transition-all duration-300 outline-none appearance-none">
                                <option value="active" class="bg-gray-900">OPERATIONAL (ACTIVE)</option>
                                <option value="inactive" class="bg-gray-900">DECOMMISSIONED (INACTIVE)</option>
                            </select>
                            <i class="fas fa-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-gray-600 pointer-events-none"></i>
                        </div>
                    </div>
                </div>

                <!-- Form Footer Buttons -->
                <div class="flex flex-col md:flex-row justify-end gap-4 mt-12 pt-8 border-t border-white/5 stagger-field">
                    <button type="button" id="cancelEditUser" class="px-8 py-4 bg-white/5 text-gray-400 rounded-2xl hover:bg-white/10 hover:text-white transition-all duration-300 font-bold uppercase tracking-widest text-xs border border-white/5">
                        Cancel Sync
                    </button>
                    <button type="submit" class="relative group/submit-btn px-10 py-4 bg-gradient-to-r from-blue-500 to-purple-500 text-white rounded-2xl font-black uppercase tracking-widest text-xs shadow-xl shadow-blue-500/20 hover:shadow-blue-500/40 hover:scale-105 active:scale-95 transition-all duration-500 overflow-hidden">
                        <div class="absolute inset-0 bg-white/20 -translate-x-full group-hover/submit-btn:translate-x-0 transition-transform duration-500"></div>
                        <span class="relative flex items-center gap-2">
                            <i class="fas fa-save"></i> Commit Changes
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <span id="deleteUserUrlTemplate" data-url="{{ path('admin_users_delete', {id: 0}) }}" class="hidden"></span>
    <!-- Delete Confirmation Modal -->
    <div id="deleteUserModal" class="modal fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[60] opacity-0 pointer-events-none transition-all duration-500 overflow-hidden">
        <div class="modal-content relative bg-[#1B1E26]/90 border border-red-500/30 rounded-2xl shadow-2xl max-w-md w-full mx-4 border border-gray-700 transform scale-95 transition-all duration-500 overflow-hidden">
            <div class="flex items-center justify-between p-6 border-b border-white/5 bg-gradient-to-r from-red-500/10 to-transparent">
                <h3 class="text-2xl font-bold text-white">Delete User</h3>
                <button type="button" id="closeDeleteUserModal" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-red-500/20 transition-all duration-300">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="p-6">
                <div class="bg-red-500/20 rounded-xl p-4 mb-4 border border-red-500/40">
                    <p class="text-gray-300">Are you sure you want to delete this user?</p>
                    <p class="mt-2 font-semibold text-white" id="deleteUserName"></p>
                </div>
                <p class="text-sm text-red-400 flex items-center gap-2 mb-6">
                    <i class="fas fa-exclamation-triangle"></i>
                    This action cannot be undone. The user will be permanently removed from the database.
                </p>

                <form id="deleteUserForm" method="POST" action="" class="flex justify-end gap-4">
                    <input type="hidden" name="_token" value="{{ csrf_token('admin_user_delete') }}">
                    <button type="button" id="cancelDeleteUser" class="px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold border border-gray-600">Cancel</button>
                    <button type="submit" class="px-6 py-3 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl hover:from-red-600 hover:to-red-700 transition font-semibold shadow-lg hover:shadow-red-500/50">
                        <i class="fas fa-trash mr-2"></i> Confirm Delete
                    </button>
                </form>
            </div>
        </div>
    </div>

    <!-- Bulk Delete Confirmation Modal -->
    <div id="bulkDeleteModal" class="modal fixed inset-0 bg-black/80 backdrop-blur-md flex items-center justify-center z-[60] opacity-0 pointer-events-none transition-all duration-500 overflow-hidden">
        <div class="modal-content relative bg-[#1B1E26]/90 border border-red-500/30 rounded-2xl shadow-2xl max-w-md w-full mx-4 border border-gray-700 transform scale-95 transition-all duration-500 overflow-hidden">
            <div class="flex items-center justify-between p-6 border-b border-white/5 bg-gradient-to-r from-red-500/10 to-transparent">
                <h3 class="text-2xl font-bold text-white">Bulk Delete</h3>
                <button type="button" id="closeBulkDeleteModal" class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center text-gray-400 hover:text-white hover:bg-red-500/20 transition-all duration-300">
                    <i class="fas fa-times"></i>
                </button>
            </div>

            <div class="p-6">
                <div class="bg-red-500/20 rounded-xl p-4 mb-4 border border-red-500/40">
                    <p class="text-gray-300">Are you sure you want to delete these <span id="modalSelectedCount" class="font-bold text-white">0</span> selected user(s)?</p>
                </div>
                <p class="text-sm text-red-400 flex items-center gap-2 mb-6">
                    <i class="fas fa-exclamation-triangle"></i>
                    This action cannot be undone. All selected records will be erased.
                </p>

                <div class="flex justify-end gap-4">
                    <button type="button" id="cancelBulkDelete" class="px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold border border-gray-600">Abort</button>
                    <button type="button" id="confirmBulkDelete" class="px-6 py-3 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl hover:from-red-600 hover:to-red-700 transition font-semibold shadow-lg hover:shadow-red-500/50">
                        <i class="fas fa-trash-alt mr-2"></i> Wipe Selected
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- JavaScript -->
    <script>
        document.addEventListener('DOMContentLoaded', function () {

            // Flash messages fade out
            document.querySelectorAll('.mb-6').forEach(flash => {
                setTimeout(() => {
                    flash.style.transition = 'opacity 0.5s ease';
                    flash.style.opacity = '0';
                    setTimeout(() => flash.remove(), 500);
                }, 5000);
            });

            const bulkDeleteBtn  = document.getElementById('bulkDeleteBtn');
            const selectAllCheck = document.getElementById('selectAllUsers');
            const selectedCount  = document.getElementById('selectedCount');
            const bulkDeleteForm = document.getElementById('bulkDeleteForm');
            
            // Bulk Delete Modal Elements
            const bulkDeleteModal      = document.getElementById('bulkDeleteModal');
            const modalSelectedCount   = document.getElementById('modalSelectedCount');
            const confirmBulkDeleteBtn = document.getElementById('confirmBulkDelete');
            const cancelBulkDeleteBtn  = document.getElementById('cancelBulkDelete');
            const closeBulkDeleteBtn   = document.getElementById('closeBulkDeleteModal');

            const searchInput   = document.getElementById('searchUsers');
            const filterStatus  = document.getElementById('filterStatus');
            const filterRole    = document.getElementById('filterRole');
            const clearButton   = document.getElementById('clearSearch');
            const searchResults = document.getElementById('searchResults');
            const tableBody     = document.querySelector('tbody');

            function updateBulkDeleteState() {
                const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
                selectedCount.textContent = checkedCount;
                
                if (checkedCount > 0) {
                    bulkDeleteBtn.classList.remove('hidden');
                } else {
                    bulkDeleteBtn.classList.add('hidden');
                }

                const totalCheckboxes = document.querySelectorAll('.user-checkbox').length;
                selectAllCheck.checked = totalCheckboxes > 0 && checkedCount === totalCheckboxes;
            }

            // Delegation for checkboxes since they are added via AJAX
            tableBody.addEventListener('change', (e) => {
                if (e.target.classList.contains('user-checkbox')) {
                    updateBulkDeleteState();
                }
            });

            selectAllCheck?.addEventListener('change', function() {
                document.querySelectorAll('.user-checkbox').forEach(cb => {
                    cb.checked = this.checked;
                });
                updateBulkDeleteState();
            });

            bulkDeleteBtn?.addEventListener('click', function() {
                const checkedCount = document.querySelectorAll('.user-checkbox:checked').length;
                modalSelectedCount.textContent = checkedCount;
                openModal(bulkDeleteModal);
            });

            confirmBulkDeleteBtn?.addEventListener('click', () => {
                bulkDeleteForm.submit();
            });

            closeBulkDeleteBtn?.addEventListener('click', () => closeModal(bulkDeleteModal));
            cancelBulkDeleteBtn?.addEventListener('click', () => closeModal(bulkDeleteModal));
            bulkDeleteModal?.addEventListener('click', e => { if (e.target === bulkDeleteModal) closeModal(bulkDeleteModal); });

            let timeout = null;

            // ────────────────────────────────────────────────
            //   AJAX filtering
            // ────────────────────────────────────────────────
            function ajaxFilter() {
                const q = searchInput.value;
                const status = filterStatus.value;
                const role = filterRole.value;

                tableBody.style.opacity = '0.5';

                const url = new URL('{{ path('admin_users_index') }}', window.location.origin);
                if (q) url.searchParams.set('q', q);
                if (status) url.searchParams.set('status', status);
                if (role) url.searchParams.set('role', role);
                url.searchParams.set('ajax', '1');

                fetch(url, {
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => response.text())
                .then(html => {
                    tableBody.innerHTML = html;
                    tableBody.style.opacity = '1';
                    
                    const visibleCount = tableBody.querySelectorAll('.table-row').length;
                    if (q || status || role) {
                        searchResults.innerHTML = `<i class="fas fa-search mr-2"></i>Showing ${visibleCount} user(s)`;
                    } else {
                        searchResults.textContent = '';
                    }

                    initModalButtons(); // Re-initialize edit/delete buttons
                    updateBulkDeleteState(); // Reset selection state
                })
                .catch(error => {
                    console.error('Error fetching users:', error);
                    tableBody.style.opacity = '1';
                });
            }

            searchInput.addEventListener('input', () => {
                clearTimeout(timeout);
                timeout = setTimeout(ajaxFilter, 300);
            });
            filterStatus.addEventListener('change', ajaxFilter);
            filterRole.addEventListener('change', ajaxFilter);

            clearButton?.addEventListener('click', () => {
                searchInput.value = '';
                filterStatus.value = '';
                filterRole.value = '';
                ajaxFilter();
                searchInput.focus();
            });

            // ────────────────────────────────────────────────
            //   Modal helpers
            // ────────────────────────────────────────────────
            function openModal(modal) {
                if (!modal) return;
                modal.classList.remove('pointer-events-none', 'opacity-0');
                modal.classList.add('active');
                const content = modal.querySelector('.modal-content');
                if (content) content.classList.remove('scale-95', 'opacity-0');
                document.body.style.overflow = 'hidden';
            }

            function closeModal(modal) {
                if (!modal) return;
                modal.classList.add('opacity-0', 'pointer-events-none');
                modal.classList.remove('active');
                const content = modal.querySelector('.modal-content');
                if (content) content.classList.add('scale-95', 'opacity-0');
                document.body.style.overflow = '';
            }

            // ────────────────────────────────────────────────
            //   Add Coach Modal
            // ────────────────────────────────────────────────
            const addModal      = document.getElementById('addCoachModal');
            const openAddBtn    = document.getElementById('openAddCoachModal');
            const closeAddBtn   = document.getElementById('closeAddCoachModal');
            const cancelAddBtn  = document.getElementById('cancelAddCoach');

            openAddBtn?.addEventListener('click', () => openModal(addModal));
            closeAddBtn?.addEventListener('click', () => closeModal(addModal));
            cancelAddBtn?.addEventListener('click', () => closeModal(addModal));
            addModal?.addEventListener('click', e => { if (e.target === addModal) closeModal(addModal); });

            // ────────────────────────────────────────────────
            //   Edit & Delete Modals Initialization
            // ────────────────────────────────────────────────
            const editModal     = document.getElementById('editUserModal');
            const deleteModal   = document.getElementById('deleteUserModal');
            const editForm      = document.getElementById('editUserForm');
            const deleteForm     = document.getElementById('deleteUserForm');

            function initModalButtons() {
                // Edit buttons
                document.querySelectorAll('.edit-user-btn').forEach(btn => {
                    btn.onclick = function () {
                        const data = {
                            id:        this.dataset.userId,
                            firstname: this.dataset.userFirstname,
                            lastname:  this.dataset.userLastname,
                            email:     this.dataset.userEmail,
                            status:    this.dataset.userStatus,
                            roles:     this.dataset.userRoles
                        };

                        document.getElementById('edit_user_id').value       = data.id;
                        document.getElementById('edit_firstname').value     = data.firstname;
                        document.getElementById('edit_lastname').value      = data.lastname;
                        document.getElementById('edit_email').value         = data.email;
                        document.getElementById('edit_accountStatus').value = data.status;
                        document.getElementById('edit_password').value      = '';

                        let primaryRole = 'ROLE_USER';
                        try {
                            const roles = JSON.parse(data.roles);
                            primaryRole = roles.find(r => r !== 'ROLE_USER') || 'ROLE_USER';
                        } catch (e) {
                            console.warn('Invalid roles format', data.roles);
                        }
                        document.getElementById('edit_role').value = primaryRole;

                        editForm.action = `/admin/users/edit/${data.id}`;
                        openModal(editModal);
                    };
                });

                // Delete buttons: show confirmation modal, then POST to delete route on confirm
                const deleteUrlTemplate = document.getElementById('deleteUserUrlTemplate').dataset.url;
                document.querySelectorAll('.delete-user-btn').forEach(btn => {
                    btn.onclick = function (e) {
                        e.preventDefault();
                        const userId = this.dataset.userId;
                        const userName = this.dataset.userName || ('User #' + userId);
                        document.getElementById('deleteUserName').textContent = userName;
                        deleteForm.action = deleteUrlTemplate.replace(/\/0$/, '/' + userId);
                        openModal(deleteModal);
                    };
                });
            }

            initModalButtons();

            // Modal closers
            document.getElementById('closeEditUserModal')?.addEventListener('click', () => closeModal(editModal));
            document.getElementById('cancelEditUser')?.addEventListener('click', () => closeModal(editModal));
            editModal?.addEventListener('click', e => { if (e.target === editModal) closeModal(editModal); });

            document.getElementById('closeDeleteUserModal')?.addEventListener('click', () => closeModal(deleteModal));
            document.getElementById('cancelDeleteUser')?.addEventListener('click', () => closeModal(deleteModal));
            deleteModal?.addEventListener('click', e => { if (e.target === deleteModal) closeModal(deleteModal); });

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    closeModal(addModal);
                    closeModal(editModal);
                    closeModal(deleteModal);
                    closeModal(bulkDeleteModal);
                }
            });
        });
    </script>

{% endblock %}