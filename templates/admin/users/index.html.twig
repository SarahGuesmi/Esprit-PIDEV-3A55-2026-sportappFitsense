{% extends 'admin/base_admin.html.twig' %}

{% block admin_content %}

<!-- Flash Messages -->
{% for label, messages in app.flashes %}
    <div class="mb-6 px-6 py-4 rounded-xl {% if label == 'success' %}bg-green-500/20 border border-green-500/40 text-green-300{% else %}bg-red-500/20 border border-red-500/40 text-red-300{% endif %} backdrop-blur">
        {% for message in messages %}
            <div class="flex items-center">
                <i class="fas {% if label == 'success' %}fa-check-circle{% else %}fa-exclamation-circle{% endif %} mr-3"></i>
                <span>{{ message }}</span>
            </div>
        {% endfor %}
    </div>
{% endfor %}

<div class="space-y-6">
    <!-- Header -->
    <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl p-8 border border-gray-700">
        <!-- Purple accent corner -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-purple-500/20 to-transparent rounded-full blur-3xl"></div>
        <div class="absolute bottom-0 left-0 w-64 h-64 bg-gradient-to-tr from-blue-500/20 to-transparent rounded-full blur-3xl"></div>
        
        <div class="relative flex justify-between items-center">
            <div>
                <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                    <div class="w-1.5 h-10 bg-gradient-to-b from-purple-400 to-blue-400 rounded-full"></div>
                    User Management
                </h1>
                <p class="text-gray-400 ml-6">Browse and manage all users in the system</p>
            </div>
            <button id="openAddCoachModal" class="bg-gradient-to-r from-purple-500 to-blue-500 text-white px-6 py-3 rounded-xl font-semibold hover:from-purple-600 hover:to-blue-600 transition-all duration-300 flex items-center gap-2 shadow-lg hover:shadow-purple-500/50 hover:transform hover:scale-105">
                <i class="fas fa-plus"></i>
                Add Coach
            </button>
        </div>
    </div>

    <!-- Search Section -->
    <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl p-6 border border-gray-700">
        <!-- Purple accent corner -->
        <div class="absolute -top-10 -right-10 w-40 h-40 bg-purple-500/30 rounded-full blur-3xl"></div>
        
        <div class="relative flex flex-col md:flex-row gap-4">
            <div class="flex-1">
                <label for="searchUsers" class="block text-sm font-medium text-gray-300 mb-2">Search Users</label>
                <div class="relative group">
                    <div class="absolute inset-y-0 left-0 pl-4 flex items-center pointer-events-none">
                        <i class="fas fa-search text-gray-500 group-focus-within:text-purple-400 transition"></i>
                    </div>
                    <input 
                        type="text" 
                        id="searchUsers" 
                        class="block w-full pl-12 pr-4 py-3.5 bg-gray-900/80 backdrop-blur border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:border-purple-500 focus:outline-none focus:ring-2 focus:ring-purple-500/30 transition"
                        placeholder="Search by name or email..."
                    >
                </div>
            </div>
            <div class="pt-7">
                <button id="clearSearch" class="px-6 py-3.5 bg-gray-900/80 backdrop-blur border border-gray-700 rounded-xl text-gray-300 hover:text-white hover:border-purple-500 transition font-medium">
                    Clear
                </button>
            </div>
        </div>
        <div id="searchResults" class="relative mt-3 text-sm text-gray-400"></div>
    </div>

    <!-- Users Table -->
    <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl border border-gray-700">
        <!-- Purple accent corners -->
        <div class="absolute top-0 right-0 w-96 h-96 bg-gradient-to-bl from-purple-500/10 to-transparent rounded-full blur-3xl pointer-events-none"></div>
        <div class="absolute bottom-0 left-0 w-96 h-96 bg-gradient-to-tr from-blue-500/10 to-transparent rounded-full blur-3xl pointer-events-none"></div>
        
        <div class="relative p-6 border-b border-gray-700/50">
            <h2 class="text-xl font-semibold text-white flex items-center gap-3">
                <div class="w-1 h-6 bg-gradient-to-b from-purple-400 to-blue-400 rounded-full"></div>
                Users Table
            </h2>
        </div>

        <div class="relative overflow-x-auto">
            <table class="min-w-full divide-y divide-gray-700/50">
                <thead class="bg-gray-900/50 backdrop-blur">
                    <tr>
                        <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-user text-purple-400"></i>
                                Author
                            </div>
                        </th>
                        <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-briefcase text-purple-400"></i>
                                Function
                            </div>
                        </th>
                        <th class="px-6 py-5 text-left text-xs font-bold text-gray-300 uppercase tracking-wider">
                            <div class="flex items-center gap-2">
                                <i class="fas fa-calendar text-purple-400"></i>
                                Employed
                            </div>
                        </th>
                        <th class="px-6 py-5 text-right text-xs font-bold text-gray-300 uppercase tracking-wider">Action</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-700/50 backdrop-blur">
                    {% for user in users %}
                        <tr class="table-row hover:bg-purple-500/5 transition-all duration-200 group">
                            <td class="px-6 py-5 whitespace-nowrap">
                                <div class="flex items-center">
                                    <div class="flex-shrink-0 h-11 w-11">
                                        <img class="h-11 w-11 rounded-xl ring-2 ring-purple-500/30 group-hover:ring-purple-500/50 transition"
                                             src="https://ui-avatars.com/api/?name={{ user.firstname }}+{{ user.lastname }}&background=7c3aed&color=fff"
                                             alt="{{ user.firstname }} {{ user.lastname }}">
                                    </div>
                                    <div class="ml-4">
                                        <div class="text-sm font-semibold text-white group-hover:text-purple-300 transition">
                                            {{ user.firstname }} {{ user.lastname }}
                                        </div>
                                        <div class="text-sm text-gray-400">
                                            {{ user.email }}
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap">
                                <span class="px-3 py-1.5 inline-flex text-xs leading-5 font-semibold rounded-lg bg-gradient-to-r from-purple-500/20 to-blue-500/20 text-purple-300 border border-purple-500/40 backdrop-blur">
                                    {{ user.roles|join(', ') }}
                                </span>
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap text-sm text-gray-300">
                                <div class="flex items-center gap-2">
                                    <i class="fas fa-clock text-gray-500 text-xs"></i>
                                    {{ user.dateCreation ? user.dateCreation|date('d/m/Y') : '—' }}
                                </div>
                            </td>
                            <td class="px-6 py-5 whitespace-nowrap text-right text-sm font-medium">
                                <div class="flex justify-end gap-2">
                                    <button 
                                        class="edit-user-btn bg-purple-500/20 hover:bg-purple-500/30 text-purple-300 px-4 py-2 rounded-lg transition-all duration-200 flex items-center gap-2 border border-purple-500/40 hover:border-purple-500/60 hover:shadow-lg hover:shadow-purple-500/20"
                                        data-user-id="{{ user.id }}"
                                        data-user-firstname="{{ user.firstname }}"
                                        data-user-lastname="{{ user.lastname }}"
                                        data-user-email="{{ user.email }}"
                                        data-user-status="{{ user.accountStatus }}"
                                        data-user-roles="{{ user.roles|json_encode }}"
                                    >
                                        <i class="fas fa-edit"></i>
                                        <span class="hidden md:inline">Edit</span>
                                    </button>
                                    <button 
                                        class="delete-user-btn bg-red-500/20 hover:bg-red-500/30 text-red-300 px-4 py-2 rounded-lg transition-all duration-200 flex items-center gap-2 border border-red-500/40 hover:border-red-500/60 hover:shadow-lg hover:shadow-red-500/20"
                                        data-user-id="{{ user.id }}"
                                        data-user-name="{{ user.firstname }} {{ user.lastname }}"
                                    >
                                        <i class="fas fa-trash"></i>
                                        <span class="hidden md:inline">Delete</span>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="4" class="px-6 py-20 text-center">
                                <div class="flex flex-col items-center justify-center">
                                    <div class="bg-gradient-to-br from-purple-500/10 to-blue-500/10 backdrop-blur rounded-2xl p-8 mb-4 border border-gray-700">
                                        <i class="fas fa-users text-gray-500 text-5xl"></i>
                                    </div>
                                    <h3 class="text-xl font-semibold text-gray-300 mb-2">No users found</h3>
                                    <p class="text-gray-500">No users registered yet</p>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>

<!-- Add Coach Modal -->
<div id="addCoachModal" class="modal">
    <div class="modal-content max-w-2xl">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold text-white">Add New Coach</h3>
            <button id="closeAddCoachModal" class="text-gray-400 hover:text-purple-400 text-2xl transition">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <form id="addCoachForm" action="{{ path('admin_users_add_coach') }}" method="POST">
            <div class="space-y-4">
                <!-- First Name -->
                <div>
                    <label for="firstname" class="block text-sm font-medium text-gray-300 mb-2">First Name *</label>
                    <input 
                        type="text" 
                        id="firstname" 
                        name="firstname" 
                        required
                        pattern="[a-zA-Z]+"
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="Enter first name"
                    >
                    <p class="mt-1 text-sm text-gray-400">Letters only, no numbers</p>
                </div>

                <!-- Last Name -->
                <div>
                    <label for="lastname" class="block text-sm font-medium text-gray-300 mb-2">Last Name *</label>
                    <input 
                        type="text" 
                        id="lastname" 
                        name="lastname" 
                        required
                        pattern="[a-zA-Z]+"
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="Enter last name"
                    >
                    <p class="mt-1 text-sm text-gray-400">Letters only, no numbers</p>
                </div>

                <!-- Email -->
                <div>
                    <label for="email" class="block text-sm font-medium text-gray-300 mb-2">Email *</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        required
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="coach@example.com"
                    >
                </div>

                <!-- Password -->
                <div>
                    <label for="password" class="block text-sm font-medium text-gray-300 mb-2">Password *</label>
                    <input 
                        type="password" 
                        id="password" 
                        name="password" 
                        required
                        minlength="6"
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="Minimum 6 characters"
                    >
                    <p class="mt-1 text-sm text-gray-400">Minimum 6 characters</p>
                </div>

                <!-- Account Status -->
                <div>
                    <label for="accountStatus" class="block text-sm font-medium text-gray-300 mb-2">Account Status *</label>
                    <select 
                        id="accountStatus" 
                        name="accountStatus" 
                        required
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                    >
                        <option value="">Select status...</option>
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="pending">Pending</option>
                    </select>
                </div>
            </div>

            <div class="flex justify-end gap-4 mt-8">
                <button type="button" id="cancelAddCoach" class="px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold border border-gray-600">
                    Cancel
                </button>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-purple-500 to-blue-500 text-white rounded-xl hover:from-purple-600 hover:to-blue-600 transition font-semibold shadow-lg hover:shadow-purple-500/50">
                    <i class="fas fa-plus mr-2"></i>
                    Create Coach
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Edit User Modal -->
<div id="editUserModal" class="modal">
    <div class="modal-content max-w-2xl">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold text-white">Edit User</h3>
            <button id="closeEditUserModal" class="text-gray-400 hover:text-purple-400 text-2xl transition">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <form id="editUserForm" method="POST">
            <input type="hidden" id="edit_user_id" name="user_id">
            
            <div class="space-y-4">
                <!-- First Name -->
                <div>
                    <label for="edit_firstname" class="block text-sm font-medium text-gray-300 mb-2">First Name *</label>
                    <input 
                        type="text" 
                        id="edit_firstname" 
                        name="firstname" 
                        required
                        pattern="[a-zA-Z]+"
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="Enter first name"
                    >
                </div>

                <!-- Last Name -->
                <div>
                    <label for="edit_lastname" class="block text-sm font-medium text-gray-300 mb-2">Last Name *</label>
                    <input 
                        type="text" 
                        id="edit_lastname" 
                        name="lastname" 
                        required
                        pattern="[a-zA-Z]+"
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="Enter last name"
                    >
                </div>

                <!-- Email -->
                <div>
                    <label for="edit_email" class="block text-sm font-medium text-gray-300 mb-2">Email *</label>
                    <input 
                        type="email" 
                        id="edit_email" 
                        name="email" 
                        required
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="user@example.com"
                    >
                </div>

                <!-- Password (Optional) -->
                <div>
                    <label for="edit_password" class="block text-sm font-medium text-gray-300 mb-2">Password</label>
                    <input 
                        type="password" 
                        id="edit_password" 
                        name="password" 
                        minlength="6"
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white placeholder-gray-500 focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                        placeholder="Leave blank to keep current password"
                    >
                    <p class="mt-1 text-sm text-gray-400">Leave blank to keep current password</p>
                </div>

                <!-- Account Status -->
                <div>
                    <label for="edit_accountStatus" class="block text-sm font-medium text-gray-300 mb-2">Account Status *</label>
                    <select 
                        id="edit_accountStatus" 
                        name="accountStatus" 
                        required
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                    >
                        <option value="active">Active</option>
                        <option value="inactive">Inactive</option>
                        <option value="pending">Pending</option>
                    </select>
                </div>

                <!-- Roles -->
                <div>
                    <label for="edit_role" class="block text-sm font-medium text-gray-300 mb-2">Role *</label>
                    <select 
                        id="edit_role" 
                        name="role" 
                        required
                        class="block w-full px-4 py-3 bg-gray-900 border border-gray-700 rounded-xl text-white focus:ring-2 focus:ring-purple-500 focus:border-purple-500 transition"
                    >
                        <option value="ROLE_USER">User</option>
                        <option value="ROLE_COACH">Coach</option>
                        <option value="ROLE_ADMIN">Admin</option>
                    </select>
                </div>
            </div>

            <div class="flex justify-end gap-4 mt-8">
                <button type="button" id="cancelEditUser" class="px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold border border-gray-600">
                    Cancel
                </button>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-purple-500 to-blue-500 text-white rounded-xl hover:from-purple-600 hover:to-blue-600 transition font-semibold shadow-lg hover:shadow-purple-500/50">
                    <i class="fas fa-save mr-2"></i>
                    Save Changes
                </button>
            </div>
        </form>
    </div>
</div>

<!-- Delete Confirmation Modal -->
<div id="deleteUserModal" class="modal">
    <div class="modal-content max-w-md">
        <div class="flex items-center justify-between mb-6">
            <h3 class="text-2xl font-bold text-white">Delete User</h3>
            <button id="closeDeleteUserModal" class="text-gray-400 hover:text-red-400 text-2xl transition">
                <i class="fas fa-times"></i>
            </button>
        </div>

        <div class="mb-6">
            <div class="bg-red-500/20 rounded-xl p-4 mb-4 border border-red-500/40">
                <p class="text-gray-300">Are you sure you want to delete this user?</p>
                <p class="mt-2 font-semibold text-white" id="deleteUserName"></p>
            </div>
            <p class="text-sm text-red-400 flex items-center gap-2">
                <i class="fas fa-exclamation-triangle"></i>
                This action cannot be undone.
            </p>
        </div>

        <form id="deleteUserForm" method="POST">
            <input type="hidden" id="delete_user_id" name="user_id">
            
            <div class="flex justify-end gap-4">
                <button type="button" id="cancelDeleteUser" class="px-6 py-3 bg-gray-700 text-white rounded-xl hover:bg-gray-600 transition font-semibold border border-gray-600">
                    Cancel
                </button>
                <button type="submit" class="px-6 py-3 bg-gradient-to-r from-red-500 to-red-600 text-white rounded-xl hover:from-red-600 hover:to-red-700 transition font-semibold shadow-lg hover:shadow-red-500/50">
                    <i class="fas fa-trash mr-2"></i>
                    Confirm Delete
                </button>
            </div>
        </form>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    // ===== Add Coach Modal Controls =====
    const addCoachModal = document.getElementById('addCoachModal');
    const openAddCoachBtn = document.getElementById('openAddCoachModal');
    const closeAddCoachBtn = document.getElementById('closeAddCoachModal');
    const cancelAddCoachBtn = document.getElementById('cancelAddCoach');

    function openAddCoachModal() {
        addCoachModal.style.display = 'flex';
        setTimeout(() => {
            addCoachModal.classList.add('active');
        }, 10);
    }

    function closeAddCoachModal() {
        addCoachModal.classList.remove('active');
        setTimeout(() => {
            addCoachModal.style.display = 'none';
        }, 300);
    }

    openAddCoachBtn.addEventListener('click', openAddCoachModal);
    closeAddCoachBtn.addEventListener('click', closeAddCoachModal);
    cancelAddCoachBtn.addEventListener('click', closeAddCoachModal);

    // Close on outside click
    addCoachModal.addEventListener('click', function(e) {
        if (e.target === addCoachModal) {
            closeAddCoachModal();
        }
    });

    // ===== Edit User Modal Controls =====
    const editUserModal = document.getElementById('editUserModal');
    const closeEditUserBtn = document.getElementById('closeEditUserModal');
    const cancelEditUserBtn = document.getElementById('cancelEditUser');
    const editUserForm = document.getElementById('editUserForm');
    const editUserBtns = document.querySelectorAll('.edit-user-btn');

    function openEditUserModal(userData) {
        // Populate form fields
        document.getElementById('edit_user_id').value = userData.id;
        document.getElementById('edit_firstname').value = userData.firstname;
        document.getElementById('edit_lastname').value = userData.lastname;
        document.getElementById('edit_email').value = userData.email;
        document.getElementById('edit_accountStatus').value = userData.status;
        document.getElementById('edit_password').value = ''; // Clear password field
        
        // Set role dropdown
        const roles = JSON.parse(userData.roles);
        const primaryRole = roles.find(r => r !== 'ROLE_USER') || 'ROLE_USER';
        document.getElementById('edit_role').value = primaryRole;
        
        // Set form action
        editUserForm.action = `/admin/users/edit/${userData.id}`;
        
        // Show modal
        editUserModal.style.display = 'flex';
        setTimeout(() => {
            editUserModal.classList.add('active');
        }, 10);
    }

    function closeEditUserModal() {
        editUserModal.classList.remove('active');
        setTimeout(() => {
            editUserModal.style.display = 'none';
        }, 300);
    }

    // Attach click handlers to all edit buttons
    editUserBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const userData = {
                id: this.dataset.userId,
                firstname: this.dataset.userFirstname,
                lastname: this.dataset.userLastname,
                email: this.dataset.userEmail,
                status: this.dataset.userStatus,
                roles: this.dataset.userRoles
            };
            openEditUserModal(userData);
        });
    });

    closeEditUserBtn.addEventListener('click', closeEditUserModal);
    cancelEditUserBtn.addEventListener('click', closeEditUserModal);

    // Close on outside click
    editUserModal.addEventListener('click', function(e) {
        if (e.target === editUserModal) {
            closeEditUserModal();
        }
    });

    // ===== Delete User Modal Controls =====
    const deleteUserModal = document.getElementById('deleteUserModal');
    const closeDeleteUserBtn = document.getElementById('closeDeleteUserModal');
    const cancelDeleteUserBtn = document.getElementById('cancelDeleteUser');
    const deleteUserForm = document.getElementById('deleteUserForm');
    const deleteUserBtns = document.querySelectorAll('.delete-user-btn');

    function openDeleteUserModal(userId, userName) {
        document.getElementById('delete_user_id').value = userId;
        document.getElementById('deleteUserName').textContent = userName;
        deleteUserForm.action = `/admin/users/delete/${userId}`;
        
        deleteUserModal.style.display = 'flex';
        setTimeout(() => {
            deleteUserModal.classList.add('active');
        }, 10);
    }

    function closeDeleteUserModal() {
        deleteUserModal.classList.remove('active');
        setTimeout(() => {
            deleteUserModal.style.display = 'none';
        }, 300);
    }

    // Attach click handlers to all delete buttons
    deleteUserBtns.forEach(btn => {
        btn.addEventListener('click', function() {
            const userId = this.dataset.userId;
            const userName = this.dataset.userName;
            openDeleteUserModal(userId, userName);
        });
    });

    closeDeleteUserBtn.addEventListener('click', closeDeleteUserModal);
    cancelDeleteUserBtn.addEventListener('click', closeDeleteUserModal);

    // Close on outside click
    deleteUserModal.addEventListener('click', function(e) {
        if (e.target === deleteUserModal) {
            closeDeleteUserModal();
        }
    });

    // Close all modals on Escape key
    document.addEventListener('keydown', function(e) {
        if (e.key === 'Escape') {
            if (addCoachModal.style.display !== 'none') {
                closeAddCoachModal();
            }
            if (editUserModal.style.display !== 'none') {
                closeEditUserModal();
            }
            if (deleteUserModal.style.display !== 'none') {
                closeDeleteUserModal();
            }
        }
    });

    // ===== Search Functionality =====
    const searchInput = document.getElementById('searchUsers');
    const clearButton = document.getElementById('clearSearch');
    const searchResults = document.getElementById('searchResults');
    const tableRows = document.querySelectorAll('tbody tr');
    
    function filterUsers() {
        const searchTerm = searchInput.value.toLowerCase().trim();
        let visibleCount = 0;
        
        tableRows.forEach(row => {
            // Skip the "no users found" row
            if (row.querySelector('td[colspan]')) {
                return;
            }
            
            const nameElement = row.querySelector('.text-sm.font-semibold.text-white');
            const emailElement = row.querySelector('.text-sm.text-gray-400');
            
            if (nameElement && emailElement) {
                const name = nameElement.textContent.toLowerCase();
                const email = emailElement.textContent.toLowerCase();
                
                if (name.includes(searchTerm) || email.includes(searchTerm)) {
                    row.style.display = '';
                    visibleCount++;
                } else {
                    row.style.display = 'none';
                }
            }
        });
        
        // Update search results text
        if (searchTerm) {
            searchResults.innerHTML = `<i class="fas fa-search mr-2"></i>Showing ${visibleCount} user(s) matching "${searchTerm}"`;
        } else {
            searchResults.textContent = '';
        }
    }
    
    // Event listeners
    searchInput.addEventListener('input', filterUsers);
    
    clearButton.addEventListener('click', function() {
        searchInput.value = '';
        filterUsers();
        searchInput.focus();
    });
    
    // Allow Enter key to trigger search (though it's already live)
    searchInput.addEventListener('keypress', function(e) {
        if (e.key === 'Enter') {
            e.preventDefault();
            filterUsers();
        }
    });
});
</script>
{% endblock %}
