{% extends 'admin/base_admin.html.twig' %}

{% block title %}FitSense - Notifications{% endblock %}

{% block admin_content %}
    <div class="space-y-6">
        <!-- Header Card -->
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl p-8 border border-gray-700">
            <div class="absolute top-0 right-0 w-64 h-64 bg-gradient-to-br from-purple-500/20 to-transparent rounded-full blur-3xl"></div>
            <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-500/20 to-transparent rounded-full blur-3xl"></div>

            <div class="relative">
                <h1 class="text-3xl font-bold text-white mb-2 flex items-center gap-3">
                    <div class="w-1.5 h-10 bg-gradient-to-b from-purple-400 to-blue-400 rounded-full"></div>
                    Notifications Center
                </h1>
                <p class="text-gray-400 ml-6">Track system events and new user registrations</p>
            </div>
        </div>

        <!-- Notifications List -->
        <div class="relative overflow-hidden bg-gradient-to-br from-gray-900 via-gray-800 to-gray-900 rounded-2xl shadow-2xl border border-gray-700">
            <div class="relative p-6 border-b border-gray-700/50 flex justify-between items-center bg-gray-900/50">
                <h2 class="text-xl font-semibold text-white flex items-center gap-3">
                    <div class="w-1 h-6 bg-gradient-to-b from-purple-400 to-blue-400 rounded-full"></div>
                    Recent Alerts
                </h2>
            </div>

            <div class="divide-y divide-gray-700/50">
                {% for notification in notifications %}
                    <div class="p-6 transition-all duration-300 hover:bg-gray-800/50 group {% if not notification.isRead %}bg-purple-500/5 border-l-4 border-purple-500{% endif %}">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-4">
                                <div class="w-12 h-12 rounded-xl flex items-center justify-center text-xl shadow-lg ring-1 ring-white/10
                                    {% if notification.type == 'registration' %}
                                        bg-blue-500/20 text-blue-400
                                    {% elseif notification.type == 'workout_creation' %}
                                        bg-green-500/20 text-green-400
                                    {% elseif notification.type == 'exercise_creation' %}
                                        bg-yellow-500/20 text-yellow-500
                                    {% else %}
                                        bg-purple-500/20 text-purple-400
                                    {% endif %}">
                                    
                                    {% if notification.type == 'registration' %}
                                        <i class="fas fa-user-plus"></i>
                                    {% elseif notification.type == 'workout_creation' %}
                                        <i class="fas fa-dumbbell"></i>
                                    {% elseif notification.type == 'exercise_creation' %}
                                        <i class="fas fa-running"></i>
                                    {% else %}
                                        <i class="fas fa-bell"></i>
                                    {% endif %}
                                </div>
                                <div>
                                    <h4 class="text-white font-bold text-lg group-hover:text-blue-400 transition">{{ notification.message }}</h4>
                                    <div class="flex items-center gap-3 mt-1">
                                        <span class="text-xs text-gray-500 font-medium">
                                            <i class="far fa-clock mr-1"></i> {{ notification.createdAt|date('d/M/Y H:i') }}
                                        </span>
                                        {% if notification.relatedUser %}
                                            <span class="text-xs text-gray-500">•</span>
                                            <a href="{{ path('admin_users_index') }}" class="text-xs text-purple-400 hover:underline">View Profile</a>
                                        {% endif %}
                                    </div>
                                </div>
                            </div>
                            
                            <div class="flex items-center gap-3">
                                {% if not notification.isRead %}
                                    <a href="{{ path('admin_notifications_mark_read', {'id': notification.id}) }}" class="px-4 py-2 bg-purple-500/10 hover:bg-purple-500/20 text-purple-400 text-xs font-bold rounded-lg border border-purple-500/30 transition shadow-lg">
                                        Mark as Read
                                    </a>
                                {% else %}
                                    <span class="px-4 py-2 bg-gray-800 text-gray-500 text-xs font-bold rounded-lg border border-gray-700">Read</span>
                                {% endif %}
                            </div>
                        </div>
                    </div>
                {% else %}
                    <div class="px-6 py-20 text-center">
                        <div class="flex flex-col items-center justify-center">
                            <div class="bg-gray-800/50 rounded-2xl p-8 mb-4 border border-gray-700">
                                <i class="fas fa-bell-slash text-gray-600 text-5xl"></i>
                            </div>
                            <h3 class="text-xl font-semibold text-gray-300 mb-2">No notifications</h3>
                            <p class="text-gray-500">Your inbox is clear! Check back later for new alerts.</p>
                        </div>
                    </div>
                {% endfor %}
            </div>
        </div>
    </div>
{% endblock %}
