<nav class="navbar sticky top-0 z-30 px-6 py-4 shadow-lg backdrop-blur-sm"
     style="background: linear-gradient(90deg, #1B1E26 0%, #262A35 100%); border-bottom: 1px solid #343846;">
  <div class="flex items-center justify-between w-full">

    <!-- Left -->
    <div class="flex items-center gap-4">
      <button class="lg:hidden text-gray-300 hover:text-white transition" id="mobileSidebarToggle" type="button">
        <i class="fas fa-bars text-xl"></i>
      </button>
      <div>
        <h2 class="text-xl font-semibold text-white">
          {% block page_title %}Admin Panel{% endblock %}
        </h2>
        <p class="text-sm text-gray-400 mt-0.5">
          {% block page_subtitle %}Manage your application{% endblock %}
        </p>
      </div>
    </div>

    <div class="flex-1"></div>

    <!-- Right -->
    <div class="flex items-center gap-8">

      {# ----- Notifications link depends on role ----- #}
      {% set isAdmin = is_granted('ROLE_ADMIN') %}
      {% set notifRoute = isAdmin ? 'admin_notifications' : 'user_notifications' %}
      {% set roleLabel = isAdmin ? 'Administrator' : 'Member' %}

      {# ✅ count selon role #}
      {% set unreadCount = isAdmin ? unread_notifications_count() : unread_user_nutrition_unread_count() %}

      {# ✅ notif bouton amélioré (comme collègue) #}
      <a href="{{ path(notifRoute) }}"
         class="relative p-2.5 text-gray-400 hover:text-white hover:bg-white/10 rounded-xl transition-all duration-300 group/nav-bell"
         title="View Notifications">
        <i class="fas fa-bell text-xl transition-transform group-hover/nav-bell:scale-110"></i>

        {# ✅ badge amélioré (9+ + ring + pulse) #}
        {% if unreadCount > 0 %}
          <span class="absolute top-1.5 right-1.5 min-w-[18px] h-[18px] px-1 bg-purple-500 text-white text-[10px] font-bold rounded-full flex items-center justify-center ring-2 ring-[#1B1E26] animate-pulse pointer-events-none">
            {{ unreadCount > 9 ? '9+' : unreadCount }}
          </span>
        {% endif %}
      </a>

      <!-- User Profile Dropdown -->
      <div class="relative group">
        <button type="button" class="flex items-center gap-4 px-4 py-2 rounded-xl hover:bg-gray-700/50 transition-all duration-200">
          <div class="text-right hidden sm:block">
            {% if app.user %}
              <p class="text-sm font-semibold text-white">{{ app.user.firstname }} {{ app.user.lastname }}</p>
            {% endif %}
            <p class="text-xs text-gray-400">{{ role_label|default(roleLabel) }}</p>
          </div>

          {# ✅ avatar image si existe (sinon initiales) #}
          {% if app.user and app.user.photoPath %}
            {% set avatarSrc = app.user.photoPath starts with 'http' ? app.user.photoPath : asset(app.user.photoPath) %}
            <img src="{{ avatarSrc }}" alt="Profile"
                 class="w-10 h-10 rounded-xl object-cover ring-2 ring-purple-500/30">
          {% else %}
            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center text-white font-bold shadow-lg ring-2 ring-purple-500/30">
              {% if app.user %}
                {{ app.user.firstname|slice(0, 1)|upper }}{{ app.user.lastname|slice(0, 1)|upper }}
              {% else %}
                U
              {% endif %}
            </div>
          {% endif %}
        </button>

        <div class="absolute right-0 mt-2 w-48 bg-gray-800 rounded-xl shadow-2xl border border-gray-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 overflow-hidden">

          {# ✅ vrais liens (comme collègue) #}
          <a href="{{ path('profile_edit') }}" class="flex items-center gap-3 px-4 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition">
            <i class="fas fa-user w-4"></i><span class="text-sm">Profile</span>
          </a>

          <a href="{{ path('profile_setup_height') }}" class="flex items-center gap-3 px-4 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition">
            <i class="fas fa-cog w-4"></i><span class="text-sm">Settings</span>
          </a>

          <div class="border-t border-gray-700"></div>

          <a href="#" class="logout-link flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-500/10 hover:text-red-300 transition">
            <i class="fas fa-sign-out-alt w-4"></i><span class="text-sm">Logout</span>
          </a>
        </div>
      </div>

    </div>
  </div>
</nav>

<style>
  /* Enhance dropdown hover behavior */
  .group:hover .group-hover\:opacity-100 {
    opacity: 1;
    visibility: visible;
  }
</style>