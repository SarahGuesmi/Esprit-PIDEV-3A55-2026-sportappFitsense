<nav class="navbar sticky top-0 z-30 px-6 py-4 shadow-lg backdrop-blur-sm" style="background: linear-gradient(90deg, #1B1E26 0%, #262A35 100%); border-bottom: 1px solid #343846;">
    <div class="flex items-center justify-between w-full">
        <!-- Left side - Breadcrumb or Title -->
        <div class="flex items-center gap-4">
            <button class="lg:hidden text-gray-300 hover:text-white transition" id="mobileSidebarToggle">
                <i class="fas fa-bars text-xl"></i>
            </button>
            <div>
                <h2 class="text-xl font-semibold text-white">
                    {% block page_title %}Admin Panel{% endblock %}
                </h2>
                <p class="text-sm text-gray-400 mt-0.5">
                    {% block page_subtitle %}Manage your application{% endblock %}
                </p>
            </div>
        </div>

        <!-- Spacer to push right content to the far right -->
        <div class="flex-1"></div>

        <!-- Right side - User Menu -->
        <div class="flex items-center gap-8">
            <!-- Notifications -->
            <button class="relative p-2 text-gray-400 hover:text-white hover:bg-gray-700/50 rounded-lg transition">
                <i class="fas fa-bell text-lg"></i>
                <span class="absolute top-1 right-1 w-2 h-2 bg-purple-500 rounded-full ring-2 ring-gray-800"></span>
            </button>

            <!-- User Profile Dropdown -->
            <div class="relative group">
                <button class="flex items-center gap-4 px-4 py-2 rounded-xl hover:bg-gray-700/50 transition-all duration-200">
                    <div class="text-right hidden sm:block">
                        <p class="text-sm font-semibold text-white">{{ app.user.firstname }} {{ app.user.lastname }}</p>
                        <p class="text-xs text-gray-400">Administrator</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500 to-blue-500 flex items-center justify-center text-white font-bold shadow-lg ring-2 ring-purple-500/30">
                        {{ app.user.firstname|slice(0, 1)|upper }}{{ app.user.lastname|slice(0, 1)|upper }}
                    </div>
                </button>

                <!-- Dropdown Menu -->
                <div class="absolute right-0 mt-2 w-48 bg-gray-800 rounded-xl shadow-2xl border border-gray-700 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200 overflow-hidden">
                    <a href="#" class="flex items-center gap-3 px-4 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition">
                        <i class="fas fa-user w-4"></i>
                        <span class="text-sm">Profile</span>
                    </a>
                    <a href="#" class="flex items-center gap-3 px-4 py-3 text-gray-300 hover:bg-gray-700 hover:text-white transition">
                        <i class="fas fa-cog w-4"></i>
                        <span class="text-sm">Settings</span>
                    </a>
                    <div class="border-t border-gray-700"></div>
                    <a href="#" class="logout-link flex items-center gap-3 px-4 py-3 text-red-400 hover:bg-red-500/10 hover:text-red-300 transition">
                        <i class="fas fa-sign-out-alt w-4"></i>
                        <span class="text-sm">Logout</span>
                    </a>
                </div>
            </div>
        </div>
    </div>
</nav>

<style>
    /* Enhance dropdown hover behavior */
    .group:hover .group-hover\:opacity-100 {
        opacity: 1;
        visibility: visible;
    }
</style>
