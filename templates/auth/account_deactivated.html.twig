{% extends 'base.html.twig' %}

{% block title %}Account deactivated - FitSense{% endblock %}

{% block stylesheets %}
{{ parent() }}
<style>
:root {
    --violet-primary: #8B5CF6;
    --violet-light: #A78BFA;
    --dark-bg: #030405;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --text-primary: #FFFFFF;
    --text-secondary: #94A3B8;
}
body { background: var(--dark-bg) !important; min-height: 100vh !important; display: flex !important; align-items: center !important; justify-content: center !important; padding: 24px !important; margin: 0 !important; }
footer { display: none !important; }
.deactivated-box {
    width: 100%;
    max-width: 440px;
    background: var(--glass-bg);
    backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 24px;
    padding: 2.5rem;
    box-shadow: 0 40px 100px rgba(0,0,0,0.5);
    text-align: center;
}
.deactivated-box h1 { font-size: 1.5rem; margin-bottom: 0.75rem; color: var(--text-primary); }
.deactivated-box p { color: var(--text-secondary); font-size: 0.95rem; line-height: 1.6; margin-bottom: 1rem; }
.deactivated-box .admin-email {
    display: inline-block;
    margin-top: 0.5rem;
    padding: 10px 18px;
    background: rgba(139, 92, 246, 0.15);
    border: 1px solid rgba(139, 92, 246, 0.3);
    border-radius: 12px;
    color: var(--violet-light);
    font-weight: 600;
    font-size: 0.95rem;
    word-break: break-all;
}
.deactivated-box a.btn-back {
    display: inline-block;
    margin-top: 1.5rem;
    padding: 14px 28px;
    background: linear-gradient(135deg, var(--violet-primary), #38BDF8);
    color: #fff;
    border-radius: 14px;
    font-weight: 600;
    text-decoration: none;
    transition: transform 0.2s, box-shadow 0.2s;
}
.deactivated-box a.btn-back:hover { transform: translateY(-2px); box-shadow: 0 8px 25px rgba(139,92,246,0.4); }
</style>
{% endblock %}

{% block header %}{% endblock %}
{% block body %}
<div class="deactivated-box">
    <h1>Account deactivated</h1>
    <p>Your account is deactivated. Contact the admin for more information.</p>
    {% if admin_email %}
        <p class="admin-email">{{ admin_email }}</p>
    {% else %}
        <p class="admin-email">Contact your administrator.</p>
    {% endif %}
    <a href="{{ path('auth_sign_in') }}" class="btn-back">Back to sign in</a>
</div>
{% endblock %}
{% block footer %}{% endblock %}
