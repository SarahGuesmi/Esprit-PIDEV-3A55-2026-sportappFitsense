{% extends 'base.html.twig' %}

{% block title %}Pick Your Identity - FitSense{% endblock %}

{% block stylesheets %}
<style>
:root {
    --violet-primary: #8B5CF6;
    --violet-light: #A78BFA;
    --violet-dark: #6D28D9;
    --dark-bg: #030405;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --text-primary: #FFFFFF;
    --text-secondary: #94A3B8;
    --gradient-main: linear-gradient(135deg, #8B5CF6, #D8B4FE);
}

body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--dark-bg);
    color: var(--text-primary);
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    position: relative;
    overflow-x: hidden;
}

body::before {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 80% 10%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 10% 90%, rgba(216, 180, 254, 0.1) 0%, transparent 40%);
    z-index: -1;
}

.setup-wrapper {
    width: 95%;
    max-width: 1000px;
    background: var(--glass-bg);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    overflow: hidden;
    padding: 60px;
    animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.setup-header {
    text-align: center;
    margin-bottom: 50px;
}

.setup-header h1 {
    font-size: 38px;
    font-weight: 900;
    margin-bottom: 15px;
    background: var(--gradient-main);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    letter-spacing: -1px;
}

.setup-header p {
    color: var(--text-secondary);
    font-size: 16px;
    font-weight: 500;
}

/* Usernames Grid */
.usernames-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 20px;
    margin-bottom: 40px;
}

.username-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--glass-border);
    border-radius: 20px;
    padding: 30px 20px;
    text-align: center;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    position: relative;
    overflow: hidden;
}

.username-card::before {
    content: "";
    position: absolute;
    top: 0; left: 0; width: 100%; height: 100%;
    background: var(--gradient-main);
    opacity: 0;
    transition: opacity 0.4s ease;
    z-index: -1;
}

.username-card h3 {
    font-size: 18px;
    font-weight: 800;
    color: var(--text-primary);
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: transform 0.3s ease;
}

.username-card:hover {
    transform: translateY(-8px) scale(1.03);
    border-color: var(--violet-light);
    box-shadow: 0 15px 30px rgba(139, 92, 246, 0.2);
}

.username-card.selected {
    border-color: var(--violet-primary);
    background: rgba(139, 92, 246, 0.1);
    box-shadow: 0 0 40px rgba(139, 92, 246, 0.3);
}

.username-card.selected h3 {
    color: var(--violet-light);
    transform: scale(1.1);
}

/* Custom Input Area */
.custom-input-wrapper {
    background: rgba(0,0,0,0.2);
    border-radius: 20px;
    padding: 30px;
    border: 1px solid var(--glass-border);
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
}

.custom-input-label {
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--violet-light);
}

.input-field {
    width: 100%;
    max-width: 400px;
    padding: 16px 20px;
    border-radius: 12px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 600;
    text-align: center;
    transition: all 0.3s ease;
}

.input-field:focus {
    outline: none;
    border-color: var(--violet-primary);
    background: rgba(255,255,255,0.05);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
}

.btn-confirm {
    width: 100%;
    max-width: 400px;
    padding: 18px;
    border-radius: 14px;
    border: none;
    background: var(--gradient-main);
    color: white;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.3);
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-confirm.active {
    opacity: 1;
    cursor: pointer;
}

.btn-confirm.active:hover {
    transform: translateY(-4px) scale(1.02);
    box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5);
}

/* AI Loading */
#loading-state {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 20px;
    padding: 60px 0;
}

.loader {
    width: 50px;
    height: 50px;
    border: 3px solid rgba(139, 92, 246, 0.1);
    border-top: 3px solid var(--violet-primary);
    border-radius: 50%;
    animation: spin 1s linear infinite;
}

@keyframes fadeInUp {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
}

@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
@keyframes pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }

.hidden { display: none !important; }

@media (max-width: 768px) {
    .setup-wrapper { padding: 40px 25px; }
    .setup-header h1 { font-size: 28px; }
    .usernames-grid { grid-template-columns: 1fr 1fr; }
}
</style>
{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<div class="setup-wrapper">
    <div class="setup-header">
        <h1>Claim Your Identity</h1>
        <p>Aura has brainstormed some unique handles for your fitness journey</p>
        <button id="regenerate-names" class="hidden" style="margin-top: 20px; background: none; border: 1px solid var(--violet-light); color: var(--violet-light); padding: 8px 16px; border-radius: 10px; font-size: 13px; font-weight: 700; cursor: pointer; transition: all 0.3s ease;">
            <i class="fa fa-sync-alt"></i> Regenerate Options
        </button>
    </div>

    <!-- AI Thinking State -->
    <div id="loading-state">
        <div class="loader"></div>
        <p style="color: var(--text-secondary); font-weight: 500; animation: pulse 1.5s infinite;">Aura is dreaming up your handle...</p>
    </div>

    <!-- Suggestions Container -->
    <div id="suggestions-container" class="usernames-grid hidden">
        <!-- Cards will be injected here -->
    </div>

    <!-- Custom Input & Action -->
    <div id="action-section" class="hidden">
        <div class="custom-input-wrapper">
            <span class="custom-input-label">Didn't like these? Create your own</span>
            <input type="text" id="custom-username" class="input-field" placeholder="Enter custom handle...">
            
            <button id="confirm-selection" class="btn-confirm" disabled>
                Confirm & Continue
            </button>
        </div>
        
        <p style="text-align: center; margin-top: 25px; font-size: 13px; color: var(--text-secondary); font-weight: 500;">
            <i class="fa fa-sparkles" style="color: var(--violet-light); margin-right: 5px;"></i>
            This will be your unique FitSense handle
        </p>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const loading = document.getElementById('loading-state');
    const container = document.getElementById('suggestions-container');
    const actionSection = document.getElementById('action-section');
    const confirmBtn = document.getElementById('confirm-selection');
    const customInput = document.getElementById('custom-username');
    const regenerateBtn = document.getElementById('regenerate-names');
    let selectedUsername = '';

    function updateConfirmState() {
        const val = customInput.value.trim();
        if (selectedUsername || val) {
            confirmBtn.disabled = false;
            confirmBtn.classList.add('active');
        } else {
            confirmBtn.disabled = true;
            confirmBtn.classList.remove('active');
        }
    }

    function fetchSuggestions() {
        // Show loading, hide others
        loading.classList.remove('hidden');
        container.classList.add('hidden');
        actionSection.classList.add('hidden');
        regenerateBtn.classList.add('hidden');
        container.innerHTML = '';
        selectedUsername = '';
        updateConfirmState();

        fetch('{{ path("username_suggest") }}')
            .then(r => {
                if (!r.ok) throw new Error('Failed to fetch suggestions');
                return r.json();
            })
            .then(data => {
                loading.classList.add('hidden');
                actionSection.classList.remove('hidden');
                regenerateBtn.classList.remove('hidden');

                if (data.usernames && data.usernames.length > 0) {
                    container.classList.remove('hidden');
                    data.usernames.forEach((name, index) => {
                        const card = document.createElement('div');
                        card.className = 'username-card';
                        card.style.animation = `fadeInUp 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards ${index * 0.1}s`;
                        card.style.opacity = '0';
                        card.innerHTML = `<h3>${name}</h3>`;

                        card.addEventListener('click', () => {
                            document.querySelectorAll('.username-card').forEach(c => c.classList.remove('selected'));
                            card.classList.add('selected');
                            selectedUsername = name;
                            customInput.value = ''; 
                            updateConfirmState();
                        });
                        container.appendChild(card);
                    });
                }
            })
            .catch(err => {
                loading.innerHTML = '<p style="color: #fda4af; font-weight: 700;">Aura is briefly offline. Please enter a handle manually.</p>';
                actionSection.classList.remove('hidden');
                regenerateBtn.classList.remove('hidden');
            });
    }

    // Initial load
    fetchSuggestions();

    regenerateBtn.addEventListener('click', fetchSuggestions);

    customInput.addEventListener('input', () => {
        if (customInput.value.trim()) {
            selectedUsername = '';
            document.querySelectorAll('.username-card').forEach(c => c.classList.remove('selected'));
        }
        updateConfirmState();
    });

    confirmBtn.addEventListener('click', () => {
        const username = selectedUsername || customInput.value.trim();
        if(!username) return;

        confirmBtn.disabled = true;
        confirmBtn.innerText = 'SAVING IDENTITY...';
        
        fetch('{{ path("username_set") }}', {
            method: 'POST',
            headers: {'Content-Type': 'application/json'},
            body: JSON.stringify({username: username})
        })
        .then(r => r.json())
        .then(d => {
            if(d.success) {
                window.location.href = '{{ path("profile_setup_height") }}';
            } else {
                alert(d.error || 'Failed to save identity');
                confirmBtn.disabled = false;
                confirmBtn.innerText = 'Confirm & Continue';
            }
        })
        .catch(() => {
            alert('Server error. Please try again.');
            confirmBtn.disabled = false;
            confirmBtn.innerText = 'Confirm & Continue';
        });
    });
});
</script>
{% endblock %}
{% block footer %}{% endblock %}
