{% extends 'base.html.twig' %}

{% block title %}Sign In - FitSense{% endblock %}

{% block stylesheets %}
<style>
:root {
    --violet-primary: #8B5CF6;
    --violet-light: #A78BFA;
    --violet-dark: #6D28D9;
    --dark-bg: #030405;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --text-primary: #FFFFFF;
    --text-secondary: #94A3B8;
    --gradient-main: linear-gradient(135deg, #8B5CF6, #D8B4FE);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--dark-bg);
    color: var(--text-primary);
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
}

/* Multi-layer Mesh Gradient Background */
body::before {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(216, 180, 254, 0.1) 0%, transparent 40%);
    z-index: -1;
}

.auth-wrapper {
    width: 95%;
    max-width: 1000px;
    min-height: 600px;
    max-height: 95vh;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    background: var(--glass-bg);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    overflow: hidden;
    animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.auth-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center; 
    text-align: center;
    padding: 60px;
    position: relative;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(216, 180, 254, 0.05));
    border-right: 1px solid var(--glass-border);
}

.auth-left::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 140%;
    height: 140%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(139, 92, 246, 0.05) 0%, transparent 70%);
    pointer-events: none;
}

.auth-left img.hero-img { 
    width: 280px; 
    margin-bottom: 35px; 
    filter: drop-shadow(0 20px 40px rgba(139, 92, 246, 0.3));
    animation: float 4s ease-in-out infinite; 
}

@keyframes float { 
    0%,100% { transform: translateY(0) rotate(0deg); } 
    50% { transform: translateY(-30px) rotate(2deg); } 
}

.auth-left h1 { 
    font-size: 38px; 
    font-weight: 900; 
    margin-bottom: 15px; 
    background: var(--gradient-main); 
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent; 
    letter-spacing: -1px;
}

.auth-left p { 
    font-size: 16px; 
    color: var(--text-secondary); 
    line-height: 1.6;
    max-width: 300px;
}

.auth-right { 
    padding: 60px; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    background: rgba(0,0,0,0.2);
    overflow-y: auto;
    max-height: 95vh;
}

.form-header h2 { 
    font-size: 36px; 
    font-weight: 800;
    margin-bottom: 8px; 
    letter-spacing: -1px;
}

.form-header p { 
    color: var(--text-secondary); 
    margin-bottom: 40px; 
    font-weight: 500;
}

.form-group { margin-bottom: 25px; position: relative; }

.form-group label {
    display: block;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--violet-light);
}

.form-group input {
    width: 100%;
    padding: 16px 20px;
    border-radius: 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 500;
    transition: all 0.3s ease;
}

.form-group input::placeholder { color: rgba(255,255,255,0.2); }

.form-group input:focus {
    outline: none;
    background: rgba(255,255,255,0.05);
    border-color: var(--violet-primary);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
    transform: translateY(-1px);
}

.btn-signin {
    margin-top: 15px;
    width: 100%;
    padding: 18px;
    border-radius: 14px;
    border: none;
    background: var(--gradient-main);
    color: white;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.3);
}

.btn-signin:hover { 
    transform: translateY(-4px) scale(1.02); 
    box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5); 
}

.btn-signin:active { transform: translateY(0); }

.signup-link { 
    text-align: center; 
    margin-top: 25px; 
    font-size: 15px; 
    color: var(--text-secondary);
}

.signup-link a { 
    color: var(--violet-light); 
    text-decoration: none; 
    font-weight: 800; 
    margin-left: 5px;
    transition: all 0.3s ease;
}

.signup-link a:hover { color: #fff; text-shadow: 0 0 10px var(--violet-light); }

.back-home {
    position: absolute;
    top: 30px;
    left: 30px;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 14px;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 10px 18px;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    transition: all 0.3s ease;
    z-index: 10;
}

.back-home:hover { 
    background: rgba(255,255,255,0.1); 
    border-color: var(--violet-light);
    transform: translateX(-5px);
}

.back-home svg { width: 18px; height: 18px; fill: var(--text-primary); transition: 0.3s; }
.back-home:hover svg { fill: var(--violet-light); }

.error-text { 
    color: #fda4af; 
    font-size: 14px; 
    font-weight: 600; 
    margin-top: 10px; 
    background: rgba(244, 63, 94, 0.1);
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(244, 63, 94, 0.2);
}

@media (max-width: 900px) {
    .auth-wrapper { grid-template-columns: 1fr; height: auto; min-height: auto; max-height: none; margin: 20px 0; }
    .auth-left { display: none; }
    body { overflow: auto; height: auto; padding: 20px 0; }
}
</style>
{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<div class="auth-wrapper">

    <!-- LEFT -->
    <div class="auth-left">
        <a href="{{ path('app_home') }}" class="back-home">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
            Home
        </a>

        <img src="/assets/images/sport-hero.png" class="hero-img" alt="Athlete">
        <h1>Push your limits</h1>
        <p>Feel the energy. Train smarter. Stay consistent.</p>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="form-header">
            <h2>Welcome Back</h2>
            <p>Sign in to continue your fitness journey</p>
        </div>

        {% set fieldErrors = {} %}
        {% if error %}
            {% set parts = error.messageKey|split('|') %}
            {% for part in parts %}
                {% set sub = part|split(':') %}
                {% if sub|length == 2 %}
                    {% set fieldErrors = fieldErrors|merge({ (sub[0]): sub[1] }) %}
                {% endif %}
            {% endfor %}
        {% endif %}

        <form id="loginForm" method="post" action="{{ path('auth_sign_in') }}" novalidate>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="{{ last_username }}" placeholder="Email" required>
                {% if fieldErrors.email is defined %}
                    <div class="error-text">{{ fieldErrors.email }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Password" required>
                {% if fieldErrors.password is defined %}
                    <div class="error-text">{{ fieldErrors.password }}</div>
                {% endif %}
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="button" id="btnFaceIdLogin" class="btn-signin">Login with Face ID</button>
            <p class="text-center text-sm mt-3" style="color: var(--text-secondary);">or sign in with email</p>
            <button type="submit" class="btn-signin" style="margin-top: 12px; background: rgba(255,255,255,0.08); border: 1px solid var(--glass-border);">Sign In with Password</button>
            <div class="mt-4 text-center text-sm">
                <a href="{{ path('app_forgot_password_request') }}"
                class="text-[#38BDF8] hover:text-[#A78BFA] font-medium transition">
                    Forgot your password?
                </a>
            </div>
        </form>

        {% if error and fieldErrors is empty %}
            <div class="error-text" style="justify-content: center; margin-top: 15px;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <div class="signup-link">
            You don't have an account? 
            <a href="{{ path('auth_sign_up') }}">Sign Up</a>
        </div>

        <!-- Face ID QR overlay -->
        <div id="faceIdOverlay" style="display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 1000; align-items: center; justify-content: center; flex-direction: column; padding: 24px;">
            <div style="background: var(--glass-bg); border: 1px solid var(--glass-border); border-radius: 24px; padding: 32px; text-align: center; max-width: 340px;">
                <h3 style="margin-bottom: 8px; font-size: 20px;">Scan with your phone</h3>
                <p style="color: var(--text-secondary); font-size: 14px; margin-bottom: 20px;">Open your camera or QR app and scan this code. Then use Face ID on your phone.</p>
                <div id="qrContainer" style="background: #fff; padding: 16px; border-radius: 16px; display: inline-block;">
                    <img id="qrImage" src="" alt="QR Code" width="220" height="220">
                </div>
                <p id="qrStatus" style="margin-top: 20px; font-size: 14px; color: var(--violet-light);">Waiting for scan…</p>
                <button type="button" id="btnCancelQr" style="margin-top: 20px; background: transparent; border: 1px solid var(--glass-border); color: var(--text-secondary); padding: 10px 24px; border-radius: 12px; cursor: pointer; font-size: 14px;">Cancel</button>
            </div>
        </div>

        </div>

        {# Security Block Modal #}
        {% if blocked_admin_email %}
            <div id="securityBlockOverlay" style="position: fixed; inset: 0; background: rgba(0,0,0,0.85); z-index: 2000; display: flex; align-items: center; justify-content: center; padding: 24px; backdrop-filter: blur(10px);">
                <div class="glass-card" style="max-width: 450px; padding: 40px; text-align: center; border: 1px solid rgba(244, 63, 94, 0.3); background: rgba(15, 5, 5, 0.6);">
                    <div class="w-20 h-20 rounded-full bg-red-500/10 flex items-center justify-center mx-auto mb-6 border border-red-500/20">
                        <i class="fas fa-user-shield text-red-500 text-3xl"></i>
                    </div>
                    <h3 style="font-size: 24px; font-weight: 800; margin-bottom: 15px; color: #fff;">Access Restricted</h3>
                    <p style="color: var(--text-secondary); line-height: 1.6; margin-bottom: 25px;">
                        Too many failed login attempts have been detected from your IP address. For your security, access has been temporarily restricted.You can try to login again after 1 hour.
                    </p>
                    <div style="background: rgba(255,255,255,0.03); padding: 20px; border-radius: 16px; border: 1px solid var(--glass-border); margin-bottom: 30px;">
                        <p style="font-size: 13px; color: var(--violet-light); text-transform: uppercase; font-weight: 700; margin-bottom: 8px;">Please contact administrator</p>
                        <a href="mailto:{{ blocked_admin_email }}" style="color: #38BDF8; font-weight: 700; font-size: 16px; text-decoration: none; word-break: break-all;">
                            {{ blocked_admin_email }}
                        </a>
                    </div>
                    <button type="button" onclick="document.getElementById('securityBlockOverlay').style.display='none'" 
                            style="width: 100%; padding: 16px; border-radius: 12px; border: 1px solid var(--glass-border); background: rgba(255,255,255,0.05); color: #fff; font-weight: 700; cursor: pointer; transition: all 0.3s;">
                        Close
                    </button>
                </div>
            </div>
        {% endif %}

        <!-- SCRIPT AFTER FORM -->
        <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("loginForm");
            if (form) {
                form.addEventListener("submit", function () { });
            }

            const overlay = document.getElementById("faceIdOverlay");
            const qrImage = document.getElementById("qrImage");
            const qrStatus = document.getElementById("qrStatus");
            const btnFaceId = document.getElementById("btnFaceIdLogin");
            const btnCancelQr = document.getElementById("btnCancelQr");

            var faceIdPollInterval = null;
            btnFaceId.addEventListener("click", async function () {
                btnFaceId.disabled = true;
                overlay.style.display = "flex";
                qrStatus.textContent = "Waiting for scan…";
                try {
                    const res = await fetch("{{ path('passkey_login_start') }}", { method: "POST", headers: { "X-Requested-With": "XMLHttpRequest", "Content-Type": "application/json" } });
                    const data = await res.json();
                    if (!data.qrUrl || !data.sessionId) {
                        qrStatus.textContent = "Could not start. Try again.";
                        btnFaceId.disabled = false;
                        return;
                    }
                    qrImage.src = "https://api.qrserver.com/v1/create-qr-code/?size=220x220&data=" + encodeURIComponent(data.qrUrl);
                    faceIdPollInterval = setInterval(async function () {
                        try {
                            const s = await fetch("{{ path('passkey_login_status') }}?session=" + encodeURIComponent(data.sessionId));
                            const st = await s.json();
                            if (st.status === "authenticated") {
                                clearInterval(faceIdPollInterval);
                                faceIdPollInterval = null;
                                qrStatus.textContent = "Success! Redirecting…";
                                window.location.href = "{{ path('passkey_login_confirm') }}?session=" + encodeURIComponent(data.sessionId);
                            } else if (st.status === "expired") {
                                clearInterval(faceIdPollInterval);
                                faceIdPollInterval = null;
                                qrStatus.textContent = "Link expired. Cancel and try again.";
                            }
                        } catch (e) {}
                    }, 1500);
                } catch (e) {
                    qrStatus.textContent = "Error. Try again.";
                    btnFaceId.disabled = false;
                }
            });

            if (btnCancelQr) {
                btnCancelQr.addEventListener("click", function () {
                    if (faceIdPollInterval) { clearInterval(faceIdPollInterval); faceIdPollInterval = null; }
                    overlay.style.display = "none";
                    btnFaceId.disabled = false;
                });
            }
        });
        </script>

    </div>

</div>
{% block footer %}{% endblock %}
{% endblock %}
