{% extends 'base.html.twig' %}

{% block title %}Sign In - FitSense{% endblock %}

{% block stylesheets %}
<style>
:root {
    --violet-primary: #8B5CF6;
    --violet-light: #A78BFA;
    --violet-dark: #6D28D9;
    --dark-bg: #030405;
    --glass-bg: rgba(255, 255, 255, 0.03);
    --glass-border: rgba(255, 255, 255, 0.08);
    --text-primary: #FFFFFF;
    --text-secondary: #94A3B8;
    --gradient-main: linear-gradient(135deg, #8B5CF6, #D8B4FE);
}

* { margin: 0; padding: 0; box-sizing: border-box; }

body {
    font-family: 'Inter', system-ui, sans-serif;
    background: var(--dark-bg);
    color: var(--text-primary);
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
}

/* Multi-layer Mesh Gradient Background */
body::before {
    content: "";
    position: absolute;
    width: 100%;
    height: 100%;
    background: 
        radial-gradient(circle at 10% 20%, rgba(139, 92, 246, 0.15) 0%, transparent 40%),
        radial-gradient(circle at 90% 80%, rgba(216, 180, 254, 0.1) 0%, transparent 40%);
    z-index: -1;
}

.auth-wrapper {
    width: 95%;
    max-width: 1000px;
    height: 600px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    background: var(--glass-bg);
    backdrop-filter: blur(25px);
    -webkit-backdrop-filter: blur(25px);
    border: 1px solid var(--glass-border);
    border-radius: 30px;
    box-shadow: 0 40px 100px rgba(0,0,0,0.8);
    overflow: hidden;
    animation: scaleIn 0.8s cubic-bezier(0.16, 1, 0.3, 1);
}

@keyframes scaleIn {
    from { opacity: 0; transform: scale(0.95) translateY(20px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
}

.auth-left {
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center; 
    text-align: center;
    padding: 60px;
    position: relative;
    background: linear-gradient(135deg, rgba(139, 92, 246, 0.1), rgba(216, 180, 254, 0.05));
    border-right: 1px solid var(--glass-border);
}

.auth-left::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 140%;
    height: 140%;
    transform: translate(-50%, -50%);
    background: radial-gradient(circle, rgba(139, 92, 246, 0.05) 0%, transparent 70%);
    pointer-events: none;
}

.auth-left img.hero-img { 
    width: 280px; 
    margin-bottom: 35px; 
    filter: drop-shadow(0 20px 40px rgba(139, 92, 246, 0.3));
    animation: float 4s ease-in-out infinite; 
}

@keyframes float { 
    0%,100% { transform: translateY(0) rotate(0deg); } 
    50% { transform: translateY(-30px) rotate(2deg); } 
}

.auth-left h1 { 
    font-size: 38px; 
    font-weight: 900; 
    margin-bottom: 15px; 
    background: var(--gradient-main); 
    -webkit-background-clip: text; 
    -webkit-text-fill-color: transparent; 
    letter-spacing: -1px;
}

.auth-left p { 
    font-size: 16px; 
    color: var(--text-secondary); 
    line-height: 1.6;
    max-width: 300px;
}

.auth-right { 
    padding: 60px; 
    display: flex; 
    flex-direction: column; 
    justify-content: center; 
    background: rgba(0,0,0,0.2);
}

.form-header h2 { 
    font-size: 36px; 
    font-weight: 800;
    margin-bottom: 8px; 
    letter-spacing: -1px;
}

.form-header p { 
    color: var(--text-secondary); 
    margin-bottom: 40px; 
    font-weight: 500;
}

.form-group { margin-bottom: 25px; position: relative; }

.form-group label {
    display: block;
    margin-bottom: 10px;
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--violet-light);
}

.form-group input {
    width: 100%;
    padding: 16px 20px;
    border-radius: 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid var(--glass-border);
    color: var(--text-primary);
    font-size: 16px;
    font-weight: 500;
    transition: all 0.3s ease;
}

.form-group input::placeholder { color: rgba(255,255,255,0.2); }

.form-group input:focus {
    outline: none;
    background: rgba(255,255,255,0.05);
    border-color: var(--violet-primary);
    box-shadow: 0 0 20px rgba(139, 92, 246, 0.2);
    transform: translateY(-1px);
}

.btn-signin {
    margin-top: 15px;
    width: 100%;
    padding: 18px;
    border-radius: 14px;
    border: none;
    background: var(--gradient-main);
    color: white;
    font-size: 16px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1px;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    box-shadow: 0 10px 30px rgba(139, 92, 246, 0.3);
}

.btn-signin:hover { 
    transform: translateY(-4px) scale(1.02); 
    box-shadow: 0 15px 40px rgba(139, 92, 246, 0.5); 
}

.btn-signin:active { transform: translateY(0); }

.signup-link { 
    text-align: center; 
    margin-top: 25px; 
    font-size: 15px; 
    color: var(--text-secondary);
}

.signup-link a { 
    color: var(--violet-light); 
    text-decoration: none; 
    font-weight: 800; 
    margin-left: 5px;
    transition: all 0.3s ease;
}

.signup-link a:hover { color: #fff; text-shadow: 0 0 10px var(--violet-light); }

.back-home {
    position: absolute;
    top: 30px;
    left: 30px;
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    color: var(--text-primary);
    font-weight: 700;
    font-size: 14px;
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(10px);
    padding: 10px 18px;
    border-radius: 12px;
    border: 1px solid var(--glass-border);
    transition: all 0.3s ease;
    z-index: 10;
}

.back-home:hover { 
    background: rgba(255,255,255,0.1); 
    border-color: var(--violet-light);
    transform: translateX(-5px);
}

.back-home svg { width: 18px; height: 18px; fill: var(--text-primary); transition: 0.3s; }
.back-home:hover svg { fill: var(--violet-light); }

.error-text { 
    color: #fda4af; 
    font-size: 14px; 
    font-weight: 600; 
    margin-top: 10px; 
    background: rgba(244, 63, 94, 0.1);
    padding: 10px;
    border-radius: 10px;
    border: 1px solid rgba(244, 63, 94, 0.2);
}

@media (max-width: 900px) {
    .auth-wrapper { grid-template-columns: 1fr; height: auto; }
    .auth-left { display: none; }
    body { overflow: auto; }
}
</style>
{% endblock %}

{% block header %}{% endblock %}

{% block body %}
<div class="auth-wrapper">

    <!-- LEFT -->
    <div class="auth-left">
        <a href="{{ path('app_home') }}" class="back-home">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                <path d="M20 11H7.83l5.59-5.59L12 4l-8 8 8 8 1.41-1.41L7.83 13H20v-2z"/>
            </svg>
            Home
        </a>

        <img src="/assets/images/sport-hero.png" class="hero-img" alt="Athlete">
        <h1>Push your limits</h1>
        <p>Feel the energy. Train smarter. Stay consistent.</p>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <div class="form-header">
            <h2>Welcome Back</h2>
            <p>Sign in to continue your fitness journey</p>
        </div>

        {% set fieldErrors = {} %}
        {% if error %}
            {% set parts = error.messageKey|split('|') %}
            {% for part in parts %}
                {% set sub = part|split(':') %}
                {% if sub|length == 2 %}
                    {% set fieldErrors = fieldErrors|merge({ (sub[0]): sub[1] }) %}
                {% endif %}
            {% endfor %}
        {% endif %}

        <form id="loginForm" method="post" action="{{ path('auth_sign_in') }}" novalidate>
            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" value="{{ last_username }}" placeholder="Email" required>
                {% if fieldErrors.email is defined %}
                    <div class="error-text">{{ fieldErrors.email }}</div>
                {% endif %}
            </div>

            <div class="form-group">
                <label>Password</label>
                <input type="password" name="password" placeholder="Password" required>
                {% if fieldErrors.password is defined %}
                    <div class="error-text">{{ fieldErrors.password }}</div>
                {% endif %}
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-signin">Sign In</button>
            <div class="mt-4 text-center text-sm">
                <a href="{{ path('app_forgot_password_request') }}"
                class="text-[#38BDF8] hover:text-[#A78BFA] font-medium transition">
                    Forgot your password?
                </a>
            </div>
        </form>

        {% if error and fieldErrors is empty %}
            <div class="error-text" style="justify-content: center; margin-top: 15px;">
                {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        <div class="signup-link">
            You don't have an account? 
            <a href="{{ path('auth_sign_up') }}">Sign Up</a>
        </div>

        <!-- SCRIPT AFTER FORM -->
        <script>
        document.addEventListener("DOMContentLoaded", function () {
            const form = document.getElementById("loginForm");
            if (!form) {
                console.error("❌ Login form not found");
                return;
            }
            form.addEventListener("submit", function () {
                console.log("🚀 FORM SUBMITTED");
            });
        });
        </script>

    </div>

</div>
{% block footer %}{% endblock %}
{% endblock %}
